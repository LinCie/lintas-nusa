<style>
	.nav-link::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 1.5px;
		background: var(--color-teal);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 200ms var(--ease-out-quart);
	}
	.nav-link:hover::after {
		transform: scaleX(1);
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-link::after {
			transition: none;
		}
	}

	.service-tab {
		border-bottom-color: transparent;
	}
	.service-tab.active {
		border-bottom-color: var(--color-teal);
		color: var(--color-navy);
		font-weight: 600;
	}
	.service-tab.active .tab-icon {
		opacity: 1;
		color: var(--color-teal);
	}
	.service-tab:not(.active):hover {
		color: var(--color-navy);
	}
	.service-tab:not(.active):hover .tab-icon {
		opacity: 1;
	}

	.service-expand-toggle[aria-expanded="true"] .toggle-chevron {
		transform: rotate(180deg);
	}
</style>

<script>
	import { initHomeAnimations } from "../scripts/home-animations";

	initHomeAnimations();

	const nav = document.getElementById("site-nav");
	const mobileMenu = document.getElementById("mobile-menu");
	const mobileMenuToggle = document.querySelector(".mobile-menu-toggle");

	function updateNav() {
		if (window.scrollY > 20) {
			nav?.classList.add("bg-mist/95", "backdrop-blur-md", "shadow-[0_1px_0_rgba(15,39,66,0.08)]");
		} else {
			nav?.classList.remove(
				"bg-mist/95",
				"backdrop-blur-md",
				"shadow-[0_1px_0_rgba(15,39,66,0.08)]",
			);
		}
	}

	function toggleMobileMenu() {
		const isOpen = mobileMenu?.classList.contains("open");
		mobileMenu?.classList.toggle("open");
		mobileMenuToggle?.setAttribute("aria-expanded", String(!isOpen));
		mobileMenu?.setAttribute("aria-hidden", String(isOpen));
	}

	function closeMobileMenu() {
		mobileMenu?.classList.remove("open");
		mobileMenuToggle?.setAttribute("aria-expanded", "false");
		mobileMenu?.setAttribute("aria-hidden", "true");
	}

	mobileMenuToggle?.addEventListener("click", toggleMobileMenu);

	mobileMenu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", closeMobileMenu);
	});

	window.addEventListener("scroll", updateNav, { passive: true });
	window.addEventListener("resize", closeMobileMenu);
	updateNav();

	/* Service tab switching */
	const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
	const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

	function activateTab(target: HTMLButtonElement) {
		tabs.forEach((tab) => {
			const isActive = tab === target;
			tab.classList.toggle("active", isActive);
			tab.setAttribute("aria-selected", String(isActive));
			tab.setAttribute("tabindex", isActive ? "0" : "-1");
		});
		panels.forEach((panel) => {
			const isTarget = panel.getAttribute("aria-labelledby") === target.id;
			if (isTarget) {
				panel.removeAttribute("hidden");
				panel.focus();
			} else {
				panel.setAttribute("hidden", "");
			}
		});
		const toggle = (target as Element)
			.closest(".service-tabs-wrapper")
			?.querySelector<HTMLButtonElement>(".service-expand-toggle");
		if (toggle) {
			const expandId = toggle.getAttribute("aria-controls");
			if (!expandId) return;
			const expandGroup = document.getElementById(expandId);
			if (expandGroup) {
				const isExpanded = toggle.getAttribute("aria-expanded") === "true";
				if (isExpanded) {
					expandGroup.hidden = true;
					toggle.setAttribute("aria-expanded", "false");
					const label = toggle.querySelector(".toggle-label");
					if (label) label.textContent = toggle.dataset.labelDefault ?? "";
					const chevron = toggle.querySelector<HTMLElement>(".toggle-chevron");
					if (chevron) chevron.style.transform = "";
				}
			}
		}
	}

	tabs.forEach((tab) => {
		tab.addEventListener("click", () => activateTab(tab));
		tab.addEventListener("keydown", (e: KeyboardEvent) => {
			if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
				e.preventDefault();
				const current = Array.from(tabs).indexOf(tab);
				const next =
					e.key === "ArrowRight"
						? (current + 1) % tabs.length
						: (current - 1 + tabs.length) % tabs.length;
				tabs[next].focus();
				activateTab(tabs[next]);
			}
		});
	});

	/* Service expand/collapse */
	document.querySelectorAll<HTMLButtonElement>(".service-expand-toggle").forEach((toggle) => {
		toggle.addEventListener("click", () => {
			const expandId = toggle.getAttribute("aria-controls");
			if (!expandId) return;
			const expandGroup = document.getElementById(expandId);
			if (!expandGroup) return;
			const isExpanded = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!isExpanded));
			expandGroup.hidden = isExpanded;
			const label = toggle.querySelector(".toggle-label");
			if (label) {
				label.textContent = isExpanded
					? (toggle.dataset.labelDefault ?? "")
					: (toggle.dataset.labelExpanded ?? "");
			}
		});
	});
</script>
