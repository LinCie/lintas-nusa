---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JangkauanExplorer from "../components/JangkauanExplorer.astro";

const pageTitle = "Jangkauan";
const pageDescription =
	"Coverage explorer LintasNusa untuk membaca wilayah aktif, lane yang terbuka, layanan yang masih review, dan proof layer yang menempel di setiap keputusan.";
---

<Layout title={pageTitle} description={pageDescription} pageName="jangkauan">
	<a
		href="#main-content"
		class="skip-to-content bg-navy font-body focus:outline-teal absolute -top-full left-4 z-9999 rounded-md px-5 py-3 text-sm font-semibold text-white no-underline transition-[top] duration-150 focus:top-4 focus:outline-2 focus:outline-offset-2"
		>Langsung ke konten</a
	>
	<Header />
	<div class="route-stage bg-white" data-page-view="jangkauan">
		<JangkauanExplorer />
		<Footer />
	</div>
</Layout>
