---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JangkauanExplorer from "../components/JangkauanExplorer.astro";

const pageTitle = "Jangkauan";
const pageDescription =
	"Jangkauan LintasNusa untuk melihat wilayah aktif, lane yang terbuka, layanan yang masih review, dan bukti yang menempel di setiap keputusan.";
---

<Layout title={pageTitle} description={pageDescription} pageName="jangkauan">
	<Header />
	<div class="route-stage bg-white" data-page-view="jangkauan">
		<JangkauanExplorer />
		<Footer />
	</div>
</Layout>
