---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const platformStats = [
	{ value: "18.500", label: "Bisnis Aktif", suffix: "" },
	{ value: "31", label: "Volume dari Dashboard & API", suffix: "%" },
	{ value: "97,9", label: "Kepatuhan Pemindaian", suffix: "%" },
];

const customerFeatures = [
	{
		title: "Lacak Tanpa Login",
		description:
			"Paket bisa dilacak lewat nomor AWB atau tautan langsung yang dibagikan pengirim. Tanpa harus membuat akun atau masuk dulu.",
		mechanism:
			"Sistem menghasilkan tautan unik per kiriman yang bisa dibuka recipient kapan saja. Setiap pemindaian memperbarui posisi secara real-time.",
	},
	{
		title: "Booking Pickup",
		description:
			"Jadwalkan penjemputan paket tanpa harus hubungi call center. Pilih tanggal, window waktu, dan titik ambil yang sesuai.",
		mechanism:
			"Setelah booking, kurir mendapat instruksi otomatis dan sender mendapat konfirmasi dengan detail penjemputan.",
	},
	{
		title: "Kalkulator Tarif",
		description:
			"Hitung estimasi biaya pengiriman sebelum memutuskan untuk kirim. Semua layanan yang tersedia di lane tersebut sudah termasuk dalam perhitungan.",
		mechanism:
			"Kalkulasi berdasarkan berat, dimensi, lane tujuan, dan layanan tambahan. Hasil ditampilkan dalam hitungan detik.",
	},
	{
		title: "Coverage Explorer",
		description:
			"Lihat lane yang aktif dan layanan yang tersedia per destination — bukan sekadar daftar kota.",
		mechanism:
			"Visualisasi lane per region dengan indikasi layanan aktif, tidak aktif, dan dalam review. Membantu estimasi kelayakan sebelum kirim.",
	},
	{
		title: "ETA dan Alerts",
		description:
			"Notifikasi akurat di setiap perubahan status pengiriman. Dari pickup sampai delivered.",
		mechanism:
			"ETA dihitung dari data historis lane dan kondisi aktual. Alerts dipicu saat paket berpindah scanner point atau ada exception.",
	},
	{
		title: "Reschedule dan Safe-Drop",
		description:
			"Penerima bisa atur ulang waktu terima atau tinggalkan instruksi untuk kurir tanpa harus hubungi CS.",
		mechanism:
			"Penerima akses via tautan lacak, pilih opsi reschedule atau masukkan instruksi safe-drop. Semua tercatat di sistem.",
	},
];

const merchantCapabilities = [
	{
		title: "Satu Login, Banyak Peran",
		description:
			"Owner, ops, finance, dan CS mengakses data yang sama dengan role masing-masing. Tidak perlu Bagi akses ke banyak platform.",
		detail:
			"Owner melihat ringkasan bisnis. Finance fokus ke settlement dan payout. Ops memantau performance lane. CS menangani exception. Semua dalam satu dashboard.",
	},
	{
		title: "Sync Pesanan",
		description:
			"Order dari marketplace, website, atau CSV masuk ke dashboard yang sama. Satu tempat untuk semua sumber order.",
		detail:
			"Mendukung integrasi dengan Tokopedia, Shopee, TikTok Shop, dan marketplace lainnya. API dan webhook untuk koneksi custom.",
	},
	{
		title: "Monitoring Multi-AWB",
		description:
			"Lacak puluhan hingga ratusan AWB secara bersamaan. Filter by status, lane, layanan, atau tanggal.",
		detail:
			"Dashboard menampilkan posisi semua paket dengan update real-time. Ekspor ke CSV atau Excel tersedia untuk pelaporan internal.",
	},
	{
		title: "SLA Performance Dashboard",
		description:
			"Lihat on-time rate per lane, per layanan, dan per periode. Proof nyata bukan claim promosi.",
		detail:
			"Data diambil dari scan compliance dan timestamps aktual. Breakdown bisa dilakukan per destination city atau region.",
	},
	{
		title: "NDR Analysis",
		description:
			"Pahami alasan kegagalan kirim (Non-Delivery Rate) per kategori dan mulai recovery lebih cepat.",
		detail:
			"NDR categories: address unclear, recipient unavailable, refused, damaged, dan lainnya. Setiap kategori menunjukkan count dan percentage.",
	},
	{
		title: "COD Settlement",
		description:
			"Rekonsiliasi payout dan tagihan COD tanpa laporan terpisah. Semua tercatat di dashboard yang sama.",
		detail:
			"Dana COD yang diterima direkonsiliasi dengan order yang dispatched. Settlement report bisa di-download per periode.",
	},
	{
		title: "Return Analytics",
		description:
			"Retur dibaca per alasan — bukan sekadar jumlah. Membantu tim product dan ops improvement.",
		detail:
			"Return reasons coded: wrong item, damaged, not as described, size mismatch, dan lainnya. Breakdown tersedia per product category.",
	},
	{
		title: "Invoice dan Dokumen Pajak",
		description:
			"Download invoice dan tax documents langsung dari dashboard. Tidak perlu ajukan ke finance team.",
		detail:
			"Invoice per shipment atau bulk per period. Format comply dengan ketentuan perpajakan Indonesia.",
	},
];

const enterpriseFeatures = [
	{
		title: "API dan Webhook Access",
		description:
			"Kirim data otomatis ke sistem Anda saat ada update lacak, tanpa middleware atau integrasi manual.",
		mechanism:
			"RESTful API dengan dokumentasi yang jelas. Webhook dipicu saat status berubah, delivered, atau exception.",
		useCases: [
			"Update internal tracking system",
			"Trigger downstream fulfillment",
			"Automate customer notification",
		],
	},
	{
		title: "ERP/WMS Integration",
		description:
			"Koneksi ke sistem manajemen gudang (WMS) dan keuangan (ERP) yang sudah berjalan di perusahaan.",
		mechanism:
			"Mendukung koneksi ke SAP, Oracle, JDE, dan sistem lokal Indonesia. Tim integrasi kami membantu onboarding.",
		useCases: [
			"Sync inventory dari WMS",
			"Auto-create shipment dari order ERP",
			"Reconcile COD dengan finance system",
		],
	},
	{
		title: "Dedicated Account View",
		description:
			"Struktur akun terpisah untuk klien dengan banyak cabang atau anak perusahaan. Isolasi data yang jelas.",
		mechanism:
			"Multi-entity support dengan parent-child relationship. Setiap entity punya own dashboard dan reporting.",
		useCases: [
			"Holding company dengan banyak subsidiary",
			"Franchise operations",
			"Multi-region management",
		],
	},
	{
		title: "Approval Workflows",
		description:
			"Tetapkan jenjang persetujuan untuk kiriman dan laporan. Notifikasi ke approver yang relevant.",
		mechanism:
			"Configurable approval chain based on shipment value, destination, atau service type. Audit trail lengkap.",
		useCases: [
			"High-value shipment approval",
			"Budget center authorization",
			"Cross-branch shipment validation",
		],
	},
	{
		title: "Incident Reporting",
		description:
			"Komunikasi gangguan terstruktur dengan service status page. Customer tidak perlu tanya-tanya.",
		mechanism:
			"Status page public yang menunjukkan service health per region dan service type. Incident reports dengan timeline.",
		useCases: [
			"Proactive customer communication",
			"SLA documentation for contracts",
			"Post-incident review",
		],
	},
];

const trustProofPoints = [
	{
		title: "Photo POD Gallery",
		description:
			"Bukti foto serah terima yang bisa diakses langsung dari dashboard. Bukan scanned dokumen.",
		proof:
			"Setiap delivery yang menggunakan LN Secure automatically captures photo. Photo stored minimal 90 hari.",
	},
	{
		title: "Geo-Stamped Scans",
		description:
			"Titik lokasi tiap pemindaian terekam otomatis. Latitude, longitude, dan timestamp.",
		proof:
			"Scan point diambil saat paket scan di setiap hub dan last-mile. Akurasi within 50 meter radius.",
	},
	{
		title: "Live Exception Alerts",
		description: "Notifikasi real-time saat ada hambatan di lapangan. Sebelum customer komplain.",
		proof:
			"Exception detected via comparing lokasi pemindaian actual dengan rute yang diharapkan. Alert dikirim via dashboard dan webhook.",
	},
	{
		title: "Claims Clock",
		description:
			"Timer klaim dengan target respons 2 × 24 jam. Setiap klaim punya deadline yang jelas.",
		proof:
			"Clock starts saat claim submitted. Dashboard menunjukkan countdown dan escalation status.",
	},
	{
		title: "Delivery Confidence Score",
		description:
			"Skor keandalan per route dan tipe layanan. Helps merchant set realistic expectation.",
		proof:
			"Dihitung dari historical data: on-time rate, NDR rate, dan exception frequency per lane.",
	},
];

const dashboardMockup = {
	label: "Dashboard Preview",
	title: "Satu layar. Seluruh operasi.",
	description:
		"Merchant dashboard menampilkan semua informasi critical tanpa harus switching tabs atau systems.",
};
---

<Layout
	title="Platform"
	description="Platform digital LintasNusa: dashboard terpadu untuk merchant, API untuk enterprise, dan recipient tools. Satu ekosistem untuk seluruh peran."
	pageName="platform"
>
	<a
		href="#main-content"
		class="skip-to-content bg-navy font-body focus:outline-teal absolute -top-full left-4 z-50 rounded-md px-5 py-3 text-sm font-semibold text-white no-underline transition-[top] duration-150 focus:top-4 focus:outline-2 focus:outline-offset-2"
		>Langsung ke konten</a
	>
	<Header />

	<div class="route-stage" data-page-view="platform">
		<!-- Hero Section -->
		<section
			id="hero"
			class="bg-navy relative flex min-h-[100dvh] flex-col justify-center overflow-hidden"
			aria-labelledby="platform-hero-heading"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<svg
					class="h-full w-full opacity-[0.04]"
					viewBox="0 0 1440 900"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					preserveAspectRatio="xMidYMid slice"
				>
					<defs>
						<pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
							<path d="M 80 0 L 0 0 0 80" fill="none" stroke="white" stroke-width="0.5"></path>
						</pattern>
					</defs>
					<rect width="100%" height="100%" fill="url(#grid)"></rect>
				</svg>
			</div>

			<div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-24 sm:px-8 lg:py-32">
				<div class="platform-hero-block max-w-3xl">
					<p
						class="hero-tagline-label text-teal mb-6 font-mono text-[10px] font-medium tracking-[0.25em] uppercase"
					>
						Platform Digital
					</p>
					<h1
						id="platform-hero-heading"
						class="hero-tagline font-display leading-[1.02] font-black tracking-tight text-white"
						style="font-size: clamp(3rem, 8vw, 5.5rem);"
					>
						Untuk bisnis yang butuh visibility, bukan sekadar kirim.
					</h1>
					<p
						class="platform-hero-copy font-body text-mist/70 mt-8 max-w-[52ch] text-base leading-relaxed sm:text-lg"
					>
						Satu akun untuk sender, recipient, merchant, finance, dan enterprise. Semua duduk di
						sistem yang sama — bukan portal yang berbeda.
					</p>
				</div>

				<div
					class="platform-stats mx-auto mt-12 grid max-w-xl grid-cols-2 gap-x-8 gap-y-6 sm:mx-0 sm:max-w-none sm:grid-cols-3 sm:gap-4"
				>
					{
						platformStats.map((stat) => (
							<div
								class="platform-stat"
								role="group"
								aria-label={`${stat.label}: ${stat.value}${stat.suffix}`}
							>
								<span class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-none font-bold text-white">
									{stat.value}
									<span class="text-teal">{stat.suffix}</span>
								</span>
								<p class="text-mist/70 mt-2 font-mono text-[9px] font-medium tracking-[0.15em] uppercase">
									{stat.label}
								</p>
							</div>
						))
					}
				</div>
			</div>

			<div
				class="hero-scroll-indicator absolute bottom-12 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3"
				aria-hidden="true"
			>
				<span class="font-mono text-[9px] font-medium tracking-[0.2em] text-white/30 uppercase">
					Scroll
				</span>
				<div class="scroll-line h-12 w-0.5 bg-linear-to-b from-white/40 to-transparent"></div>
			</div>
		</section>

		<!-- Ecosystem Narrative -->
		<section id="ekosistem" aria-labelledby="ekosistem-heading" class="bg-white py-20 lg:py-28">
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.55fr)] lg:gap-20"
				>
					<div class="ekosistem-prose space-y-6">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							One Ecosystem
						</span>
						<h2
							id="ekosistem-heading"
							class="font-display text-navy leading-[1.05] font-bold tracking-tight"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							Mengapa satu platform lebih baik dari banyak portal.
						</h2>
						<div class="space-y-4">
							<p class="font-body text-charcoal-mid text-base leading-[1.7]">
								Sebagian besar perusahaan logistik Memisahkan experience per role. Sender pakai satu
								app, recipient pakai tautan berbeda, merchant login ke dashboard terpisah, dan
								enterprise harus setup integrasi via email. Hasilnya: data terfragmentasi, tim kerja
								tidak sinkron, dan customer service menjelaskan status dari dua tempat.
							</p>
							<p class="font-body text-charcoal-mid text-base leading-[1.7]">
								LintasNusa dibangun dengan satu thesis: <strong class="text-navy"
									>logistics is not just movement — it is information discipline.</strong
								>
								Semua role melihat data yang sama, dari saat paket dijemput sampai settlement selesai.
								Update terjadi di satu tempat dan langsung visible untuk semua yang berkepentingan.
							</p>
						</div>
					</div>

					<aside class="ekosistem-sidebar self-start lg:pt-2">
						<div class="bg-mist rounded-2xl p-6 sm:p-8">
							<p
								class="text-navy/50 mb-5 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
							>
								Platform components
							</p>
							<ul class="space-y-4">
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Recipient tools — lacak, reschedule, safe-drop</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Merchant dashboard — order, SLA, COD, returns</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Enterprise API — sync, webhook, integration</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Trust layer — photo POD, geo-stamp, claims clock</span
									>
								</li>
							</ul>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<!-- Customer Platform Section -->
		<section
			id="pelanggan"
			aria-labelledby="pelanggan-heading"
			class="border-mist-dark border-t bg-white py-20 lg:py-28"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="platform-section-header mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:gap-16"
				>
					<div class="max-w-2xl space-y-5">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							Untuk Penerima
						</span>
						<h2
							id="pelanggan-heading"
							class="font-display text-navy leading-[1.05] font-bold tracking-tight"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							Recipient tools yang bekerja independent dari merchant.
						</h2>
						<p class="font-body text-charcoal-mid text-base leading-relaxed">
							Recipient tidak perlu install app atau punya account untuk lacak paket, ubah jadwal,
							atau berikan instruksi. Semua dilakukan dari tautan yang diberikan pengirim.
						</p>
					</div>
				</div>

				<div class="platform-features-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:gap-6">
					{
						customerFeatures.map((feature, index) => (
							<article class="platform-feature-card group border-mist-dark bg-mist/50 rounded-2xl border p-6 sm:p-7">
								<div class="mb-4 flex items-start justify-between gap-4">
									<span class="text-charcoal-mid/60 font-mono text-xs font-medium">
										{String(index + 1).padStart(2, "0")}
									</span>
								</div>
								<h3 class="font-display text-navy mb-2 text-lg font-bold tracking-tight">
									{feature.title}
								</h3>
								<p class="font-body text-charcoal-mid mb-4 text-sm leading-relaxed">
									{feature.description}
								</p>
								<div class="border-mist-dark border-t pt-4">
									<p class="text-teal mb-2 font-mono text-[10px] font-medium tracking-[0.15em] uppercase">
										Mechanism
									</p>
									<p class="font-body text-charcoal-mid/80 text-xs leading-relaxed">
										{feature.mechanism}
									</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- Merchant Dashboard Section -->
		<section
			id="merchant"
			aria-labelledby="merchant-heading"
			class="border-mist-dark bg-navy border-t py-20 lg:py-28"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="platform-section-header mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:gap-16"
				>
					<div class="max-w-2xl space-y-5">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							Merchant Dashboard
						</span>
						<h2
							id="merchant-heading"
							class="font-display leading-[1.05] font-bold tracking-tight text-white"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							satu login. Owner, ops, finance, CS.
						</h2>
						<p class="font-body text-mist/70 text-base leading-relaxed">
							Masing-masing role punya view yang sesuai dengan tanggung jawabnya — tetapi semua dari
							data yang sama. Tidak perlu switching antar platform.
						</p>
					</div>
				</div>

				<!-- Dashboard Mockup Visual -->
				<div class="platform-dashboard-mockup mb-12">
					<div
						class="bg-charcoal/80 relative overflow-hidden rounded-2xl border border-white/10 p-8 lg:p-12"
					>
						<div class="pointer-events-none absolute inset-0" aria-hidden="true">
							<div class="from-teal/5 absolute inset-0 bg-gradient-to-br to-transparent"></div>
						</div>
						<div class="relative z-10">
							<span
								class="font-mono text-[10px] font-medium tracking-[0.2em] text-white/40 uppercase"
							>
								{dashboardMockup.label}
							</span>
							<p class="font-display mt-3 text-2xl font-bold text-white lg:text-3xl">
								{dashboardMockup.title}
							</p>
							<p class="font-body text-mist/60 mt-2 max-w-[52ch] text-sm leading-relaxed">
								{dashboardMockup.description}
							</p>
							<div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-4">
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="Today: 1,284 shipments"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">
										Today
									</p>
									<p class="font-display text-xl font-bold text-white">1,284</p>
									<p class="font-body text-teal text-xs">Shipments</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="On-Time: 97.2% SLA Rate"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">
										On-Time
									</p>
									<p class="font-display text-xl font-bold text-white">97.2%</p>
									<p class="font-body text-teal text-xs">SLA Rate</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="COD: Rp 842jt to settle"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">COD</p>
									<p class="font-display text-xl font-bold text-white">Rp 842jt</p>
									<p class="font-body text-teal text-xs">To Settle</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="NDR: 2.8% rate"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">NDR</p>
									<p class="font-display text-xl font-bold text-white">2.8%</p>
									<p class="font-body text-teal text-xs">Rate</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="platform-capabilities-grid grid grid-cols-1 gap-5 lg:grid-cols-2">
					{
						merchantCapabilities.map((cap) => (
							<article class="platform-capability-card group rounded-2xl border border-white/10 bg-white/5 p-6 transition-colors duration-200 hover:bg-white/8">
								<h3 class="font-display mb-2 text-base font-bold tracking-tight text-white">
									{cap.title}
								</h3>
