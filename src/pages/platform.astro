---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const platformStats = [
	{ value: "18.500", label: "Bisnis Aktif", suffix: "" },
	{ value: "31", label: "Volume dari dashboard dan API", suffix: "%" },
	{ value: "97,9", label: "Kepatuhan Pemindaian", suffix: "%" },
];

const customerFeatures = [
	{
		title: "Lacak Tanpa Login",
		description:
			"Paket bisa dilacak lewat nomor AWB atau tautan yang dibagikan pengirim. Penerima tidak perlu membuat akun atau masuk dulu.",
		mechanism:
			"Sistem membuat tautan unik per kiriman yang bisa dibuka penerima kapan saja. Setiap pemindaian memperbarui posisi secara real-time.",
	},
	{
		title: "Booking Pickup",
		description:
			"Jadwalkan penjemputan paket tanpa perlu menghubungi call center. Pilih tanggal, jendela waktu, dan titik ambil yang sesuai.",
		mechanism:
			"Setelah booking, kurir menerima instruksi otomatis dan pengirim mendapat konfirmasi dengan detail penjemputan.",
	},
	{
		title: "Kalkulator Tarif",
		description:
			"Hitung estimasi biaya kirim sebelum memutuskan untuk mengirim. Semua layanan yang tersedia di lane tersebut sudah ikut dihitung.",
		mechanism:
			"Kalkulasi berdasarkan berat, dimensi, lane tujuan, dan layanan tambahan. Hasilnya tampil dalam hitungan detik.",
	},
	{
		title: "Coverage Explorer",
		description:
			"Lihat lane yang aktif dan layanan yang tersedia per tujuan, bukan sekadar daftar kota.",
		mechanism:
			"Visualisasi lane per region dengan status aktif, tidak aktif, dan review. Membantu menilai kelayakan sebelum kirim.",
	},
	{
		title: "ETA dan Alerts",
		description:
			"Notifikasi muncul di setiap perubahan status pengiriman, dari pickup sampai delivered.",
		mechanism:
			"ETA dihitung dari data historis lane dan kondisi aktual. Alerts dipicu saat paket berpindah scan point atau ada exception.",
	},
	{
		title: "Reschedule dan Safe-Drop",
		description:
			"Penerima bisa mengatur ulang waktu terima atau meninggalkan instruksi untuk kurir tanpa menghubungi CS.",
		mechanism:
			"Penerima membuka tautan lacak, memilih reschedule atau mengisi instruksi safe-drop. Semua tercatat di sistem.",
	},
];

const merchantCapabilities = [
	{
		title: "Satu Login, Banyak Peran",
		description:
			"Owner, ops, finance, dan CS mengakses data yang sama dengan peran masing-masing. Tidak perlu membagi akses ke banyak platform.",
		detail:
			"Owner melihat ringkasan bisnis. Finance fokus ke settlement dan payout. Ops memantau performa lane. CS menangani exception. Semua ada di satu dashboard.",
	},
	{
		title: "Sinkronisasi Pesanan",
		description:
			"Pesanan dari marketplace, website, atau CSV masuk ke dashboard yang sama. Semua sumber pesanan terkumpul di satu tempat.",
		detail:
			"Mendukung integrasi dengan Tokopedia, Shopee, TikTok Shop, dan marketplace lainnya. API dan webhook tersedia untuk koneksi khusus.",
	},
	{
		title: "Monitoring Multi-AWB",
		description:
			"Lacak puluhan hingga ratusan AWB secara bersamaan. Filter berdasarkan status, lane, layanan, atau tanggal.",
		detail:
			"Dashboard menampilkan posisi semua paket dengan update real-time. Ekspor ke CSV atau Excel tersedia untuk laporan internal.",
	},
	{
		title: "Dashboard Kinerja SLA",
		description:
			"Lihat on-time rate per lane, per layanan, dan per periode. Bukti nyata, bukan klaim promosi.",
		detail:
			"Data diambil dari scan compliance dan timestamp aktual. Rincian bisa dilakukan per kota tujuan atau wilayah.",
	},
	{
		title: "Analisis NDR",
		description: "Pahami alasan kegagalan kirim per kategori dan mulai recovery lebih cepat.",
		detail:
			"Kategori NDR: alamat tidak jelas, penerima tidak tersedia, ditolak, rusak, dan lainnya. Setiap kategori menunjukkan jumlah dan persentase.",
	},
	{
		title: "COD Settlement",
		description:
			"Rekonsiliasi payout dan tagihan COD tanpa laporan terpisah. Semua tercatat di dashboard yang sama.",
		detail:
			"Dana COD yang diterima direkonsiliasi dengan pesanan yang dikirim. Laporan settlement bisa diunduh per periode.",
	},
	{
		title: "Return Analytics",
		description:
			"Retur dibaca per alasan, bukan sekadar jumlah. Membantu tim product dan ops memperbaiki proses.",
		detail:
			"Alasan retur dikodekan: barang salah, rusak, tidak sesuai deskripsi, ukuran tidak cocok, dan lainnya. Rincian tersedia per kategori produk.",
	},
	{
		title: "Invoice dan Dokumen Pajak",
		description:
			"Unduh invoice dan dokumen pajak langsung dari dashboard. Tidak perlu minta ke tim finance.",
		detail:
			"Invoice tersedia per shipment atau bulk per periode. Formatnya mengikuti ketentuan perpajakan Indonesia.",
	},
];

const enterpriseFeatures = [
	{
		title: "Akses API dan Webhook",
		description:
			"Kirim data otomatis ke sistem Anda saat ada update lacak, tanpa middleware atau integrasi manual.",
		mechanism:
			"RESTful API dengan dokumentasi yang jelas. Webhook dipicu saat status berubah, paket terkirim, atau exception muncul.",
		useCases: [
			"Perbarui sistem pelacakan internal",
			"Picu fulfillment berikutnya",
			"Otomatiskan notifikasi pelanggan",
		],
	},
	{
		title: "Integrasi ERP/WMS",
		description:
			"Koneksi ke sistem manajemen gudang (WMS) dan keuangan (ERP) yang sudah berjalan di perusahaan.",
		mechanism:
			"Mendukung koneksi ke SAP, Oracle, JDE, dan sistem lokal Indonesia. Tim integrasi kami membantu onboarding.",
		useCases: [
			"Sinkronkan inventori dari WMS",
			"Buat pengiriman otomatis dari pesanan ERP",
			"Rekonsiliasi COD dengan sistem finance",
		],
	},
	{
		title: "Tampilan Akun Khusus",
		description:
			"Struktur akun terpisah untuk klien dengan banyak cabang atau anak perusahaan. Data tetap terisolasi dengan jelas.",
		mechanism:
			"Dukungan multi-entitas dengan hubungan induk-anak. Setiap entitas punya dashboard dan pelaporan sendiri.",
		useCases: [
			"Holding company dengan banyak anak usaha",
			"Operasi waralaba",
			"Manajemen lintas wilayah",
		],
	},
	{
		title: "Alur Persetujuan",
		description:
			"Tetapkan jenjang persetujuan untuk kiriman dan laporan. Notifikasi dikirim ke penyetuju yang relevan.",
		mechanism:
			"Rantai persetujuan bisa dikonfigurasi berdasarkan nilai kiriman, tujuan, atau jenis layanan. Audit trail lengkap.",
		useCases: [
			"Persetujuan kiriman bernilai tinggi",
			"Otorisasi pusat biaya",
			"Validasi kiriman lintas cabang",
		],
	},
	{
		title: "Pelaporan Insiden",
		description:
			"Komunikasi gangguan yang terstruktur lewat halaman status layanan. Pelanggan tidak perlu bertanya satu per satu.",
		mechanism:
			"Halaman status publik yang menunjukkan kesehatan layanan per wilayah dan jenis layanan. Laporan insiden menampilkan timeline.",
		useCases: [
			"Komunikasi proaktif ke pelanggan",
			"Dokumentasi SLA untuk kontrak",
			"Tinjauan pascainsiden",
		],
	},
];

const trustProofPoints = [
	{
		title: "Galeri Photo POD",
		description:
			"Bukti foto serah terima yang bisa diakses langsung dari dashboard, bukan scan dokumen.",
		proof:
			"Setiap pengiriman yang memakai LN Secure otomatis mengambil foto. Foto disimpan minimal 90 hari.",
	},
	{
		title: "Scan dengan Geo-Stamp",
		description:
			"Titik lokasi tiap pemindaian terekam otomatis, lengkap dengan latitude, longitude, dan timestamp.",
		proof:
			"Scan point diambil saat paket dipindai di setiap hub dan last-mile. Akurasi dalam radius 50 meter.",
	},
	{
		title: "Peringatan Exception Langsung",
		description: "Notifikasi real-time saat ada hambatan di lapangan, sebelum pelanggan komplain.",
		proof:
			"Exception terdeteksi dengan membandingkan lokasi scan aktual dan rute yang diharapkan. Peringatan dikirim lewat dashboard dan webhook.",
	},
	{
		title: "Jam Klaim",
		description:
			"Timer klaim dengan target respons 2 × 24 jam. Setiap klaim punya batas waktu yang jelas.",
		proof:
			"Jam berjalan saat klaim dikirim. Dashboard menampilkan hitung mundur dan status eskalasi.",
	},
	{
		title: "Skor Keandalan Pengiriman",
		description:
			"Skor keandalan per rute dan jenis layanan. Membantu merchant menetapkan ekspektasi yang realistis.",
		proof: "Dihitung dari data historis: on-time rate, NDR rate, dan frekuensi exception per lane.",
	},
];

const dashboardMockup = {
	label: "Pratinjau Dashboard",
	title: "Satu layar. Seluruh operasi.",
	description:
		"Dasbor merchant menampilkan semua informasi penting tanpa harus pindah tab atau sistem.",
};
---

<Layout
	title="Platform"
	description="Platform digital LintasNusa: dashboard terpadu untuk merchant, API untuk enterprise, dan alat penerima. Satu ekosistem untuk seluruh peran."
	pageName="platform"
>
	<Header />

	<div class="route-stage" data-page-view="platform">
		<!-- Hero Section -->
		<section
			id="hero"
			class="bg-navy relative flex min-h-[100dvh] flex-col justify-center overflow-hidden"
			aria-labelledby="platform-hero-heading"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<svg
					class="h-full w-full opacity-[0.04]"
					viewBox="0 0 1440 900"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					preserveAspectRatio="xMidYMid slice"
				>
					<defs>
						<pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
							<path d="M 80 0 L 0 0 0 80" fill="none" stroke="white" stroke-width="0.5"></path>
						</pattern>
					</defs>
					<rect width="100%" height="100%" fill="url(#grid)"></rect>
				</svg>
			</div>

			<div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-24 sm:px-8 lg:py-32">
				<div class="platform-hero-block max-w-3xl">
					<p
						class="hero-tagline-label text-teal mb-6 font-mono text-[10px] font-medium tracking-[0.25em] uppercase"
					>
						Platform Digital
					</p>
					<h1
						id="platform-hero-heading"
						class="hero-tagline font-display leading-[1.02] font-black tracking-tight text-white"
						style="font-size: clamp(3rem, 8vw, 5.5rem);"
					>
						Untuk bisnis yang butuh visibilitas, bukan sekadar kirim.
					</h1>
					<p
						class="platform-hero-copy font-body text-mist/70 mt-8 max-w-[52ch] text-base leading-relaxed sm:text-lg"
					>
						Satu akun untuk pengirim, penerima, merchant, finance, dan enterprise. Semua bekerja di
						sistem yang sama, bukan portal yang berbeda.
					</p>
				</div>

				<div
					class="platform-stats mx-auto mt-12 grid max-w-xl grid-cols-2 gap-x-8 gap-y-6 sm:mx-0 sm:max-w-none sm:grid-cols-3 sm:gap-4"
				>
					{
						platformStats.map((stat) => (
							<div
								class="platform-stat"
								role="group"
								aria-label={`${stat.label}: ${stat.value}${stat.suffix}`}
							>
								<span class="font-display text-[clamp(1.5rem,3vw,2rem)] leading-none font-bold text-white">
									{stat.value}
									<span class="text-teal">{stat.suffix}</span>
								</span>
								<p class="text-mist/70 mt-2 font-mono text-[9px] font-medium tracking-[0.15em] uppercase">
									{stat.label}
								</p>
							</div>
						))
					}
				</div>
			</div>

			<div
				class="hero-scroll-indicator absolute bottom-12 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3"
				aria-hidden="true"
			>
				<span class="font-mono text-[9px] font-medium tracking-[0.2em] text-white/30 uppercase">
					Scroll
				</span>
				<div class="scroll-line h-12 w-0.5 bg-linear-to-b from-white/40 to-transparent"></div>
			</div>
		</section>

		<!-- Ecosystem Narrative -->
		<section id="ekosistem" aria-labelledby="ekosistem-heading" class="bg-white py-20 lg:py-28">
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.55fr)] lg:gap-20"
				>
					<div class="ekosistem-prose space-y-6">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							Satu ekosistem
						</span>
						<h2
							id="ekosistem-heading"
							class="font-display text-navy leading-[1.05] font-bold tracking-tight"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							Kenapa satu platform lebih rapi daripada banyak portal.
						</h2>
						<div class="space-y-4">
							<p class="font-body text-charcoal-mid text-base leading-[1.7]">
								Banyak perusahaan logistik memisahkan pengalaman per peran. Pengirim memakai satu
								aplikasi, penerima memakai tautan berbeda, merchant login ke dashboard terpisah, dan
								enterprise harus menyiapkan integrasi lewat email. Hasilnya, data terfragmentasi,
								tim tidak sinkron, dan tim layanan pelanggan menjelaskan status dari tempat yang
								berbeda.
							</p>
							<p class="font-body text-charcoal-mid text-base leading-[1.7]">
								LintasNusa dibangun dengan satu tesis: <strong class="text-navy"
									>logistik bukan cuma gerak, melainkan disiplin informasi.</strong
								>
								Semua peran membaca data yang sama, dari saat paket dijemput sampai settlement selesai.
								Update terjadi di satu tempat dan langsung terlihat oleh semua pihak yang berkepentingan.
							</p>
						</div>
					</div>

					<aside class="ekosistem-sidebar self-start lg:pt-2">
						<div class="bg-mist rounded-2xl p-6 sm:p-8">
							<p
								class="text-navy/50 mb-5 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
							>
								Komponen platform
							</p>
							<ul class="space-y-4">
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Alat penerima: lacak, atur ulang, safe-drop</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Dashboard merchant: pesanan, SLA, COD, retur</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>API enterprise: sinkronisasi, webhook, integrasi</span
									>
								</li>
								<li class="flex items-start gap-3">
									<span class="bg-teal mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full"></span>
									<span class="font-body text-charcoal-mid text-sm leading-relaxed"
										>Lapisan bukti: photo POD, geo-stamp, jam klaim</span
									>
								</li>
							</ul>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<!-- Customer Platform Section -->
		<section
			id="pelanggan"
			aria-labelledby="pelanggan-heading"
			class="border-mist-dark border-t bg-white py-20 lg:py-28"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="platform-section-header mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:gap-16"
				>
					<div class="max-w-2xl space-y-5">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							Untuk Penerima
						</span>
						<h2
							id="pelanggan-heading"
							class="font-display text-navy leading-[1.05] font-bold tracking-tight"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							Alat untuk penerima yang bekerja terpisah dari merchant.
						</h2>
						<p class="font-body text-charcoal-mid text-base leading-relaxed">
							Penerima tidak perlu memasang aplikasi atau punya akun untuk melacak paket, mengubah
							jadwal, atau memberi instruksi. Semua dilakukan dari tautan yang dibagikan pengirim.
						</p>
					</div>
				</div>

				<div class="platform-features-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:gap-6">
					{
						customerFeatures.map((feature, index) => (
							<article class="platform-feature-card group border-mist-dark bg-mist/50 rounded-2xl border p-6 sm:p-7">
								<div class="mb-4 flex items-start justify-between gap-4">
									<span class="text-charcoal-mid/60 font-mono text-xs font-medium">
										{String(index + 1).padStart(2, "0")}
									</span>
								</div>
								<h3 class="font-display text-navy mb-2 text-lg font-bold tracking-tight">
									{feature.title}
								</h3>
								<p class="font-body text-charcoal-mid mb-4 text-sm leading-relaxed">
									{feature.description}
								</p>
								<div class="border-mist-dark border-t pt-4">
									<p class="text-teal mb-2 font-mono text-[10px] font-medium tracking-[0.15em] uppercase">
										Cara kerja
									</p>
									<p class="font-body text-charcoal-mid/80 text-xs leading-relaxed">
										{feature.mechanism}
									</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- Merchant Dashboard Section -->
		<section
			id="merchant"
			aria-labelledby="merchant-heading"
			class="border-mist-dark bg-navy border-t py-20 lg:py-28"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="platform-section-header mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:gap-16"
				>
					<div class="max-w-2xl space-y-5">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
							Dashboard merchant
						</span>
						<h2
							id="merchant-heading"
							class="font-display leading-[1.05] font-bold tracking-tight text-white"
							style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);"
						>
							Satu login untuk owner, ops, finance, dan CS.
						</h2>
						<p class="font-body text-mist/70 text-base leading-relaxed">
							Masing-masing peran punya tampilan yang sesuai dengan tanggung jawabnya, tetapi semua
							membaca data yang sama. Tidak perlu pindah antar platform.
						</p>
					</div>
				</div>

				<!-- Dashboard Mockup Visual -->
				<div class="platform-dashboard-mockup mb-12">
					<div
						class="bg-charcoal/80 relative overflow-hidden rounded-2xl border border-white/10 p-8 lg:p-12"
					>
						<div class="pointer-events-none absolute inset-0" aria-hidden="true">
							<div class="from-teal/5 absolute inset-0 bg-gradient-to-br to-transparent"></div>
						</div>
						<div class="relative z-10">
							<span
								class="font-mono text-[10px] font-medium tracking-[0.2em] text-white/40 uppercase"
							>
								{dashboardMockup.label}
							</span>
							<p class="font-display mt-3 text-2xl font-bold text-white lg:text-3xl">
								{dashboardMockup.title}
							</p>
							<p class="font-body text-mist/60 mt-2 max-w-[52ch] text-sm leading-relaxed">
								{dashboardMockup.description}
							</p>
							<div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-4">
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="Hari ini: 1.284 pengiriman"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">
										Hari ini
									</p>
									<p class="font-display text-xl font-bold text-white">1,284</p>
									<p class="font-body text-teal text-xs">Pengiriman</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="Tepat waktu: 97,2% rasio SLA"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">
										Tepat waktu
									</p>
									<p class="font-display text-xl font-bold text-white">97.2%</p>
									<p class="font-body text-teal text-xs">Rasio SLA</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
									aria-label="COD: Rp 842 juta menunggu settlement"
								>
									<p class="text-mist/70 mb-1 font-mono text-[10px] tracking-wide uppercase">COD</p>
									<p class="font-display text-xl font-bold text-white">Rp 842jt</p>
									<p class="font-body text-teal text-xs">Menunggu settlement</p>
								</div>
								<div
									class="rounded-xl border border-white/8 bg-white/5 p-4"
									role="group"
