---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Tentang";
const pageDescription =
	"Profil LintasNusa Logistics, perusahaan logistik digital Indonesia yang membangun satu sistem operasional untuk brand, UMKM, dan enterprise.";
---

<Layout title={pageTitle} description={pageDescription} pageName="tentang">
	<a
		href="#main-content"
		class="skip-to-content bg-navy font-body focus:outline-teal absolute -top-full left-4 z-9999 rounded-md px-5 py-3 text-sm font-semibold text-white no-underline transition-[top] duration-150 focus:top-4 focus:outline-2 focus:outline-offset-2"
		>Langsung ke konten</a
	>
	<Header />

	<nav
		id="section-nav"
		class="section-nav fixed top-18 z-40 w-full bg-white/95 backdrop-blur-sm"
		aria-label="Section navigation"
	>
		<div class="mx-auto flex max-w-7xl items-center px-4 sm:px-8">
			<div
				class="flex items-center gap-0.5 overflow-x-auto py-3 text-[11px] font-medium tracking-wide sm:gap-2"
			>
				<a
					href="#cerita"
					class="section-nav-link shrink-0 rounded px-3 py-1.5 text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
					data-section="cerita"
				>
					Cerita
				</a>
				<span class="text-charcoal-mid/20 mx-1" aria-hidden="true">/</span>
				<a
					href="#misi"
					class="section-nav-link shrink-0 rounded px-3 py-1.5 text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
					data-section="misi"
				>
					Visi & Misi
				</a>
				<span class="text-charcoal-mid/20 mx-1" aria-hidden="true">/</span>
				<a
					href="#nilai"
					class="section-nav-link shrink-0 rounded px-3 py-1.5 text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
					data-section="nilai"
				>
					Nilai Inti
				</a>
				<span class="text-charcoal-mid/20 mx-1" aria-hidden="true">/</span>
				<a
					href="#kepemimpinan"
					class="section-nav-link shrink-0 rounded px-3 py-1.5 text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
					data-section="kepemimpinan"
				>
					Kepemimpinan
				</a>
				<span class="text-charcoal-mid/20 mx-1" aria-hidden="true">/</span>
				<a
					href="#kontak"
					class="section-nav-link shrink-0 rounded px-3 py-1.5 text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
					data-section="kontak"
				>
					Kontak
				</a>
			</div>
		</div>
	</nav>

	<div class="route-stage" data-page-view="tentang">
		<section
			id="hero"
			class="bg-navy relative flex min-h-svh flex-col justify-center overflow-hidden"
			aria-labelledby="hero-tagline"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<svg
					class="h-full w-full"
					viewBox="0 0 1440 900"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					preserveAspectRatio="xMidYMid slice"
				>
					<path
						d="M-60 700 Q180 580 400 600 T900 520 T1400 480 T1540 460"
						stroke="var(--color-teal)"
						stroke-width="1"
						opacity="0.12"></path>
					<path
						d="M-60 640 Q200 520 440 540 T940 460 T1440 420 T1540 400"
						stroke="var(--color-teal)"
						stroke-width="0.5"
						opacity="0.08"></path>
					<path
						d="M-60 360 Q180 440 420 400 T920 340 T1420 300 T1540 280"
						stroke="var(--color-teal)"
						stroke-width="1"
						opacity="0.10"></path>
					<path
						d="M-60 300 Q240 380 480 340 T980 280 T1480 240 T1540 220"
						stroke="var(--color-teal)"
						stroke-width="0.5"
						opacity="0.06"></path>
					<line
						x1="720"
						y1="0"
						x2="720"
						y2="900"
						stroke="var(--color-teal)"
						stroke-width="0.4"
						opacity="0.05"
						stroke-dasharray="6 12"></line>
					<circle cx="720" cy="450" r="2" fill="var(--color-teal)" opacity="0.15"></circle>
					<circle cx="400" cy="600" r="1.5" fill="var(--color-teal)" opacity="0.12"></circle>
					<circle cx="900" cy="520" r="1.5" fill="var(--color-teal)" opacity="0.10"></circle>
					<circle cx="420" cy="400" r="1.5" fill="var(--color-teal)" opacity="0.12"></circle>
					<circle cx="920" cy="340" r="1.5" fill="var(--color-teal)" opacity="0.10"></circle>
					<circle cx="200" cy="680" r="1" fill="var(--color-teal)" opacity="0.08"></circle>
					<circle cx="1100" cy="420" r="1" fill="var(--color-teal)" opacity="0.08"></circle>
					<circle cx="600" cy="320" r="1" fill="var(--color-teal)" opacity="0.08"></circle>
					<circle cx="1000" cy="280" r="1" fill="var(--color-teal)" opacity="0.08"></circle>
				</svg>
			</div>

			<div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-24 sm:px-8 lg:py-32">
				<div class="hero-tagline-block max-w-4xl">
					<p
						class="hero-tagline-label text-teal mb-6 font-mono text-[10px] font-medium tracking-[0.25em] uppercase"
					>
						PT Lintas Nusa Terpadu, Didirikan 2021
					</p>
					<h1
						id="hero-tagline"
						class="hero-tagline font-display leading-[1.02] font-black tracking-tight text-white"
						style="font-size: clamp(3rem, 8vw, 6rem);"
					>
						Satu Sistem.<br />Seluruh Nusantara.
					</h1>
					<p
						class="hero-tagline-sub font-body text-mist/70 mt-8 max-w-[52ch] text-base leading-relaxed sm:text-lg"
					>
						Kami membangun logistik yang tidak sekadar menggerakkan paket, tetapi juga
						menginformasikan setiap langkahnya. Dari pickup hingga penerima, satu sistem, satu cara
						kerja.
					</p>
				</div>

				<div class="hero-thesis-block mt-16 max-w-2xl">
					<div class="border-t border-white/10 pt-8">
						<p
							class="mb-3 font-mono text-[10px] font-medium tracking-[0.2em] text-white/40 uppercase"
						>
							Tesis Perusahaan
						</p>
						<p
							class="font-display text-mist/90 text-[clamp(1.25rem,2.5vw,1.75rem)] leading-tight font-bold tracking-tight"
						>
							Logistik bukanlah sekadar gerak. Ia adalah disiplin informasi.
						</p>
						<p
							class="mt-4 font-mono text-[9px] font-medium tracking-[0.15em] text-white/30 uppercase"
						>
							L — Lugas &nbsp;&nbsp; I — Integritas &nbsp;&nbsp; N — Nyata &nbsp;&nbsp; T — Tanggap
							&nbsp;&nbsp; A — Andal &nbsp;&nbsp; S — Selaras
						</p>
					</div>
				</div>
			</div>

			<div
				class="hero-scroll-indicator absolute bottom-12 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3"
				aria-hidden="true"
			>
				<span class="font-mono text-[9px] font-medium tracking-[0.2em] text-white/30 uppercase">
					Scroll
				</span>
				<div class="scroll-line h-12 w-0.5 bg-linear-to-b from-white/40 to-transparent"></div>
			</div>
		</section>

		<section id="cerita" aria-labelledby="cerita-heading" class="bg-white py-24 lg:py-32">
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div
					class="grid grid-cols-1 gap-16 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.5fr)] lg:gap-24"
				>
					<div class="cerita-prose space-y-8">
						<div class="mb-10">
							<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
								Asal Mula
							</span>
						</div>

						<div class="cerita-block space-y-6">
							<h2
								id="cerita-heading"
								class="font-display text-navy leading-[1.05] font-bold tracking-tight"
								style="font-size: clamp(2rem, 4vw, 3rem);"
							>
								Masalahnya sederhana: logistik sudah digital, tapi terpecah di banyak sistem.
							</h2>

							<div class="space-y-5">
								<p class="font-body text-charcoal-mid text-base leading-relaxed">
									LintasNusa didirikan tahun 2021 di Jakarta Selatan oleh tim yang sebelumnya
									bekerja di operasi e-commerce, distribusi last-mile, dan produk SaaS.
									Masing-masing mengalami masalah yang sama: pengiriman sudah digital, tapi
									pengalamannya terpecah di banyak portal, aplikasi, dan subdomain yang berbeda.
								</p>

								<p class="font-body text-charcoal-mid text-base leading-relaxed">
									Seller mengelola pesanan di satu dashboard. Tim finance membaca laporan di sistem
									lain. Customer service mengejar ticket di platform terpisah. Sementara itu,
									penerima paket sering hanya bisa menunggu tanpa tahu pasti di mana paket mereka
									berada.
								</p>

								<p class="font-body text-charcoal-mid text-base leading-relaxed">
									Tim kami sampai pada kesimpulan yang sama: <em
										>pengalaman logistics yang baik bukan tentang memiliki aplikasi terbanyak,
										melainkan tentang membangun satu sistem yang bekerja sebagai satu kesatuan.</em
									>
								</p>
							</div>
						</div>

						<div class="cerita-thesis border-teal/30 bg-teal/5 rounded-xl border p-6">
							<p
								class="font-display text-navy text-[clamp(1.25rem,2.5vw,1.75rem)] leading-tight font-bold tracking-tight"
							>
								Kami merancang LintasNusa sebagai sistem operasi tunggal untuk pengiriman,
								fulfillment, pelacakan, klaim, dan retur.
							</p>
							<p
								class="text-charcoal-mid/50 mt-3 font-mono text-[9px] font-medium tracking-[0.12em] uppercase"
							>
								Enam nilai: Lugas, Integritas, Nyata, Tanggap, Andal, Selaras.
							</p>
						</div>
					</div>

					<aside class="cerita-sidebar self-start lg:sticky lg:top-32 lg:pt-2">
						<div class="border-mist-dark bg-mist/50 rounded-3xl border p-6 sm:p-8">
							<p
								class="text-navy/50 mb-5 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
							>
								Profil perusahaan
							</p>
							<dl class="space-y-5">
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Nama
									</dt>
									<dd class="font-display text-navy mt-1 text-base font-bold">
										LintasNusa Logistics
									</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Entitas Hukum
									</dt>
									<dd class="font-body text-charcoal-mid mt-1 text-sm">PT Lintas Nusa Terpadu</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Diresmikan
									</dt>
									<dd class="font-body text-charcoal-mid mt-1 text-sm">2021</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Kantor Pusat
									</dt>
									<dd class="font-body text-charcoal-mid mt-1 text-sm">Jakarta Selatan</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Kota & Kabupaten
									</dt>
									<dd class="font-display text-navy mt-1 text-2xl font-bold">247</dd>
									<dd class="text-charcoal-mid/50 font-mono text-[8px] tracking-wide">
										Jawa, Sumatra, Kalimantan, Sulawesi
									</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Gateway Hub
									</dt>
									<dd class="font-display text-navy mt-1 text-2xl font-bold">9</dd>
									<dd class="text-charcoal-mid/50 font-mono text-[8px] tracking-wide">
										strategic cross-island points
									</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Satellite Hub
									</dt>
									<dd class="font-display text-navy mt-1 text-2xl font-bold">38</dd>
									<dd class="text-charcoal-mid/50 font-mono text-[8px] tracking-wide">
										last-mile coverage points
									</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Armada Kendaraan
									</dt>
									<dd class="font-display text-navy mt-1 text-2xl font-bold">1.120</dd>
									<dd class="text-charcoal-mid/50 font-mono text-[8px] tracking-wide">
										proprietary fleet units
									</dd>
								</div>
								<div>
									<dt
										class="text-charcoal-mid/70 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
									>
										Tim & Partner
									</dt>
									<dd class="font-display text-navy mt-1 text-2xl font-bold">2.850</dd>
									<dd class="text-charcoal-mid/50 font-mono text-[8px] tracking-wide">
										employees & logistics partners
									</dd>
								</div>
							</dl>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<section
			id="misi"
			aria-labelledby="misi-heading"
			class="bg-mist/40 border-mist-dark border-t py-24 lg:py-32"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div class="mb-16 max-w-2xl">
					<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
						Visi & Misi
					</span>
					<h2
						id="misi-heading"
						class="font-display text-navy mt-4 leading-[1.05] font-bold tracking-tight"
						style="font-size: clamp(2rem, 4vw, 3rem);"
					>
						Menjadi partner logistik digital yang dipercaya untuk perdagangan modern di Indonesia.
					</h2>
				</div>

				<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
					<div class="misi-item border-mist-dark rounded-2xl border bg-white p-6">
						<span class="font-display text-navy/45 text-3xl leading-none font-bold">01</span>
						<p class="font-body text-charcoal mt-4 text-sm leading-relaxed">
							Menghilangkan ketidakpastian pengiriman dengan lacak real-time dan standar layanan
							yang jelas.
						</p>
					</div>
					<div class="misi-item border-mist-dark rounded-2xl border bg-white p-6">
						<span class="font-display text-navy/45 text-3xl leading-none font-bold">02</span>
						<p class="font-body text-charcoal mt-4 text-sm leading-relaxed">
							Membantu brand dan UMKM Indonesia berkembang dengan alat logistik yang lebih simpel,
							laporan yang jujur, dan layanan klaim yang bisa diandalkan.
						</p>
					</div>
					<div class="misi-item border-mist-dark rounded-2xl border bg-white p-6">
						<span class="font-display text-navy/45 text-3xl leading-none font-bold">03</span>
						<p class="font-body text-charcoal mt-4 text-sm leading-relaxed">
							Membangun layanan logistik lintas pulau yang transparan dalam proses, modern dalam
							sistem, dan disiplin dalam eksekusi.
						</p>
					</div>
					<div class="misi-item border-mist-dark rounded-2xl border bg-white p-6">
						<span class="font-display text-navy/45 text-3xl leading-none font-bold">04</span>
						<p class="font-body text-charcoal mt-4 text-sm leading-relaxed">
							Menyatukan fulfillment, pengiriman, retur, dan rekonsiliasi dalam satu alur yang
							tersambung.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section
			id="nilai"
			aria-labelledby="nilai-heading"
			class="border-mist-dark border-t bg-white py-24 lg:py-32"
		>
			<div class="mx-auto max-w-7xl px-6 sm:px-8">
				<div class="mb-16 max-w-2xl">
					<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
						Nilai Inti
					</span>
					<h2
						id="nilai-heading"
						class="font-display text-navy mt-4 leading-[1.05] font-bold tracking-tight"
						style="font-size: clamp(2rem, 4vw, 3rem);"
					>
						LINTAS, singkatan yang mengikat cara kerja kami.
					</h2>
				</div>

				<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								L
							</span>
							<div>
								<p class="font-display text-navy text-lg font-bold">Lugas</p>
								<p
									class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
								>
									Communicate clearly
								</p>
							</div>
						</div>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							To the point. Tanpa basa-basi. Setiap dokumen, setiap SLA, setiap Janji harus bisa
							dibaca tanpa perlu penafsiran ulang.
						</p>
					</div>

					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								I
							</span>
							<div>
								<p class="font-display text-navy text-lg font-bold">Integritas</p>
								<p
									class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
								>
									Act with honesty
								</p>
							</div>
						</div>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Janji yang ditepati, klaim yang dituntaskan. Kalau ada kendala, kami komunikasikan,
							bukan sembunyikan.
						</p>
					</div>

					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								N
							</span>
							<div>
								<p class="font-display text-navy text-lg font-bold">Nyata</p>
								<p
									class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
								>
									Prove it with data
								</p>
							</div>
						</div>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Klaim harus bisa dibuktikan dengan data. Setiap angka yang kami sampaikan berasal dari
							sistem, bukan estimasi.
						</p>
					</div>

					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								T
							</span>
							<div>
								<p class="font-display text-navy text-lg font-bold">Tanggap</p>
								<p
									class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
								>
									Respond and resolve
								</p>
							</div>
						</div>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Cepat tangkap masalah, cepat selesaikan akar penyebabnya, bukan sekadar tambal
							permukaan lalu biarkan muncul lagi.
						</p>
					</div>

					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								A
							</span>
							<div>
								<p class="font-display text-navy text-lg font-bold">Andal</p>
								<p
									class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
								>
									Reliability is the product
								</p>
							</div>
						</div>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Keandalan adalah produk. Kalau bilang next-day, ya next-day. Kalau 98% on-time, angka
							itu yang kami tepati.
						</p>
					</div>

					<div class="nilai-item bg-mist/40 rounded-2xl p-6 sm:p-8">
						<div class="mb-4 flex items-center gap-4">
							<span
								class="bg-navy text-teal font-display flex size-12 items-center justify-center rounded-full text-xl font-bold"
							>
								S
							</span>
							<div>
