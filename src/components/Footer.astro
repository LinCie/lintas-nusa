---
const pageLinks = [
	{ label: "Beranda", href: "/" },
	{ label: "Layanan", href: "/layanan" },
	{ label: "Jangkauan", href: "/jangkauan" },
	{ label: "Platform", href: "/platform" },
	{ label: "Tentang", href: "/tentang" },
];

const evaluationLinks = [
	{ label: "Jadwalkan sesi evaluasi", href: "/#demo" },
	{ label: "Baca portofolio layanan", href: "/layanan" },
	{ label: "Pelajari struktur jaringan", href: "/jangkauan" },
	{ label: "Lihat alur platform", href: "/platform" },
];

const contactChannels = [
	{
		label: "Email partnership",
		value: "partner@lintasnusa.co.id",
		href: "mailto:partner@lintasnusa.co.id?subject=Permintaan%20Informasi%20LintasNusa",
	},
	{
		label: "WhatsApp bisnis",
		value: "+62 812 3456 7890",
		href: "https://wa.me/6281234567890",
	},
];

const operatingNotes = [
	"Kantor pusat di Jakarta Selatan, dengan control tower nasional di Cikarang.",
	"247 kota dan kabupaten aktif dibuka berdasarkan lane yang tervalidasi.",
	"Permintaan partnership kami balas dalam 1 hari kerja lewat kanal yang tertera.",
];
---

<footer class="bg-navy text-white">
	<div class="mx-auto max-w-7xl px-6 py-14 sm:px-8 sm:py-16">
		<div
			class="grid gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)_minmax(0,0.95fr)] lg:gap-10"
		>
			<div class="max-w-xl space-y-6">
				<a
					href="/"
					class="inline-flex items-center gap-3 no-underline"
					aria-label="LintasNusa Beranda"
				>
					<svg
						width="36"
						height="36"
						viewBox="0 0 32 32"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
						aria-hidden="true"
					>
						<rect width="32" height="32" rx="6" fill="var(--color-teal)"></rect>
						<path
							d="M8 16L14 10L20 16L26 10"
							stroke="white"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
						<path
							d="M8 22L14 16L20 22L26 16"
							stroke="white"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							opacity="0.5"></path>
					</svg>
					<span class="font-display text-lg font-bold tracking-tight text-white">LintasNusa</span>
				</a>

				<div class="space-y-4">
					<p class="font-body text-sm font-semibold tracking-[0.16em] text-white/64 uppercase">
						Satu Sistem. Seluruh Nusantara.
					</p>
					<p class="font-body max-w-[58ch] text-sm leading-7 text-white/76 sm:text-base">
						LintasNusa membantu tim operasi, finance, dan customer service melihat lane, bukti
						serah-terima, klaim, dan status layanan dari satu sistem operasional yang sama.
					</p>
				</div>

				<ul class="grid gap-3">
					{
						operatingNotes.map((note) => (
							<li class="font-body grid grid-cols-[auto_1fr] gap-3 text-sm leading-6 text-white/66">
								<span class="bg-teal mt-2 h-1.5 w-1.5 rounded-full" aria-hidden="true" />
								<span>{note}</span>
							</li>
						))
					}
				</ul>
			</div>

			<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
				<nav aria-label="Halaman utama">
					<p class="font-body text-sm font-semibold tracking-[0.16em] text-white/48 uppercase">
						Halaman
					</p>
					<ul class="mt-5 grid gap-3">
						{
							pageLinks.map((link) => (
								<li>
									<a
										href={link.href}
										class="footer-nav-link font-body inline-flex min-h-11 items-center py-2 text-sm text-white/72 no-underline transition-colors duration-150 hover:text-white"
									>
										{link.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>

				<nav aria-label="Langkah evaluasi">
					<p class="font-body text-sm font-semibold tracking-[0.16em] text-white/48 uppercase">
						Langkah evaluasi
					</p>
					<ul class="mt-5 grid gap-3">
						{
							evaluationLinks.map((link) => (
								<li>
									<a
										href={link.href}
										class="footer-nav-link font-body inline-flex min-h-11 items-center py-2 text-sm text-white/72 no-underline transition-colors duration-150 hover:text-white"
									>
										{link.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>

			<div class="rounded-[1.5rem] border border-white/10 bg-white/4 p-6 sm:p-7">
				<p class="font-body text-sm font-semibold tracking-[0.16em] text-white/48 uppercase">
					Hubungi Tim Partnership
				</p>
				<h3
					class="font-display mt-4 max-w-[16ch] text-[clamp(1.55rem,3vw,2.25rem)] leading-[1.05] font-bold tracking-tight"
				>
					Butuh pembacaan lane dan kesiapan sistem yang lebih detail?
				</h3>
				<p class="font-body mt-4 max-w-[34ch] text-sm leading-7 text-white/74">
					Tim kami membahas lane prioritas, proof layer, target layanan, dan kesiapan integrasi
					sebelum masuk ke ruang lingkup teknis yang lebih detail.
				</p>

				<div class="mt-6 grid gap-4 border-t border-white/10 pt-6">
					{
						contactChannels.map((channel) => (
							<div>
								<p class="font-body text-[0.72rem] font-semibold tracking-[0.14em] text-white/48 uppercase">
									{channel.label}
								</p>
								<a
									href={channel.href}
									class="font-body mt-1 inline-flex min-h-11 items-center py-2 text-sm leading-6 text-white/84 no-underline transition-colors duration-150 hover:text-white"
								>
									{channel.value}
								</a>
							</div>
						))
					}
				</div>

				<div class="mt-6 border-t border-white/10 pt-6">
					<a
						href="/#demo"
						class="bg-orange font-body hover:bg-orange-hover inline-flex min-h-11 items-center justify-center rounded-md px-5 py-3 text-sm font-semibold text-white no-underline transition-colors duration-150 focus:outline-2 focus:outline-offset-3 focus:outline-white"
					>
						Jadwalkan Sesi Evaluasi
					</a>
				</div>
			</div>
		</div>

		<div class="mt-12 border-t border-white/10 pt-6">
			<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
				<p class="font-body text-xs text-white/48">
					&copy; 2026 PT Lintas Nusa Terpadu. Seluruh hak cipta dilindungi.
				</p>
				<p class="font-body text-xs text-white/48">
					Jakarta Selatan • Control tower Cikarang • Indonesia
				</p>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer-nav-link {
		position: relative;
	}

	.footer-nav-link::after {
		content: "";
		position: absolute;
		bottom: -1px;
		left: 0;
		right: 0;
		height: 1px;
		background: var(--color-teal);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 200ms var(--ease-out-quart);
	}

	.footer-nav-link:hover::after {
		transform: scaleX(1);
	}

	@media (prefers-reduced-motion: reduce) {
		.footer-nav-link::after {
			transition: none;
			transform: none;
		}
	}
</style>
