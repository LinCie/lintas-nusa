						<path
							d="M8 16L14 10L20 16L26 10"
							stroke="white"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
						<path
							d="M8 22L14 16L20 22L26 16"
							stroke="white"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							opacity="0.5"></path>
					</svg>
					<span class="font-display text-lg font-bold tracking-tight text-white">LintasNusa</span>
