					<a
						href="https://wa.me"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="WhatsApp"
						class="social-icon text-white/50 hover:text-white"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
							></path>
						</svg>
					</a>
				</div>
			</div>

			<div class="grid grid-cols-2 gap-8 sm:grid-cols-2 lg:col-span-2">
				<div>
					<h3
						class="font-display mb-4 text-sm font-semibold tracking-wider text-white/40 uppercase"
					>
						Perusahaan
					</h3>
					<ul class="flex flex-col gap-3">
						<li>
							<a
								href="/tentang"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Tentang Kami</a
							>
						</li>
						<li>
							<a
								href="/layanan"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Layanan</a
							>
						</li>
						<li>
							<a
								href="/jangkauan"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Jangkauan</a
							>
						</li>
						<li>
							<a
								href="/karir"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Karir</a
							>
						</li>
					</ul>
				</div>
				<div>
					<h3
						class="font-display mb-4 text-sm font-semibold tracking-wider text-white/40 uppercase"
					>
						Platform
					</h3>
					<ul class="flex flex-col gap-3">
						<li>
							<a
								href="/dashboard"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Dashboard</a
							>
						</li>
						<li>
							<a
								href="/api"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>API & Integrasi</a
							>
						</li>
						<li>
							<a
								href="/studi-kasus"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Studi Kasus</a
							>
						</li>
						<li>
							<a
								href="/keberlanjutan"
								class="footer-nav-link font-body text-sm text-white/60 no-underline transition-colors duration-150 hover:text-white"
								>Keberlanjutan</a
							>
						</li>
					</ul>
				</div>
			</div>

			<div class="lg:col-span-1">
				<h3 class="font-display mb-2 text-sm font-semibold text-white">
					Langganan update operasional
				</h3>
				<p class="font-body mb-4 text-sm text-white/50">
					Berita layanan, status jaringan, dan analisis logistik, semua lewat email.
				</p>
				<form class="newsletter-form mb-3" novalidate>
					<div class="relative">
						<label for="newsletter-email" class="sr-only">Alamat email untuk newsletter</label>
						<input
							type="email"
							id="newsletter-email"
							placeholder="alamat@perusahaan.com"
							class="newsletter-input font-body focus:border-teal w-full rounded-md border border-white/10 bg-white/5 px-4 py-3 pr-28 text-sm text-white placeholder-white/30 transition-[border-color,background] duration-150 outline-none focus:bg-white/10"
							required
						/>
						<button
							type="submit"
							class="newsletter-btn bg-teal font-body hover:bg-teal/90 focus:outline-teal absolute top-1 right-1 bottom-1 my-0.5 shrink-0 rounded-md px-4 text-sm font-semibold text-white transition-colors duration-150 focus:outline-2 focus:outline-offset-1 focus:outline-none"
						>
							Berlangganan
						</button>
					</div>
					<p class="newsletter-error font-body text-orange mt-2 hidden text-xs"></p>
					<p class="newsletter-success font-body text-teal mt-2 hidden text-sm"></p>
				</form>
				<p class="font-body text-xs text-white/30">
					Kami tidak kirim spam.
					<a
						href="#unsubscribe"
						class="underline transition-colors duration-150 hover:text-white/60"
						>Berhenti kapan saja</a
					>.
				</p>
			</div>
		</div>

		<div class="mt-12 border-t border-white/10 pt-8">
			<div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
				<p class="font-body text-xs text-white/40">
					&copy; 2026 PT Lintas Nusa Terpadu. Seluruh hak cipta dilindungi.
				</p>
				<nav class="flex flex-wrap gap-6" aria-label="Navigasi legal">
					<a
						href="/privasi"
						class="font-body text-xs text-white/40 no-underline transition-colors duration-150 hover:text-white/70"
						>Privasi</a
					>
					<a
						href="/syarat"
						class="font-body text-xs text-white/40 no-underline transition-colors duration-150 hover:text-white/70"
						>Syarat</a
					>
					<a
						href="/peta-situs"
						class="font-body text-xs text-white/40 no-underline transition-colors duration-150 hover:text-white/70"
						>Peta Situs</a
					>
				</nav>
			</div>
		</div>
	</div>
</footer>

<style>
	.social-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 6px;
		transition:
			color 150ms var(--ease-out-quart),
			background-color 150ms var(--ease-out-quart);
	}

	.social-icon:hover {
		background-color: rgba(255, 255, 255, 0.08);
	}

	.social-icon:focus-visible {
		outline: 2px solid white;
		outline-offset: 2px;
	}

	.footer-nav-link {
		position: relative;
	}

	.footer-nav-link::after {
		content: "";
		position: absolute;
		bottom: -1px;
		left: 0;
		right: 0;
		height: 1px;
		background: var(--color-teal);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 200ms var(--ease-out-quart);
	}

	.footer-nav-link:hover::after {
		transform: scaleX(1);
	}

	.footer-nav-link:hover {
		color: var(--color-white);
	}

	.newsletter-input:focus {
		border-color: var(--color-teal);
	}

	.newsletter-btn:active {
		transform: scale(0.97);
	}

	@media (prefers-reduced-motion: reduce) {
		.social-icon,
		.footer-nav-link::after,
		.footer-nav-link,
		.newsletter-btn {
			transition: none;
		}

		.footer-nav-link::after {
			transform: none;
		}

		.newsletter-btn:active {
			transform: none;
		}
	}
</style>

<script>
	const forms = document.querySelectorAll(".newsletter-form");

	forms.forEach((form) => {
		const input = form.querySelector(".newsletter-input") as HTMLInputElement;
		const errorEl = form.querySelector(".newsletter-error") as HTMLElement;
		const successEl = form.querySelector(".newsletter-success") as HTMLElement;
		const btn = form.querySelector(".newsletter-btn") as HTMLButtonElement;

		form.addEventListener("submit", (e) => {
			e.preventDefault();
			errorEl.classList.add("hidden");
			successEl.classList.add("hidden");

			const email = input.value.trim();

			if (!email) {
				errorEl.textContent = "Mohon masukkan alamat email Anda.";
				errorEl.classList.remove("hidden");
				return;
			}

			const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
			if (!emailRegex.test(email)) {
				errorEl.textContent = "Format email tidak valid. Periksa kembali penulisan email Anda.";
				errorEl.classList.remove("hidden");
				return;
			}

			btn.textContent = "Mengirim...";
			btn.disabled = true;

			input.value = "";
			btn.textContent = "Berlangganan";
			btn.disabled = false;
			successEl.textContent = "Berhasil! Anda sudah terdaftar di newsletter LintasNusa.";
			successEl.classList.remove("hidden");
		});

		input.addEventListener("input", () => {
			if (errorEl && !errorEl.classList.contains("hidden")) {
				errorEl.classList.add("hidden");
			}
		});
	});
</script>
