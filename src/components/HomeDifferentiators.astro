---
const differentiators = [
	{
		number: "01",
		title: "Satu operating layer untuk keputusan lintas tim",
		description:
			"Ops, finance, dan customer service membaca shipment, payout, dan exception dari sumber data yang sama, sehingga handoff tidak terpecah antarpermukaan.",
	},
	{
		number: "02",
		title: "Proof layer disiapkan sebelum jargon layanan dipakai",
		description:
			"Status utama, photo POD, geo scan, dan histori klaim disiapkan sebagai mekanisme kerja, bukan sekadar materi pemasaran yang menyusul belakangan.",
	},
	{
		number: "03",
		title: "Coverage dibuka per lane yang memang bisa dijaga",
		description:
			"SLA dan layanan khusus tidak disamaratakan ke seluruh jaringan. Komitmen baru dibuka setelah lane, cut-off, dan prosedur serah-terima lolos validasi operasional.",
	},
];
---

<section
	id="why-lintasnusa"
	class="border-mist-dark border-t bg-white py-18 lg:py-22"
	aria-labelledby="why-lintasnusa-heading"
	data-home-reveal
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div class="grid gap-8 lg:grid-cols-[minmax(0,28rem)_minmax(0,1fr)] lg:gap-14">
			<div class="space-y-4" data-home-reveal-item>
				<p class="font-body text-teal text-[0.68rem] font-semibold tracking-[0.16em] uppercase">
					Pembeda Utama
				</p>
				<h2
					id="why-lintasnusa-heading"
					class="font-display text-navy max-w-[16ch] text-[clamp(2rem,4vw,3.2rem)] leading-[1.02] font-bold tracking-tight"
				>
					Halaman ini tidak mencoba menjual semuanya. Cukup tiga alasan kenapa evaluasinya layak
					diteruskan.
				</h2>
				<p class="font-body text-charcoal-mid max-w-[48ch] text-base leading-7">
					Setelah itu, detail lengkap dipindahkan ke halaman yang memang dibuat untuk melihat
					layanan, jangkauan, dan platform secara utuh.
				</p>
			</div>

			<div class="grid gap-4 lg:grid-cols-3">
				{
					differentiators.map((item) => (
						<article
							class="border-mist-dark rounded-3xl border bg-white px-5 py-6 sm:px-6"
							data-home-reveal-item
							data-home-hover
						>
							<p class="font-body text-teal text-[0.72rem] font-semibold tracking-[0.16em] uppercase">
								{item.number}
							</p>
							<h3 class="font-display text-navy mt-5 text-[1.35rem] leading-[1.1] font-bold tracking-tight">
								{item.title}
							</h3>
							<p class="font-body text-charcoal-mid mt-4 text-sm leading-7">{item.description}</p>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
