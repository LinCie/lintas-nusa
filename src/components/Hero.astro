---

---

<section
	class="bg-mist relative flex min-h-screen flex-col overflow-hidden pt-(--nav-height)"
	aria-label="Hero LintasNusa"
>
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<svg
			class="absolute inset-0 h-full w-full"
			viewBox="0 0 1440 800"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
			preserveAspectRatio="xMidYMid slice"
			aria-hidden="true"
		>
			<path
				d="M-50 600 Q200 500 400 520 T800 480 T1200 450 T1490 420"
				stroke="var(--color-navy)"
				stroke-width="1"
				opacity="0.05"></path>
			<path
				d="M-50 560 Q160 460 360 480 T760 440 T1160 410 T1490 380"
				stroke="var(--color-navy)"
				stroke-width="0.5"
				opacity="0.04"></path>
			<path
				d="M-50 300 Q200 350 450 320 T900 280 T1350 250 T1490 240"
				stroke="var(--color-navy)"
				stroke-width="1"
				opacity="0.05"></path>
			<line
				x1="800"
				y1="100"
				x2="800"
				y2="700"
				stroke="var(--color-navy)"
				stroke-width="0.5"
				opacity="0.03"
				stroke-dasharray="4 8"></line>
		</svg>
	</div>

	<div
		class="relative z-10 mx-auto grid w-full max-w-7xl flex-1 grid-cols-1 items-center gap-12 px-8 py-16 lg:grid-cols-[1fr_380px] lg:gap-20"
	>
		<div class="hero-reveal">
			<h1
				class="font-display text-navy mb-8 leading-[1.05] font-black tracking-tight"
				style="font-size: clamp(3rem, 7vw, 5.5rem);"
			>
				Pengiriman bisnis,<br />
				lebih jelas dari<br />
				awal sampai tiba.
			</h1>

			<div class="mb-8 flex flex-col gap-6 sm:flex-row sm:items-end sm:gap-12">
				<div class="flex items-baseline gap-2">
					<span
						class="font-display text-navy tracking-tightest leading-none font-black"
						style="font-size: clamp(3.5rem, 8vw, 6rem);">97,9</span
					>
					<span
						class="font-display text-teal leading-none font-bold tracking-tight"
						style="font-size: clamp(1.5rem, 3vw, 2.25rem);">%</span
					>
				</div>
				<p class="text-charcoal-mid pb-1 font-mono text-xs font-medium tracking-widest uppercase">
					Kepatuhan Scan<br />2025
				</p>
			</div>

			<p
				class="font-body text-charcoal-mid max-w-[52ch] leading-relaxed"
				style="font-size: clamp(1rem, 1.5vw, 1.125rem);"
			>
				Dari pickup sampai retur, semuanya terpantau dalam satu sistem. Tim Anda bisa cek status
				kiriman secara real-time, memantau SLA, dan menangani kendala lebih cepat tanpa
				pindah-pindah tools.
			</p>
		</div>

		<div class="hero-reveal flex flex-col gap-8">
			<div class="flex flex-col gap-5">
				<p class="font-body text-charcoal-mid text-sm leading-relaxed">
					Ceritakan kebutuhan pengiriman bisnis Anda, kami bantu cari alur yang paling pas.
				</p>
				<a
					href="#layanan"
					class="cta-primary bg-orange font-body hover:bg-orange-hover focus:outline-teal block rounded-md px-6 py-4 text-center text-[15px] font-semibold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(255,107,61,0.35)] focus:outline-2 focus:outline-offset-3 active:translate-y-0 active:scale-[.99] active:shadow-[0_1px_4px_rgba(255,107,61,0.2)]"
				>
					Jadwalkan diskusi dengan tim kami
				</a>
				<a
					href="#platform"
					class="cta-secondary text-teal font-body hover:text-navy focus:outline-teal flex items-center justify-center gap-2 py-2 text-sm font-medium no-underline transition-colors duration-150 focus:rounded-sm focus:outline-2 focus:outline-offset-4"
				>
					Lihat cara dashboard kami bekerja
					<svg
						width="14"
						height="14"
						viewBox="0 0 14 14"
						fill="none"
						aria-hidden="true"
						class="transition-transform duration-150 group-hover:translate-x-0.5"
					>
						<path
							d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>

			<div class="border-navy/10 border-t pt-4">
				<p
					class="text-charcoal-mid mb-4 font-mono text-[10px] font-medium tracking-widest uppercase"
				>
					Operasional yang kami jalankan di lapangan
				</p>
				<div class="grid grid-cols-3 gap-6">
					<div class="flex flex-col gap-0.5">
						<span
							class="font-display text-navy leading-none font-bold tracking-tight"
							style="font-size: clamp(1.5rem, 3vw, 2rem);">247</span
						>
						<span
							class="text-charcoal-mid font-mono text-[10px] leading-tight font-medium tracking-widest uppercase"
							>Wilayah Jangkauan</span
						>
					</div>
					<div class="flex flex-col gap-0.5">
						<span
							class="font-display text-navy leading-none font-bold tracking-tight"
							style="font-size: clamp(1.5rem, 3vw, 2rem);"
							>12,4<span class="text-charcoal-mid text-xs font-normal">jt</span></span
						>
						<span
							class="text-charcoal-mid font-mono text-[10px] leading-tight font-medium tracking-widest uppercase"
							>Paket Ditangani 2025</span
						>
					</div>
					<div class="flex flex-col gap-0.5">
						<span
							class="font-display text-navy leading-none font-bold tracking-tight"
							style="font-size: clamp(1.5rem, 3vw, 2rem);"
							>18,5<span class="text-charcoal-mid text-xs font-normal">rb</span></span
						>
						<span
							class="text-charcoal-mid font-mono text-[10px] leading-tight font-medium tracking-widest uppercase"
							>Bisnis Aktif</span
						>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div
		class="hero-reveal absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2"
		aria-hidden="true"
	>
		<span class="text-charcoal-mid/60 font-mono text-[9px] font-medium tracking-[0.15em] uppercase"
			>Lihat studi kasus</span
		>
		<div class="scroll-line from-charcoal-mid/25 h-10 w-px bg-linear-to-b to-transparent"></div>
	</div>
</section>
