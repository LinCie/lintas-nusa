---
const contactChannels = [
	{
		label: "Email",
		value: "partner@lintasnusa.co.id",
		href: "mailto:partner@lintasnusa.co.id",
		icon: "mail",
	},
	{
		label: "WhatsApp",
		value: "+62 812 3456 7890",
		href: "https://wa.me/6281234567890",
		icon: "whatsapp",
	},
	{
		label: "Kantor Pusat",
		value: "Jl. TB Simatupang No. 17, Cilandak, Jakarta Selatan 12430",
		href: "https://www.google.com/maps/search/Jl.+TB+Simatupang+No.+17+Cilandak+Jakarta+Selatan+12430",
		icon: "location",
	},
];

const ctaLinks = [
	{
		label: "Minta jadwal konsultasi",
		href: "#kontak",
		primary: true,
	},
	{
		label: "Coba lihat demo",
		href: "#platform",
		primary: false,
	},
];
---

<section
	id="kontak"
	aria-labelledby="cta-heading"
	class="border-mist-dark relative overflow-hidden border-t bg-white py-20 lg:py-28"
>
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<svg
			class="text-navy/4 absolute top-1/2 -right-32 h-[600px] w-[600px] -translate-y-1/2"
			viewBox="0 0 400 400"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M200 1 Q350 200 200 399" stroke="currentColor" stroke-width="0.5" fill="none"></path>
			<path d="M200 1 Q50 200 200 399" stroke="currentColor" stroke-width="0.5" fill="none"></path>
			<path d="M1 200 Q200 50 399 200" stroke="currentColor" stroke-width="0.5" fill="none"></path>
			<path d="M1 200 Q200 350 399 200" stroke="currentColor" stroke-width="0.5" fill="none"></path>
			<circle cx="200" cy="200" r="80" stroke="currentColor" stroke-width="0.5" fill="none"
			></circle>
			<circle cx="200" cy="200" r="160" stroke="currentColor" stroke-width="0.3" fill="none"
			></circle>
			<circle cx="200" cy="200" r="4" fill="currentColor"></circle>
			<circle cx="200" cy="120" r="2" fill="currentColor"></circle>
			<circle cx="200" cy="280" r="2" fill="currentColor"></circle>
			<circle cx="120" cy="200" r="2" fill="currentColor"></circle>
			<circle cx="280" cy="200" r="2" fill="currentColor"></circle>
		</svg>
	</div>

	<div class="relative z-10 mx-auto max-w-7xl px-6 sm:px-8">
		<div class="mb-4">
			<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
				Hubungi Tim Kami
			</span>
		</div>

		<div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr] lg:gap-16 xl:gap-24">
			<div class="cta-content max-w-xl">
				<h2
					id="cta-heading"
					class="font-display text-navy mb-6 leading-[1.05] font-bold tracking-tight"
					style="font-size: clamp(2rem, 4vw, 3rem);"
				>
					Bahas alur distribusi yang lebih tertata?
				</h2>
				<p class="font-body text-charcoal-mid mb-10 max-w-[52ch] text-base leading-relaxed">
					Siapkan waktu untuk bicara dengan tim operational kami. Kami akan bertanya tentang lane
					yang biasa dipakai, pola muatan, dan standar bukti serah yang perlu dijaga sebelum apa-apa
					berjalan di sistem.
				</p>

				<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
					{
						ctaLinks.map((link) =>
							link.primary ? (
								<a
									href={link.href}
									class="cta-primary bg-orange font-body focus:outline-teal hover:bg-orange-hover inline-flex min-h-[52px] items-center justify-center gap-2 rounded-md px-6 py-4 text-[15px] font-semibold text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_10px_24px_rgba(169,60,25,0.18)] focus:outline-2 focus:outline-offset-3 active:translate-y-0 active:scale-[.99] active:shadow-none sm:min-w-[200px]"
								>
									{link.label}
									<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
										<path
											d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										/>
									</svg>
								</a>
							) : (
								<a
									href={link.href}
									class="cta-secondary font-body text-teal hover:text-navy focus:outline-teal group border-teal/60 hover:border-teal hover:bg-teal/5 inline-flex min-h-[52px] items-center justify-center gap-2 rounded-md border px-6 py-4 text-[15px] font-semibold no-underline transition-all duration-150 focus:outline-2 focus:outline-offset-3 sm:min-w-[200px]"
								>
									{link.label}
								</a>
							),
						)
					}
				</div>

				<p class="font-body text-charcoal-mid/85 mt-6 text-sm leading-relaxed">
					Gratis, tanpa komitmen. Baru lanjut kalau memang cocok.
				</p>
			</div>

			<div class="cta-contact">
				<div class="border-mist-dark bg-mist/40 rounded-3xl border p-6 sm:p-8">
					<p class="font-body text-navy mb-6 text-sm font-semibold tracking-[0.08em] uppercase">
						Langsung hubungi kami
					</p>

					<div class="space-y-5">
						{
							contactChannels.map((channel) => (
								<div class="cta-contact-item flex items-start gap-4">
									<div class="bg-navy/15 flex size-10 shrink-0 items-center justify-center rounded-xl">
										{channel.icon === "mail" && (
											<svg
												width="18"
												height="18"
												viewBox="0 0 24 24"
												fill="none"
												stroke="var(--color-navy)"
												stroke-width="1.5"
												stroke-linecap="round"
												stroke-linejoin="round"
												aria-hidden="true"
											>
												<rect x="2" y="4" width="20" height="16" rx="2" />
												<path d="M22 6L12 13L2 6" />
											</svg>
										)}
										{channel.icon === "whatsapp" && (
											<svg
												width="18"
												height="18"
												viewBox="0 0 24 24"
												fill="var(--color-navy)"
												aria-hidden="true"
											>
												<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
											</svg>
										)}
										{channel.icon === "location" && (
											<svg
												width="18"
												height="18"
												viewBox="0 0 24 24"
												fill="none"
												stroke="var(--color-navy)"
												stroke-width="1.5"
												stroke-linecap="round"
												stroke-linejoin="round"
												aria-hidden="true"
											>
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
												<circle cx="12" cy="10" r="3" />
											</svg>
										)}
									</div>
									<div class="min-w-0 flex-1">
										<p class="font-body text-navy text-xs font-semibold tracking-[0.08em] uppercase">
											{channel.label}
										</p>
										<a
											href={channel.href}
											aria-label={channel.label + ": " + channel.value}
											class="font-body text-charcoal-mid hover:text-navy mt-0.5 block text-sm leading-relaxed wrap-break-word no-underline transition-colors duration-150"
										>
											{channel.value}
										</a>
									</div>
								</div>
							))
						}
					</div>

					<div
						class="border-mist-dark mt-6 border-t pt-6"
						role="group"
						aria-labelledby="operational-hours-label"
					>
						<p
							id="operational-hours-label"
							class="font-body text-navy mb-3 text-xs font-semibold tracking-[0.08em] uppercase"
						>
							Jam operasional
						</p>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Senin – Jumat: 08.00 – 17.00 WIB
						</p>
					</div>

					<div
						class="bg-teal/8 mt-4 rounded-xl px-4 py-3"
						role="note"
						aria-label="Dukungan darurat"
					>
						<p class="font-body text-teal text-xs leading-relaxed font-medium">
							Akun enterprise bisa minta dukungan darurat
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	function initCtaContactAnimations() {
		const mm = gsap.matchMedia();

		mm.add("(prefers-reduced-motion: no-preference)", () => {
			const contentItems = gsap.utils.toArray<HTMLElement>(
				".cta-content, .cta-contact, .cta-contact-item",
			);

			if (contentItems.length) {
				gsap.from(contentItems, {
					opacity: 0,
					y: 24,
					duration: 0.6,
					ease: "power2.out",
					stagger: 0.1,
					scrollTrigger: {
						trigger: ".cta-content",
						start: "top 82%",
						once: true,
					},
					clearProps: "opacity,transform",
				});
			}
		});
	}

	initCtaContactAnimations();
</script>
