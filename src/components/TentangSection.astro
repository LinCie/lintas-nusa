---
const companyStory = {
	year: "2021",
	location: "Jakarta Selatan",
};

const vision = {
	label: "Visi",
	text: "Menjadi partner logistik digital yang dipercaya untuk perdagangan modern di Indonesia.",
};

const missions = [
	{
		number: "01",
		text: "Menghilangkan ketidakpastian pengiriman dengan lacak real-time dan standar layanan yang jelas.",
	},
	{
		number: "02",
		text: "Membantu brand dan UMKM Indonesia berkembang dengan alat logistik yang lebih simpel, laporan yang jujur, dan layanan klaim yang bisa diandalkan.",
	},
	{
		number: "03",
		text: "Membangun layanan logistik lintas pulau yang transparan dalam proses, modern dalam sistem, dan disiplin dalam eksekusi.",
	},
	{
		number: "04",
		text: "Menyatukan fulfillment, pengiriman, retur, dan rekonsiliasi dalam satu alur yang tersambung.",
	},
];

const coreValues = [
	{
		letter: "L",
		name: "Lugas",
		description: "To the point. Tanpa basa-basi.",
	},
	{
		letter: "I",
		name: "Integritas",
		description: "Janji yang ditepati, klaim yang dituntaskan.",
	},
	{
		letter: "N",
		name: "Nyata",
		description: "Klaim harus bisa dibuktikan dengan data.",
	},
	{
		letter: "T",
		name: "Tanggap",
		description: "Cepat tangkap masalah, cepat selesaikan akar penyebabnya.",
	},
	{
		letter: "A",
		name: "Andal",
		description: "Keandalan adalah produk.",
	},
	{
		letter: "S",
		name: "Selaras",
		description: "Sukses bareng klien, agen, dan komunitas.",
	},
];

const leadership = [
	{
		name: "Nadira Prasetyo",
		role: "Founder & Chief Executive Officer",
		bio: "Mantan kepala strategi fulfillment di platform commerce regional; memimpin product-market fit dan pertumbuhan jaringan.",
	},
	{
		name: "Bima Ardian",
		role: "Chief Operating Officer",
		bio: "Membangun program line-haul dan last-mile di Jawa dan Sumatra; bertanggung jawab atas reliabilitas jaringan dan kualitas layanan.",
	},
	{
		name: "Kevin Halim",
		role: "Chief Technology Officer",
		bio: "Mantan arsitek integrasi SaaS; memimpin merchant OS, stack API, dan layer control tower.",
	},
	{
		name: "Marissa Gunawan",
		role: "Chief Commercial Officer",
		bio: "Spesialis desain penjualan D2C dan B2B; memimpin solusi industri dan pengelolaan akun besar nasional.",
	},
	{
		name: "Raka Wibisono",
		role: "VP Network & Quality",
		bio: "Mengelola gateway, rutinitas audit, integritas POD, dan standar penanganan khusus.",
	},
];

const operatingMetrics = [
	{
		value: "12,4 jt",
		label: "Parcel ditangani 2025",
		target: "12.4",
		suffix: " jt",
		decimal: true,
	},
	{ value: "97,9%", label: "Kepatuhan pemindaian", target: "97.9", suffix: "%", decimal: true },
	{ value: "95,8%", label: "Berhasil kirim pertama", target: "95.8", suffix: "%", decimal: true },
	{
		value: "98,3%",
		label: "Keberangkatan tepat waktu",
		target: "98.3",
		suffix: "%",
		decimal: true,
	},
];
---

<section
	id="tentang"
	aria-labelledby="tentang-heading"
	class="border-mist-dark relative overflow-hidden border-t bg-white py-20 lg:py-28"
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<header class="mb-16 max-w-3xl space-y-5 lg:mb-20">
			<div class="mb-4">
				<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
					>Profil Perusahaan</span
				>
			</div>
			<div class="grid grid-cols-1 gap-5 lg:grid-cols-[1fr_280px] lg:gap-10">
				<h2
					id="tentang-heading"
					class="font-display text-navy max-w-[20ch] leading-[1.05] font-bold tracking-tight"
					style="font-size: clamp(2rem, 4vw, 3rem);"
				>
					Dibangun di sekitar satu masalah yang jelas: logistik terlalu terpecah.
				</h2>
				<p class="font-body text-charcoal-mid max-w-[42ch] text-base leading-relaxed lg:self-end">
					LintasNusa didirikan tahun {companyStory.year} di {companyStory.location} oleh tim yang sebelumnya
					bekerja di operasi e-commerce, distribusi last-mile, dan produk SaaS. Masing-masing menghadapi
					masalah yang sama: pengiriman sudah digital, tapi pengalamannya terpecah di banyak sistem.
				</p>
			</div>
		</header>

		<div
			class="tentang-vision-block bg-navy mb-14 rounded-4xl p-6 text-white sm:p-8 lg:mb-16 lg:p-10"
		>
			<div
				class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(14rem,0.6fr)] lg:gap-12"
			>
				<div class="space-y-4">
					<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
						>{vision.label}</span
					>
					<p
						class="font-display text-[clamp(1.5rem,3.5vw,2.5rem)] leading-tight font-bold tracking-tight text-white"
					>
						{vision.text}
					</p>
				</div>
				<div class="space-y-3 lg:self-center">
					<p class="font-body text-sm font-semibold tracking-[0.14em] text-white/70 uppercase">
						Tesis Perusahaan
					</p>
					<p class="font-body text-base leading-relaxed text-white/85">
						Setiap paket yang bergerak menghasilkan data. <span class="text-teal font-semibold"
							>Data itu menjadi dasar keputusan.</span
						>
					</p>
				</div>
			</div>
		</div>

		<div class="mb-14 lg:mb-16">
			<div class="mb-8 space-y-3 lg:mb-10">
				<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
					>Misi</span
				>
				<h3
					class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold tracking-tight"
				>
					Empat misi yang mengarahkan setiap keputusan kami.
				</h3>
			</div>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				{
					missions.map((mission) => (
						<div class="tentang-mission-item border-mist-dark bg-mist/50 rounded-2xl border p-5 sm:p-6">
							<div class="flex gap-4">
								<span class="font-display text-navy/60 text-2xl leading-none font-bold">
									{mission.number}
								</span>
								<p class="font-body text-charcoal text-sm leading-relaxed">{mission.text}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>

		<div class="border-mist-dark mb-14 border-t pt-10 lg:mb-16 lg:pt-12">
			<div class="mb-8 space-y-3 lg:mb-10">
				<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
					>Nilai Inti</span
				>
				<h3
					class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold tracking-tight"
				>
					LINTAS adalah singkatan yang mengikat cara kerja tim ke empat misi.
				</h3>
			</div>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{
					coreValues.map((value) => (
						<div class="tentang-value-item border-mist-dark rounded-2xl border bg-white p-5 sm:p-6">
							<div class="mb-3 flex items-center gap-3">
								<span class="bg-navy text-teal font-display flex size-10 items-center justify-center rounded-full text-xl font-bold">
									{value.letter}
								</span>
								<p class="font-display text-navy text-lg font-bold">{value.name}</p>
							</div>
							<p class="font-body text-charcoal-mid text-sm leading-relaxed">{value.description}</p>
						</div>
					))
				}
			</div>
		</div>

		<div class="mb-14 lg:mb-16">
			<div class="mb-8 space-y-3 lg:mb-10">
				<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
					>Jajaran Kepemimpinan</span
				>
				<h3
					class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold tracking-tight"
				>
					Tim dengan pengalaman nyata di commerce, operasi, dan teknologi.
				</h3>
			</div>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{
					leadership.map((leader, i) => (
						<div
							class={`tentang-leader-item border-mist-dark rounded-2xl border bg-white p-5 sm:p-6 ${i === 0 ? "border-l-2 border-l-[--color-teal]" : ""}`}
						>
							<div class="mb-3">
								<p class="font-display text-navy text-base leading-tight font-bold">
									{leader.name}
								</p>
								<p class="text-teal mt-1 font-mono text-xs font-medium tracking-[0.04em]">
									{leader.role}
								</p>
							</div>
							<p class="font-body text-charcoal-mid text-sm leading-relaxed">{leader.bio}</p>
						</div>
					))
				}
			</div>
		</div>

		<div
			class="tentang-metrics-block border-mist-dark bg-mist/60 rounded-4xl border p-6 sm:p-8 lg:p-10"
		>
			<div class="mb-6 space-y-2 lg:mb-8">
				<p class="font-body text-navy-light text-sm font-semibold tracking-[0.14em] uppercase">
					Bukti Operasional
				</p>
				<h3
					class="font-display text-navy text-[clamp(1.25rem,2.5vw,1.75rem)] leading-tight font-bold tracking-tight"
				>
					Angka-angka ini menjelaskan kapasitas nyata, bukan sekadar skala.
				</h3>
			</div>
			<dl class="grid grid-cols-2 gap-4 sm:grid-cols-4">
				{
					operatingMetrics.map((metric) => (
						<div class="text-center sm:text-left">
							<dt class="font-body text-charcoal-mid text-xs font-medium sm:text-sm">
								{metric.label}
							</dt>
							<dd class="mt-1">
								<span
									class="tentang-metric-value font-display text-navy block text-[clamp(1.75rem,4vw,2.5rem)] leading-none font-bold tracking-tight"
									data-target={metric.target}
									data-suffix={metric.suffix}
									data-decimal={metric.decimal ? "true" : undefined}
								>
									{metric.value}
								</span>
							</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	function formatMetric(value: number, isDecimal: boolean, suffix: string) {
		const formatted = isDecimal
			? value.toFixed(1).replace(".", ",")
			: Math.round(value).toLocaleString("id-ID");
		return `${formatted}${suffix}`;
	}

	function initTentangAnimations() {
		const mm = gsap.matchMedia();

		mm.add("(prefers-reduced-motion: no-preference)", () => {
			const revealGroups = [
				".tentang-vision-block",
				".tentang-mission-item",
				".tentang-value-item",
				".tentang-leader-item",
				".tentang-metrics-block",
			];

			revealGroups.forEach((selector) => {
				const items = gsap.utils.toArray<HTMLElement>(selector);
				if (!items.length) return;

				gsap.from(items, {
					opacity: 0,
					y: 20,
					duration: 0.5,
					ease: "power2.out",
					stagger: 0.08,
					scrollTrigger: {
						trigger: items[0],
						start: "top 84%",
						once: true,
					},
					clearProps: "opacity,transform",
				});
			});

			const metrics = gsap.utils.toArray<HTMLElement>(".tentang-metric-value");
			metrics.forEach((el) => {
				const target = parseFloat(el.dataset.target || "0");
				const suffix = el.dataset.suffix || "";
				const isDecimal = el.dataset.decimal === "true";
				const counter = { value: 0 };

				gsap.fromTo(
					counter,
					{ value: 0 },
					{
						value: target,
						duration: 1.2,
						ease: "power2.out",
						scrollTrigger: {
							trigger: el,
							start: "top 88%",
							once: true,
						},
						onStart: () => {
							el.textContent = formatMetric(0, isDecimal, suffix);
						},
						onUpdate: () => {
							el.textContent = formatMetric(counter.value, isDecimal, suffix);
						},
						onComplete: () => {
							el.textContent = formatMetric(target, isDecimal, suffix);
						},
					},
				);
			});
		});
	}

	initTentangAnimations();
</script>
