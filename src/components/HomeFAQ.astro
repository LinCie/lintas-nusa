---
const faqs = [
	{
		question: "Layanan apa yang biasanya dibandingkan pada evaluasi awal?",
		answer:
			"Evaluasi biasanya dimulai dari kombinasi <strong>LN Regular</strong>, <strong>LN NextDay</strong>, <strong>LN SameDay Metro</strong>, <strong>LN COD Clear</strong>, serta layanan khusus seperti <strong>LN Cold</strong> atau <strong>LN Secure</strong>. Fokusnya bukan memilih layanan terbanyak, tetapi memilih lane dan proof layer yang paling relevan untuk operasi Anda.",
	},
	{
		question: "Seberapa luas jangkauan aktif LintasNusa saat ini?",
		answer:
			"Jaringan aktif mencakup <strong>247 kota dan kabupaten</strong>, dengan control tower nasional di Cikarang dan delapan gateway regional utama. Coverage dibuka berdasarkan lane yang tervalidasi, jadi komitmen layanan tidak disamaratakan ke seluruh jaringan.",
	},
	{
		question: "Bukti operasional apa yang tersedia ketika exception atau klaim muncul?",
		answer:
			"Tim dapat membaca status utama, geo-stamped scan, photo POD, histori exception, dan evidence trail klaim dari alur yang sama. Tujuannya agar recovery tidak bergantung pada follow-up manual lintas tim.",
	},
	{
		question: "Apakah ops, finance, dan customer service membaca data yang sama?",
		answer:
			"Ya. Merchant dashboard dirancang untuk banyak peran dalam satu akun. Ops membaca ritme kirim dan exception, finance membaca payout dan rekonsiliasi, sementara customer service melihat status kirim dan klaim tanpa memecah sumber data.",
	},
	{
		question: "Kapan integrasi API atau ERP/WMS dibahas?",
		answer:
			"Pembahasan integrasi biasanya dimulai setelah lane prioritas, SLA, dan proof layer disepakati. Di tahap itu tim kami bisa membuka ruang lingkup API, webhook, sandbox, atau kebutuhan ERP/WMS secara lebih presisi.",
	},
	{
		question: "Apa yang dibawa dalam sesi evaluasi pertama?",
		answer:
			"Sesi awal membahas lane prioritas, ritme pickup dan dispatch, exception yang paling sering mengganggu, dan siapa yang butuh visibilitas. Hasilnya adalah pembacaan kecocokan awal, bukan demo fitur yang terlalu lebar.",
	},
];
---

<section
	id="faq"
	class="border-mist-dark bg-mist/24 border-t py-18 lg:py-24"
	aria-labelledby="faq-heading"
	data-home-reveal
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,24rem)_minmax(0,1fr)] lg:gap-14">
			<header class="space-y-4" data-home-reveal-item>
				<p class="font-body text-teal text-[0.68rem] font-semibold tracking-[0.16em] uppercase">
					Pertanyaan Umum
				</p>
				<h2
					id="faq-heading"
					class="font-display text-navy max-w-[14ch] text-[clamp(1.9rem,3.8vw,2.8rem)] leading-[1.04] font-bold tracking-tight"
				>
					Enam pertanyaan yang paling sering muncul sebelum pembahasan masuk lebih dalam.
				</h2>
				<p class="font-body text-charcoal-mid max-w-[42ch] text-base leading-7">
					Halaman utama hanya memuat jawaban yang paling berguna untuk membaca kecocokan awal. Jika
					kasus Anda lebih spesifik, lanjutkan pembahasannya lewat sesi evaluasi.
				</p>
			</header>

			<div class="grid gap-0" data-home-reveal-item>
				{
					faqs.map((item, index) => (
						<article class="faq-item border-mist-dark border-b last:border-b-0">
							<button
								id={`faq-${index}`}
								class="faq-q font-body text-navy hover:text-teal focus-visible:ring-navy flex w-full items-start justify-between gap-4 py-5 text-left text-[15px] leading-6 font-semibold transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-offset-2"
								aria-expanded={index === 0 ? "true" : "false"}
								aria-controls={`faq-a-${index}`}
							>
								<span class="max-w-[42rem]">{item.question}</span>
								<span
									class:list={[
										"faq-chevron text-teal mt-1 shrink-0 rotate-0 transition-transform duration-200 ease-out",
										index === 0 ? "rotate-180" : "",
									]}
									aria-hidden="true"
								>
									<svg width="16" height="16" viewBox="0 0 16 16" fill="none">
										<path
											d="M4 6L8 10L12 6"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										/>
									</svg>
								</span>
							</button>
							<div
								id={`faq-a-${index}`}
								class:list={[
									"faq-answer-wrap grid overflow-hidden transition-[grid-template-rows,opacity] duration-200 ease-out",
									index === 0 ? "grid-rows-[1fr] opacity-100" : "grid-rows-[0fr] opacity-0",
								]}
								aria-hidden={index === 0 ? "false" : "true"}
							>
								<div class="min-h-0 overflow-hidden">
									<div
										class="faq-answer font-body text-charcoal-mid max-w-[64ch] pb-6 text-sm leading-7"
										set:html={item.answer}
									/>
								</div>
							</div>
						</article>
					))
				}
			</div>
		</div>

		<div class="border-mist-dark mt-12 border-t pt-8" data-home-reveal-item>
			<p class="font-body text-charcoal-mid max-w-[58ch] text-sm leading-6">
				Butuh kasus yang lebih spesifik untuk lane, payout, atau integrasi?
				<a
					href="/#demo"
					class="text-teal hover:text-navy ml-1 font-semibold no-underline transition-colors duration-150"
				>
					Jadwalkan sesi evaluasi bersama tim kami.
				</a>
			</p>
		</div>
	</div>
</section>

<style>
	.faq-chevron svg {
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.faq-answer-wrap {
			transition: none;
		}

		.faq-chevron svg {
			transition: none;
		}
	}
</style>

<script>
	const initFaq = () => {
		const faqRoot = document.getElementById("faq");
		if (!faqRoot || faqRoot.dataset.faqBound === "true") {
			return;
		}

		faqRoot.dataset.faqBound = "true";

		const questions = faqRoot.querySelectorAll<HTMLButtonElement>(".faq-q");
		const setAnswerState = (
			question: HTMLButtonElement,
			answer: HTMLElement,
			chevron: SVGElement | null,
			isOpen: boolean,
		) => {
			question.setAttribute("aria-expanded", String(isOpen));
			answer.setAttribute("aria-hidden", String(!isOpen));

			answer.classList.toggle("grid-rows-[1fr]", isOpen);
			answer.classList.toggle("grid-rows-[0fr]", !isOpen);
			answer.classList.toggle("opacity-100", isOpen);
			answer.classList.toggle("opacity-0", !isOpen);

			if (chevron) {
				chevron.classList.toggle("rotate-180", isOpen);
			}
		};

		questions.forEach((question) => {
			question.addEventListener("click", () => {
				const answerId = question.getAttribute("aria-controls");
				const answer = answerId ? document.getElementById(answerId) : null;
				const chevron = question.querySelector<SVGElement>(".faq-chevron svg");

				if (!answer) {
					return;
				}

				const isOpen = question.getAttribute("aria-expanded") === "true";

				if (isOpen) {
					setAnswerState(question, answer, chevron, false);
					return;
				}

				questions.forEach((otherQuestion) => {
					if (otherQuestion === question) {
						return;
					}

					const otherAnswerId = otherQuestion.getAttribute("aria-controls");
					const otherAnswer = otherAnswerId ? document.getElementById(otherAnswerId) : null;
					const otherChevron = otherQuestion.querySelector<SVGElement>(".faq-chevron svg");

					if (otherAnswer && otherQuestion.getAttribute("aria-expanded") === "true") {
						setAnswerState(otherQuestion, otherAnswer, otherChevron, false);
					}
				});

				setAnswerState(question, answer, chevron, true);
			});
		});
	};

	initFaq();
	document.addEventListener("DOMContentLoaded", initFaq, { once: true });
	document.addEventListener("astro:page-load", initFaq);
</script>
