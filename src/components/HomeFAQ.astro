---

<section
	id="faq"
	class="border-mist-dark bg-mist/30 border-t py-18 lg:py-24"
	aria-labelledby="faq-heading"
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<header class="mb-12 lg:mb-14">
			<p class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
				Pertanyaan Umum
			</p>
			<h2
				id="faq-heading"
				class="font-display text-navy mt-3 max-w-[20ch] text-[clamp(1.75rem,3.5vw,2.6rem)] leading-[1.05] font-bold tracking-tight"
			>
				Pertanyaan yang sering muncul sebelum evaluasi partnership
			</h2>
			<p class="font-body text-charcoal-mid mt-4 max-w-[56ch] text-base leading-7">
				Jika Anda tidak menemukan jawaban yang dicari, tim kami siap mendiskusikan kebutuhan
				operasional Anda secara langsung.
			</p>
		</header>

		<div class="faq-layout lg:grid lg:grid-cols-[14rem_1fr] lg:gap-10 xl:gap-14">
			<nav class="faq-categories hidden lg:block" aria-label="FAQ categories">
				<ul class="space-y-1">
					{
						categories.map((cat) => (
							<li>
								<button
									class="faq-cat-btn font-body group text-charcoal-mid flex w-full items-center gap-2.5 rounded-lg px-3 py-2.5 text-left text-sm font-medium transition-colors duration-150"
									data-cat={cat.id}
									aria-pressed="false"
								>
									<span class="faq-cat-indicator bg-teal/0 group-hover:bg-teal/40 h-0.5 w-4 rounded-full transition-all duration-200" />
									{cat.label}
								</button>
							</li>
						))
					}
				</ul>
			</nav>

			<div class="faq-mobile-cats lg:hidden">
				<div class="scrollbar-none flex gap-2 overflow-x-auto pb-3">
					{
						categories.map((cat) => (
							<button
								class="faq-cat-tab border-mist-dark text-charcoal-mid rounded-full border bg-white px-4 py-2 font-mono text-[10px] font-medium tracking-[0.12em] whitespace-nowrap uppercase transition-all duration-150"
								data-cat={cat.id}
								aria-pressed="false"
							>
								{cat.label}
							</button>
						))
					}
				</div>
			</div>

			<div class="faq-panels mt-6 lg:mt-0">
				{
					categories.map((cat) => (
						<div class="faq-panel hidden" data-panel={cat.id}>
							<ul class="faq-list space-y-0" role="list">
								{cat.items.map((item, i) => (
									<li class="faq-item border-mist-dark border-b last:border-b-0">
										<button
											class="faq-q font-body group text-navy hover:text-teal flex w-full items-start justify-between gap-4 py-5 text-left text-[15px] leading-6 font-semibold transition-colors duration-150"
											aria-expanded="false"
											aria-controls={`faq-a-${cat.id}-${i}`}
										>
											{item.question}
											<span class="faq-chevron text-teal mt-1 shrink-0" aria-hidden="true">
												<svg
													width="16"
													height="16"
													viewBox="0 0 16 16"
													fill="none"
													class="transition-transform duration-200"
												>
													<path
														d="M4 6L8 10L12 6"
														stroke="currentColor"
														stroke-width="1.5"
														stroke-linecap="round"
														stroke-linejoin="round"
													/>
												</svg>
											</span>
										</button>
										<div
											id={`faq-a-${cat.id}-${i}`}
											class="faq-answer overflow-hidden"
											style="display: none;"
										>
											<p class="font-body text-charcoal-mid pb-6 text-sm leading-7">
												{item.answer}
											</p>
										</div>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>

		<div class="border-mist-dark mt-12 border-t pt-8">
			<p class="font-body text-charcoal-mid text-sm">
				Tidak menemukan jawaban yang Anda cari?{" "}
				<a
					href="mailto:partner@lintasnusa.co.id?subject=Permintaan%20Informasi%20LintasNusa"
					class="text-teal hover:text-navy font-semibold no-underline underline-offset-2 transition-colors duration-150"
				>
					Diskusikan kebutuhan Anda dengan tim kami
				</a>
			</p>
		</div>
	</div>
</section>

<style>
	.faq-panel:not(.hidden) {
		display: block;
	}

	.faq-cat-btn[aria-pressed="true"] {
		color: var(--color-navy);
	}

	.faq-cat-btn[aria-pressed="true"] .faq-cat-indicator {
		background-color: var(--color-teal);
		width: 1.5rem;
	}

	.faq-cat-tab[aria-pressed="true"] {
		border-color: var(--color-teal);
		background-color: var(--color-teal);
		color: #fff;
	}

	@media (prefers-reduced-motion: reduce) {
		.faq-answer {
			transition: none !important;
		}
		.faq-chevron svg {
			transition: none !important;
		}
	}
</style>

<script>
	import gsap from "gsap";

	document.addEventListener("DOMContentLoaded", () => {
		const catBtns = document.querySelectorAll<HTMLButtonElement>(".faq-cat-btn");
		const catTabs = document.querySelectorAll<HTMLButtonElement>(".faq-cat-tab");
		const panels = document.querySelectorAll<HTMLElement>(".faq-panel");
		const questions = document.querySelectorAll<HTMLButtonElement>(".faq-q");

		const mm = window.matchMedia("(prefers-reduced-motion: reduce)");

		function setCategory(catId: string, animate = true) {
			catBtns.forEach((btn) => {
				const active = btn.dataset.cat === catId;
				btn.setAttribute("aria-pressed", String(active));
			});
			catTabs.forEach((tab) => {
				const active = tab.dataset.cat === catId;
				tab.setAttribute("aria-pressed", String(active));
			});

			panels.forEach((panel) => {
				if (panel.dataset.panel === catId) {
					panel.classList.remove("hidden");

					if (animate && !mm.matches) {
						const items = panel.querySelectorAll<HTMLElement>(".faq-item");
						gsap.fromTo(
							items,
							{ opacity: 0, y: 10 },
							{
								opacity: 1,
								y: 0,
								duration: 0.25,
								ease: "power2.out",
								stagger: 0.06,
							},
						);
					} else {
						const items = panel.querySelectorAll<HTMLElement>(".faq-item");
						items.forEach((item) => {
							item.style.opacity = "1";
						});
					}
				} else {
					panel.classList.add("hidden");
				}
			});
		}

		catBtns.forEach((btn) => {
			btn.addEventListener("click", () => setCategory(btn.dataset.cat ?? ""));
		});

		catTabs.forEach((tab) => {
			tab.addEventListener("click", () => setCategory(tab.dataset.cat ?? ""));
		});

		const firstCatId = panels[0]?.dataset.panel ?? "";
		setCategory(firstCatId);

		questions.forEach((q) => {
			q.addEventListener("click", () => {
				const answerId = q.getAttribute("aria-controls");
				const answer = answerId ? document.getElementById(answerId) : null;
				if (!answer) return;

				const isOpen = q.getAttribute("aria-expanded") === "true";
				const chevron = q.querySelector<SVGElement>(".faq-chevron svg");

				const allAnswers = document.querySelectorAll<HTMLElement>(".faq-answer");

				if (!isOpen) {
					allAnswers.forEach((a) => {
						if (a.style.display === "block" && a.id !== answerId) {
							const correspondingQ = document.querySelector(`[aria-controls="${a.id}"]`);
							if (correspondingQ) correspondingQ.setAttribute("aria-expanded", "false");
							const correspondingChevron =
								correspondingQ?.querySelector<SVGElement>(".faq-chevron svg");
							if (correspondingChevron && !mm.matches) {
								gsap.to(correspondingChevron, { rotation: 0, duration: 0.2, ease: "power2.out" });
							}
							if (!mm.matches) {
								gsap.to(a, {
									height: 0,
									duration: 0.2,
									ease: "power2.in",
									onComplete: () => {
										a.style.display = "none";
										(a as HTMLElement).style.height = "";
									},
								});
							} else {
								a.style.display = "none";
							}
						}
					});
				}

				q.setAttribute("aria-expanded", String(!isOpen));

				if (isOpen) {
					if (!mm.matches) {
						gsap.to(answer, {
							height: 0,
							duration: 0.25,
							ease: "power2.in",
							onComplete: () => {
								answer.style.display = "none";
								(answer as HTMLElement).style.height = "";
							},
						});
					} else {
						answer.style.display = "none";
					}
					if (chevron && !mm.matches) {
						gsap.to(chevron, { rotation: 0, duration: 0.2, ease: "power2.out" });
					}
				} else {
					answer.style.display = "block";
					const targetHeight = answer.scrollHeight;
					answer.style.height = "0px";
					if (!mm.matches) {
						gsap.to(answer, { height: targetHeight, duration: 0.3, ease: "power2.out" });
					} else {
						(answer as HTMLElement).style.height = "";
					}
					if (chevron && !mm.matches) {
						gsap.to(chevron, { rotation: 180, duration: 0.2, ease: "power2.out" });
					}
				}
			});
		});
	});
</script>
