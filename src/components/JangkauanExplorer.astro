function getStatusTone(status: string) {
	switch (status) {
		case "Aktif":
			return "border-teal/20 bg-teal/10 text-teal";
		case "Terbatas":
			return "border-navy/15 bg-navy/5 text-navy";
		case "Review":
			return "border-orange/20 bg-orange/10 text-orange";
		default:
			return "border-mist-dark bg-white text-charcoal-mid";
	}
}
---

<section
	id="jangkauan"
	data-coverage-explorer
	aria-labelledby="jangkauan-heading"
	class="relative overflow-hidden bg-white py-16 lg:py-24"
>
	<div
		class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(238,243,247,0.7),rgba(255,255,255,0)_28%),radial-gradient(circle_at_82%_12%,rgba(13,120,114,0.08),transparent_30%),radial-gradient(circle_at_14%_4%,rgba(15,39,66,0.05),transparent_22%)]"
		aria-hidden="true"
	>
	</div>

	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div
			class="relative grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1.08fr)_minmax(19rem,0.92fr)] lg:items-end lg:gap-16"
		>
			<div class="max-w-3xl space-y-6">
				<p class="text-navy-light font-body text-sm font-semibold tracking-[0.18em] uppercase">
					Coverage Explorer
				</p>
				<div class="space-y-4">
					<h1
						id="jangkauan-heading"
						class="font-display text-navy text-[clamp(2.6rem,5.4vw,5rem)] leading-[0.95] font-bold tracking-tight"
					>
						Dari ringkasan di beranda ke lane yang bisa Anda cek satu per satu.
					</h1>
					<p class="font-body text-charcoal max-w-[58ch] text-base leading-7 sm:text-lg">
						Halaman ini mengubah coverage menjadi alat keputusan: pilih wilayah, baca node aktif,
						bandingkan lane yang terbuka, lalu cek mana yang masih review sebelum dikutip.
					</p>
				</div>

				<div class="flex flex-wrap gap-3">
					<a
						href="#jangkauan-wilayah"
						class="bg-navy font-body focus:outline-teal inline-flex min-h-11 items-center rounded-md px-5 py-3 text-sm font-semibold text-white no-underline focus:outline-2 focus:outline-offset-3"
					>
						Pilih wilayah
					</a>
					<a
						href="#jangkauan-layanan"
						class="font-body text-teal border-teal focus:outline-teal inline-flex min-h-11 items-center rounded-md border px-5 py-3 text-sm font-semibold no-underline focus:outline-2 focus:outline-offset-3"
					>
						Bandingkan layanan
					</a>
					<a
						href="#jangkauan-bukti"
						class="font-body text-navy-light border-mist-dark hover:bg-mist focus:outline-teal inline-flex min-h-11 items-center rounded-md border px-5 py-3 text-sm font-semibold no-underline focus:outline-2 focus:outline-offset-3"
					>
						Baca proof layer
					</a>
				</div>
			</div>

			<aside class="jangkauan-map-shell border-mist-dark bg-mist/80 rounded-4xl border p-6 sm:p-8">
				<div class="space-y-2">
					<p class="text-navy-light font-body text-sm font-semibold tracking-[0.14em] uppercase">
						Snapshot coverage
					</p>
					<p class="font-body text-charcoal-mid max-w-[30ch] text-sm leading-6">
						Beranda memberi ringkasan. Explorer ini membuka detail lane, status, dan proof yang
						menempel di setiap keputusan.
					</p>
				</div>

				<div class="mt-6 space-y-3">
					<div class="border-mist-dark rounded-[1.45rem] border bg-white p-5 sm:p-6">
						<div class="flex items-start justify-between gap-4">
							<div class="space-y-2">
								<p
									class="font-body text-navy-light text-[0.68rem] font-semibold tracking-[0.14em] uppercase"
								>
									{heroStats[0].label}
								</p>
								<span
									class="jangkauan-number font-display text-navy block text-[clamp(3rem,7vw,4.8rem)] leading-none font-bold tracking-tight"
									data-target={heroStats[0].target}
									data-decimal={heroStats[0].decimal ? "true" : undefined}
									data-suffix={heroStats[0].suffix}
								>
									{heroStats[0].display}
								</span>
							</div>
							<p class="font-body text-charcoal-mid max-w-[18ch] text-sm leading-6">
								{heroStats[0].note}
							</p>
						</div>
					</div>

					<div class="grid gap-3 sm:grid-cols-2">
						{
							heroStats.slice(1, 3).map((stat) => (
								<div class="border-mist-dark rounded-[1.3rem] border bg-white p-4">
									<p class="font-body text-navy-light text-[0.68rem] font-semibold tracking-[0.14em] uppercase">
										{stat.label}
									</p>
