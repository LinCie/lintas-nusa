---
const gatewayNodes = [
	{ city: "Medan", x: 65, y: 140, labelX: 65, labelY: 130, labelAnchor: "middle" },
	{ city: "Palembang", x: 133, y: 220, labelX: 133, labelY: 210, labelAnchor: "middle" },
	{ city: "Bandung", x: 180, y: 275, labelX: 180, labelY: 285, labelAnchor: "middle" },
	{ city: "Semarang", x: 220, y: 270, labelX: 220, labelY: 260, labelAnchor: "middle" },
	{ city: "Surabaya", x: 250, y: 280, labelX: 250, labelY: 270, labelAnchor: "middle" },
	{ city: "Denpasar", x: 285, y: 295, labelX: 285, labelY: 285, labelAnchor: "middle" },
	{ city: "Balikpapan", x: 290, y: 200, labelX: 290, labelY: 190, labelAnchor: "middle" },
	{ city: "Makassar", x: 350, y: 250, labelX: 350, labelY: 240, labelAnchor: "middle" },
];

const controlTower = {
	x: 175,
	y: 265,
	titleX: 175,
	titleY: 250,
	subtitleX: 175,
	subtitleY: 255,
};

const primaryRoutes = [
	"M 65 140 Q 98 171 133 220",
	"M 133 220 Q 154 242 175 265",
	"M 175 265 Q 176 272 180 275",
	"M 180 275 Q 201 271 220 270",
	"M 220 270 Q 236 273 250 280",
	"M 250 280 Q 270 289 285 295",
	"M 175 265 Q 224 230 290 200",
	"M 290 200 Q 324 218 350 250",
];

const supportingRoutes = [
	"M 290 200 Q 347 194 398 198 Q 442 202 470 214",
	"M 350 250 Q 404 251 456 258 Q 506 277 552 304",
	"M 350 250 Q 414 239 475 210 Q 534 188 586 168",
];

const commandPills = [
	"247 kota & kabupaten aktif",
	"97,9% scan compliance",
	"SLA dibuka hanya pada lane tervalidasi",
];

const operatingPrinciples = [
	"Coverage ditentukan oleh lane yang aktif, bukan sekadar nama kota tujuan.",
	"Same-day, next-day, cold chain, dan secure handling hanya dibuka saat mekanismenya siap.",
	"Control tower dan gateway dipakai untuk menjaga dispatch, handoff, dan exception tetap sinkron.",
];

const controlTowerReadouts = [
	{
		label: "Mode jaringan",
		value: "Lane-based coverage",
		description: "setiap SLA dikunci oleh lane, cut-off, dan tipe penanganan",
	},
	{
		label: "Node sinkron",
		value: "9 titik utama",
		description: "8 gateway regional dipantau dari control tower nasional Cikarang",
	},
	{
		label: "Trust layer",
		value: "Geo scan + photo POD",
		description: "dipakai pada layanan yang membutuhkan bukti tambahan dan recovery lebih presisi",
	},
];

const coverageCards = [
	{
		label: "Koridor primer",
		title: "Stabil antar-node",
		description: "Perpindahan volume antarnode dibaca sebagai tulang punggung jaringan nasional.",
	},
	{
		label: "Metro prioritas",
		title: "ETA lebih ketat",
		description: "Klaster metro memakai ritme dispatch berbeda agar cut-off cepat tetap realistis.",
	},
	{
		label: "Penanganan khusus",
		title: "Hanya lane tervalidasi",
		description:
			"Cold chain, secure, dan bulk drop dibuka saat suhu, volume, dan handoff lolos validasi.",
	},
];
---

<section
	id="coverage"
	class="border-mist-dark border-t bg-white py-18 lg:py-24"
	aria-labelledby="coverage-heading"
	data-home-reveal
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div class="max-w-3xl space-y-5" data-home-reveal-item>
			<p class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
				Ringkasan Jangkauan
			</p>
			<h2
				id="coverage-heading"
				class="font-display text-navy max-w-[14ch] text-[clamp(2.2rem,4.8vw,4rem)] leading-[0.98] font-bold tracking-tight"
			>
				Map ini sengaja dipakai sebagai bukti disiplin, bukan dekorasi.
			</h2>
			<p class="font-body text-charcoal max-w-[54ch] text-base leading-7 sm:text-lg">
				LintasNusa memperlihatkan coverage sebagai struktur operasional: node yang aktif, koridor
				utama yang dijaga, dan lane yang hanya dibuka saat SLA serta proof layer-nya bisa
				dipertahankan.
			</p>
			<ul class="grid gap-3 pt-2">
				{
					operatingPrinciples.map((item) => (
						<li class="font-body text-charcoal-mid grid grid-cols-[auto_1fr] gap-3 text-sm leading-6">
							<span class="bg-teal mt-2 block h-1.5 w-1.5 rounded-full" aria-hidden="true" />
							<span>{item}</span>
						</li>
					))
				}
			</ul>
			<a
				href="/jangkauan"
				class="font-body text-teal hover:text-navy focus:outline-teal inline-flex min-h-12 items-center gap-2 rounded-sm pt-3 text-sm font-semibold no-underline transition-colors duration-150 focus:outline-2 focus:outline-offset-4"
			>
				Lihat Detail Jangkauan
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path
						d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</div>

	<div class="mx-auto mt-10 w-full max-w-[112rem] px-4 sm:mt-12 sm:px-6 lg:px-8">
		<div
			class="jangkauan-map-shell jangkauan-command-shell bg-navy relative overflow-hidden rounded-[2rem] px-5 py-6 text-white sm:px-7 sm:py-7"
			data-home-reveal-item
			data-home-map-shell
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div
					class="jangkauan-command-aura bg-teal/18 absolute top-10 -left-10 h-44 w-44 rounded-full blur-3xl"
				>
				</div>
				<div
					class="jangkauan-command-aura absolute top-0 right-0 h-64 w-64 rounded-full bg-orange-400/10 blur-3xl"
				>
				</div>
				<div class="absolute inset-x-6 top-8 h-px bg-white/20"></div>
				<div class="absolute inset-x-6 bottom-8 h-px bg-white/12"></div>
				<div class="absolute inset-6 rounded-4xl border border-white/8"></div>
				<div
					class="absolute inset-x-6 top-6 bottom-6 rounded-4xl bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0))]"
				>
				</div>
			</div>

			<div class="relative z-10 space-y-6">
				<div
					class="jangkauan-command-header flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
				>
					<div class="max-w-3xl space-y-3">
						<div class="flex flex-wrap gap-2">
							{
								commandPills.map((pill) => (
									<span class="jangkauan-command-pill font-body inline-flex min-h-8 items-center rounded-full border border-white/12 bg-white/8 px-3 py-1.5 text-[0.7rem] font-semibold tracking-[0.14em] text-white/78 uppercase">
										{pill}
									</span>
								))
							}
						</div>
						<div class="space-y-2">
							<p class="font-body text-sm font-semibold tracking-[0.16em] text-white/70 uppercase">
								Lane Command View
							</p>
							<h3
								class="font-display text-[clamp(1.5rem,3vw,2.2rem)] leading-tight font-bold tracking-tight"
							>
								Gateway regional bekerja sebagai node. Cikarang menjaga satu ritme jaringan.
							</h3>
						</div>
					</div>

					<div class="jangkauan-command-caption grid max-w-lg grid-cols-1 gap-3 sm:grid-cols-3">
						{
							controlTowerReadouts.map((readout) => (
								<div class="jangkauan-command-card rounded-[1.4rem] border border-white/10 bg-white/7 px-4 py-4 backdrop-blur-sm">
									<p class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase">
										{readout.label}
									</p>
									<p class="font-display mt-2 text-lg leading-tight font-semibold text-white">
										{readout.value}
									</p>
									<p class="font-body mt-2 text-sm leading-6 text-white/68">
										{readout.description}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<p class="font-body max-w-[60ch] text-sm leading-6 text-white/78 sm:text-base">
					Diagram ini tetap skematis. Tujuannya bukan meniru peta geografis penuh, tetapi
					menunjukkan bagaimana volume nasional dibaca sebagai sistem yang terkoordinasi lalu
					dipantau terus-menerus untuk menjaga handoff dan recovery tetap sinkron.
				</p>
			</div>

			<div
				class="jangkauan-map-stage relative z-10 mt-7 overflow-hidden rounded-[1.9rem] border border-white/10 bg-[#081723]/90 p-3 sm:p-5"
			>
				<div
					class="via-teal/22 pointer-events-none absolute inset-y-5 left-0 w-1/2 bg-linear-to-r from-transparent to-transparent opacity-0 blur-2xl"
					aria-hidden="true"
				>
					<div class="jangkauan-scan-beam h-full w-full"></div>
				</div>
				<div
					class="jangkauan-scan-line pointer-events-none absolute top-5 bottom-5 left-0 w-px bg-linear-to-b from-transparent via-white/70 to-transparent opacity-0"
					aria-hidden="true"
				>
				</div>
				<div
					class="pointer-events-none absolute inset-3 rounded-3xl border border-white/6 bg-[linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(180deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[3.6rem_3.6rem]"
					aria-hidden="true"
				>
				</div>
				<div class="absolute top-4 left-4 z-20 flex flex-wrap gap-2 sm:top-5 sm:left-5">
					<span
						class="font-body border-teal/22 bg-teal/12 inline-flex min-h-8 items-center rounded-full border px-3 py-1 text-[0.66rem] font-semibold tracking-[0.16em] text-teal-100 uppercase"
					>
						control sweep aktif
					</span>
					<span
						class="font-body inline-flex min-h-8 items-center rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[0.66rem] font-semibold tracking-[0.16em] text-white/70 uppercase"
					>
						gateway-to-gateway signal
					</span>
				</div>
				<div
					class="pointer-events-none absolute inset-3 flex items-center justify-center opacity-20 mix-blend-screen sm:inset-5"
					aria-hidden="true"
				>
					<img
						src="/indonesia-blankmap.svg"
						alt=""
						class="h-full w-full scale-[1.02] object-contain brightness-0 invert"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<svg
					viewBox="0 0 640 420"
					class="relative z-10 w-full"
					role="img"
					aria-label="Diagram jaringan gateway regional dan control tower Cikarang"
				>
					<defs>
						<radialGradient id="home-control-gradient">
							<stop offset="0%" stop-color="rgba(98, 233, 214, 0.95)"></stop>
							<stop offset="65%" stop-color="rgba(98, 233, 214, 0.22)"></stop>
							<stop offset="100%" stop-color="rgba(98, 233, 214, 0)"></stop>
						</radialGradient>
						<linearGradient id="home-route-glow" x1="0%" x2="100%" y1="0%" y2="0%">
							<stop offset="0%" stop-color="rgba(255,255,255,0.16)"></stop>
							<stop offset="45%" stop-color="rgba(112,229,214,0.9)"></stop>
							<stop offset="100%" stop-color="rgba(255,255,255,0.12)"></stop>
						</linearGradient>
						<linearGradient id="home-support-glow" x1="0%" x2="100%" y1="0%" y2="0%">
							<stop offset="0%" stop-color="rgba(94, 202, 201, 0.15)"></stop>
							<stop offset="100%" stop-color="rgba(94, 202, 201, 0.55)"></stop>
						</linearGradient>
					</defs>

					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="74"
						class="jangkauan-control-glow"
						fill="url(#home-control-gradient)"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="24"
						class="jangkauan-control-ring stroke-teal/24 fill-none"
						stroke-width="1.2"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="40"
						class="jangkauan-control-ring stroke-teal/18 fill-none"
						stroke-width="1"></circle>

					{
						supportingRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-network-line jangkauan-route-support text-teal/28"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
							/>
						))
					}

					{
						primaryRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-network-line jangkauan-route-primary text-white/22"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
							/>
						))
					}

					{
						primaryRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-route-glow"
								fill="none"
								stroke="url(#home-route-glow)"
								stroke-width="4.5"
								stroke-linecap="round"
								opacity="0.45"
							/>
						))
					}

					{
						supportingRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-route-glow"
								fill="none"
								stroke="url(#home-support-glow)"
								stroke-width="3"
								stroke-linecap="round"
								opacity="0.3"
							/>
						))
					}

					{
						primaryRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-route-signal"
								fill="none"
								stroke="rgba(255,255,255,0.92)"
								stroke-width="1.4"
								stroke-dasharray="4 18"
								stroke-linecap="round"
								opacity="0.88"
							/>
						))
					}

					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="4"
						class="fill-teal/16 stroke-teal/35"
						stroke-width="1.5"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="2.5"
						class="fill-teal stroke-white/20"
						stroke-width="3"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="5.5"
						class="jangkauan-control-core fill-white/96"></circle>
					<text
						x={controlTower.titleX}
						y={controlTower.titleY}
						text-anchor="middle"
						class="jangkauan-network-label font-body fill-white text-[6px] font-semibold tracking-[0.02em]"
					>
						CIKARANG
					</text>
					<text
						x={controlTower.subtitleX}
						y={controlTower.subtitleY}
						text-anchor="middle"
						class="jangkauan-network-label font-body fill-white/62 text-[4px] font-medium tracking-[0.08em] uppercase"
					>
						CONTROL TOWER
					</text>

					{
						gatewayNodes.map((node) => (
							<>
								<circle
									cx={node.x}
									cy={node.y}
									r="4"
									class="jangkauan-node-pulse stroke-teal/30 fill-none"
									stroke-width="1.2"
								/>
								<circle
									cx={node.x}
									cy={node.y}
									r="2.5"
									class="jangkauan-network-node fill-teal stroke-white/10"
									stroke-width="2.5"
								/>
								<text
									x={node.labelX}
									y={node.labelY}
									text-anchor={node.labelAnchor}
									class="jangkauan-network-label font-body fill-white/76 text-[6px] font-semibold"
								>
									{node.city}
								</text>
							</>
						))
					}
				</svg>
			</div>

			<div class="relative z-10 mt-5 grid gap-3 text-sm leading-6 sm:grid-cols-3">
				{
					coverageCards.map((card) => (
						<div class="jangkauan-command-card rounded-3xl border border-white/10 bg-white/7 px-4 py-4 text-white/85">
							<p class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase">
								{card.label}
							</p>
							<p class="font-display mt-2 text-xl leading-tight font-semibold text-white">
								{card.title}
							</p>
							<p class="font-body mt-2 text-sm leading-6 text-white/72">{card.description}</p>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
