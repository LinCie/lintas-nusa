---
const gatewayNodes = [
	{ city: "Medan", x: 65, y: 140, labelX: 65, labelY: 130, labelAnchor: "middle" },
	{ city: "Palembang", x: 133, y: 220, labelX: 133, labelY: 210, labelAnchor: "middle" },
	{ city: "Bandung", x: 180, y: 275, labelX: 180, labelY: 285, labelAnchor: "middle" },
	{ city: "Semarang", x: 220, y: 270, labelX: 220, labelY: 260, labelAnchor: "middle" },
	{ city: "Surabaya", x: 250, y: 280, labelX: 250, labelY: 270, labelAnchor: "middle" },
	{ city: "Denpasar", x: 285, y: 295, labelX: 285, labelY: 285, labelAnchor: "middle" },
	{ city: "Balikpapan", x: 290, y: 200, labelX: 290, labelY: 190, labelAnchor: "middle" },
	{ city: "Makassar", x: 350, y: 250, labelX: 350, labelY: 240, labelAnchor: "middle" },
];

const controlTower = {
	x: 175,
	y: 265,
	titleX: 175,
	titleY: 250,
	subtitleX: 175,
	subtitleY: 255,
};

const primaryRoutes = [
	"M 65 140 Q 98 171 133 220",
	"M 133 220 Q 154 242 175 265",
	"M 175 265 Q 176 272 180 275",
	"M 180 275 Q 201 271 220 270",
	"M 220 270 Q 236 273 250 280",
	"M 250 280 Q 270 289 285 295",
	"M 175 265 Q 224 230 290 200",
	"M 290 200 Q 324 218 350 250",
];

const supportingRoutes = [
	"M 290 200 Q 347 194 398 198 Q 442 202 470 214",
	"M 350 250 Q 404 251 456 258 Q 506 277 552 304",
	"M 350 250 Q 414 239 475 210 Q 534 188 586 168",
];

const operatingPrinciples = [
	"Coverage ditentukan oleh lane yang aktif, bukan sekadar nama kota tujuan.",
	"Same-day, next-day, cold chain, dan secure handling hanya dijalankan saat mekanismenya siap.",
	"Control tower dan gateway dipakai untuk menjaga dispatch, handoff, dan exception tetap selaras.",
];

const controlTowerReadouts = [
	{
		label: "Jangkauan aktif",
		value: "247 kota & kabupaten",
		description: "dibuka hanya pada lane yang sudah tervalidasi dan bisa dijaga",
	},
	{
		label: "Node utama",
		value: "9 titik sinkron",
		description: "8 gateway regional dipantau dari control tower nasional di Cikarang",
	},
];

const coverageCards = [
	{
		label: "Koridor primer",
		title: "Stabil antar-node",
		description: "Perpindahan volume antarnode menjadi tulang punggung jaringan nasional.",
	},
	{
		label: "Metro prioritas",
		title: "ETA lebih ketat",
		description:
			"Klaster metro memakai ritme dispatch yang berbeda supaya cut-off cepat tetap realistis.",
	},
	{
		label: "Penanganan khusus",
		title: "Lane tervalidasi",
		description:
			"Cold chain, secure, dan bulk drop hanya dibuka saat suhu, volume, dan handoff bisa dijaga.",
	},
];
---

<section
	id="coverage"
	class="border-mist-dark bg-white py-18 lg:py-24"
	aria-labelledby="coverage-heading"
	data-home-reveal
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div class="max-w-3xl space-y-5" data-home-reveal-item>
			<p class="font-body text-teal text-[0.68rem] font-semibold tracking-[0.16em] uppercase">
				Ringkasan Jangkauan
			</p>
			<h2
				id="coverage-heading"
				class="font-display text-navy max-w-[14ch] text-[clamp(2.2rem,4.8vw,4rem)] leading-[0.98] font-bold tracking-tight"
			>
				Peta ini dipakai sebagai bukti disiplin, bukan dekorasi.
			</h2>
			<p class="font-body text-charcoal max-w-[54ch] text-base leading-7 sm:text-lg">
				LintasNusa menampilkan coverage sebagai struktur operasional: node yang aktif, koridor utama
				yang dijaga, dan lane yang hanya dibuka saat SLA serta proof layer-nya bisa dijaga.
			</p>
			<ul class="grid gap-3 pt-2">
				{
					operatingPrinciples.map((item) => (
						<li class="font-body text-charcoal-mid grid grid-cols-[auto_1fr] gap-3 text-sm leading-6">
							<span class="bg-teal mt-2 block h-1.5 w-1.5 rounded-full" aria-hidden="true" />
							<span>{item}</span>
						</li>
					))
				}
			</ul>
			<a
				href="/jangkauan"
				class="font-body text-teal hover:text-navy focus:outline-teal inline-flex min-h-12 items-center gap-2 rounded-sm pt-3 text-sm font-semibold no-underline transition-colors duration-150 focus:outline-2 focus:outline-offset-4"
			>
				Lihat Detail Jangkauan
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path
						d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</div>

	<div class="mx-auto mt-10 w-full max-w-[112rem] px-4 sm:mt-12 sm:px-6 lg:px-8">
		<div
			class="jangkauan-map-shell bg-navy relative overflow-hidden rounded-[1.8rem] px-5 py-6 text-white sm:px-7 sm:py-7"
			data-home-reveal-item
			data-home-map-shell
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-x-6 top-8 h-px bg-white/14"></div>
				<div class="absolute inset-x-6 bottom-8 h-px bg-white/10"></div>
				<div class="absolute inset-6 rounded-[1.5rem] border border-white/8"></div>
			</div>

			<div class="relative z-10 space-y-6">
				<div
					class="jangkauan-command-header flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
				>
					<div class="max-w-3xl space-y-3">
						<p
							class="font-body text-[0.72rem] font-semibold tracking-[0.16em] text-white/62 uppercase"
						>
							Pembacaan jaringan
						</p>
						<h3
							class="font-display text-[clamp(1.5rem,3vw,2.2rem)] leading-tight font-bold tracking-tight"
						>
							Gateway regional diperlakukan sebagai node. Cikarang menjaga ritme layanan tetap satu.
						</h3>
					</div>

					<div class="jangkauan-command-caption grid max-w-xl gap-3 sm:grid-cols-2">
						{
							controlTowerReadouts.map((readout) => (
								<div class="jangkauan-command-card rounded-[1.25rem] border border-white/10 bg-white/[0.04] px-4 py-4">
									<p class="font-body text-[0.7rem] font-semibold tracking-[0.14em] text-white/52 uppercase">
										{readout.label}
									</p>
									<p class="font-display mt-2 text-lg leading-tight font-semibold text-white">
										{readout.value}
									</p>
									<p class="font-body mt-2 text-sm leading-6 text-white/68">
										{readout.description}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<p class="font-body max-w-[60ch] text-sm leading-6 text-white/72 sm:text-base">
					Diagram ini memang skematis. Tujuannya bukan meniru peta geografis penuh, melainkan
					menunjukkan bagaimana volume nasional dikoordinasikan untuk menjaga handoff dan recovery
					tetap sinkron.
				</p>
			</div>

			<div
				class="jangkauan-map-stage relative z-10 mt-7 overflow-hidden rounded-[1.6rem] border border-[color:var(--surface-map-shell-border)] bg-[var(--surface-map-shell)] p-4 sm:p-6"
			>
				<div
					class="pointer-events-none absolute inset-4 rounded-[1.3rem] border border-[color:var(--surface-map-shell-frame)] bg-[linear-gradient(90deg,var(--surface-map-shell-grid)_1px,transparent_1px),linear-gradient(180deg,var(--surface-map-shell-grid)_1px,transparent_1px)] bg-size-[3.75rem_3.75rem]"
					aria-hidden="true"
				>
				</div>
				<div
					class="pointer-events-none absolute inset-4 flex items-center justify-center opacity-[0.12] mix-blend-screen"
					aria-hidden="true"
				>
					<img
						src="/indonesia-blankmap.svg"
						alt=""
						class="h-full w-full object-contain brightness-0 invert"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<svg
					viewBox="0 0 640 420"
					class="relative z-10 w-full"
					role="img"
					aria-label="Diagram jaringan gateway regional dan control tower Cikarang"
				>
					<defs>
						<radialGradient id="home-control-gradient">
							<stop offset="0%" stop-color="var(--surface-map-halo-strong)"></stop>
							<stop offset="65%" stop-color="var(--surface-map-halo-soft)"></stop>
							<stop offset="100%" stop-color="var(--surface-map-halo-fade)"></stop>
						</radialGradient>
					</defs>

					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="54"
						class="jangkauan-control-glow"
						fill="url(#home-control-gradient)"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="22"
						class="jangkauan-control-ring stroke-teal/18 fill-none"
						stroke-width="1.1"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="34"
						class="jangkauan-control-ring stroke-teal/12 fill-none"
						stroke-width="0.9"></circle>

					{
						supportingRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-network-line jangkauan-route-support text-teal/18"
								fill="none"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
							/>
						))
					}

					{
						primaryRoutes.map((route) => (
							<path
								d={route}
								class="jangkauan-network-line jangkauan-route-primary text-white/22"
								fill="none"
								stroke="currentColor"
								stroke-width="2.3"
								stroke-linecap="round"
							/>
						))
					}

					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="4"
						class="fill-teal/18 stroke-teal/28"
						stroke-width="1.4"></circle>
					<circle
						cx={controlTower.x}
						cy={controlTower.y}
						r="5"
						class="jangkauan-control-core fill-white/92"></circle>
					<text
						x={controlTower.titleX}
						y={controlTower.titleY}
						text-anchor="middle"
						class="jangkauan-network-label font-body hidden fill-white text-[6px] font-semibold tracking-[0.02em] sm:inline"
					>
						CIKARANG
					</text>
					<text
						x={controlTower.subtitleX}
						y={controlTower.subtitleY}
						text-anchor="middle"
						class="jangkauan-network-label font-body hidden fill-white/58 text-[4px] font-medium tracking-[0.08em] uppercase sm:inline"
					>
						CONTROL TOWER
					</text>

					{
						gatewayNodes.map((node) => (
							<>
								<circle
									cx={node.x}
									cy={node.y}
									r="4"
									class="jangkauan-node-pulse stroke-teal/18 fill-none"
									stroke-width="1"
								/>
								<circle
									cx={node.x}
									cy={node.y}
									r="2.5"
									class="jangkauan-network-node fill-teal stroke-white/8"
									stroke-width="2"
								/>
								<text
									x={node.labelX}
									y={node.labelY}
									text-anchor={node.labelAnchor}
									class="jangkauan-network-label font-body hidden fill-white/72 text-[6px] font-semibold sm:inline"
								>
									{node.city}
								</text>
							</>
						))
					}
				</svg>
			</div>

			<div class="relative z-10 mt-6 grid gap-3 text-sm leading-6 sm:grid-cols-3">
				{
					coverageCards.map((card) => (
						<div class="jangkauan-command-card rounded-[1.15rem] border border-white/10 bg-white/[0.04] px-4 py-4 text-white/82">
							<p class="font-body text-[0.7rem] font-semibold tracking-[0.14em] text-white/50 uppercase">
								{card.label}
							</p>
							<p class="font-display mt-2 text-lg leading-tight font-semibold text-white">
								{card.title}
							</p>
							<p class="font-body mt-2 text-sm leading-6 text-white/68">{card.description}</p>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
