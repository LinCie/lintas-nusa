---
const networkStats = [
	{
		target: "9",
		value: "9",
		label: "Node jaringan utama",
		description: "8 gateway regional dan 1 control tower nasional",
	},
	{
		target: "38",
		value: "38",
		label: "Satellite hub",
		description: "untuk konsolidasi antarkota dan feeder",
	},
	{
		target: "286",
		value: "286",
		label: "Service point",
		description: "pickup, handoff, dan support operasional",
	},
	{
		target: "1120",
		value: "1.120",
		label: "Armada aktif",
		description: "line-haul dan last-mile di jalur primer serta metro",
	},
];

const gatewayNodes = [
	{ city: "Medan", x: 65, y: 140, labelX: 65, labelY: 130, labelAnchor: "middle" },
	{ city: "Palembang", x: 133, y: 220, labelX: 133, labelY: 210, labelAnchor: "middle" },
	{ city: "Bandung", x: 180, y: 275, labelX: 180, labelY: 285, labelAnchor: "middle" },
	{ city: "Semarang", x: 220, y: 270, labelX: 220, labelY: 260, labelAnchor: "middle" },
	{ city: "Surabaya", x: 250, y: 280, labelX: 250, labelY: 270, labelAnchor: "middle" },
	{ city: "Denpasar", x: 285, y: 295, labelX: 285, labelY: 285, labelAnchor: "middle" },
	{ city: "Balikpapan", x: 290, y: 200, labelX: 290, labelY: 190, labelAnchor: "middle" },
	{ city: "Makassar", x: 350, y: 250, labelX: 350, labelY: 240, labelAnchor: "middle" },
];

const controlTower = {
	x: 175,
	y: 265,
	titleX: 175,
	titleY: 250,
	subtitleX: 175,
	subtitleY: 255,
};

const primaryRoutes = [
	"M 65 140 Q 98 171 133 220",
	"M 133 220 Q 154 242 175 265",
	"M 175 265 Q 176 272 180 275",
	"M 180 275 Q 201 271 220 270",
	"M 220 270 Q 236 273 250 280",
	"M 250 280 Q 270 289 285 295",
	"M 175 265 Q 224 230 290 200",
	"M 290 200 Q 324 218 350 250",
];

const supportingRoutes = [
	"M 290 200 Q 347 194 398 198 Q 442 202 470 214",
	"M 350 250 Q 404 251 456 258 Q 506 277 552 304",
	"M 350 250 Q 414 239 475 210 Q 534 188 586 168",
	"M 290 200 Q 361 186 425 171 Q 465 160 486 138",
];

const coverageLenses = [
	{
		eyebrow: "Koridor primer",
		title: "Gateway ke gateway untuk volume nasional",
		description:
			"Jalur utama dibangun untuk replenishment reguler, distribusi B2B, dan perpindahan volume antarpulau yang perlu ritme stabil.",
		details: [
			"Setiap koridor dibuka melalui node Medan, Palembang, Bandung, Semarang, Surabaya, Denpasar, Balikpapan, dan Makassar.",
			"Dispatch dan handoff dipantau dari Cikarang supaya alur antarnode tidak putus saat volume naik.",
		],
	},
	{
		eyebrow: "Metro prioritas",
		title: "Lane cepat untuk ETA yang lebih ketat",
		description:
			"Same-day dan next-day diprioritaskan di area dengan densitas order tinggi, cut-off lebih agresif, dan kebutuhan ETA yang lebih presisi.",
		details: [
			"Fokus utama berada di Jabodetabek, Bandung Raya, Surabaya Raya, dan Denpasar.",
			"Service level mengikuti lane, cut-off, dan tipe penanganan yang dipilih, bukan dipukul rata untuk semua tujuan.",
		],
	},
	{
		eyebrow: "Penanganan khusus",
		title: "Coverage yang dikunci lewat validasi operasional",
		description:
			"LN Cold, LN Secure, dan LN BulkDrop hanya aktif pada lane yang lolos validasi volume, temperatur, dan prosedur serah-terima.",
		details: [
			"Cocok untuk frozen food, barang bernilai tinggi, dan multi-drop distribusi toko.",
			"Coverage detail dikonfirmasi saat review lane dan SLA agar komitmen operasionalnya tetap realistis.",
		],
	},
];

const roleViews = [
	{
		label: "Ops",
		description: "melihat dispatch, handoff, dan exception tanpa pindah ke permukaan lain",
	},
	{
		label: "Customer service",
		description: "menindaklanjuti kendala dari status yang sama dengan tim lapangan",
	},
	{
		label: "Finance",
		description: "mencocokkan payout COD, invoice, dan bukti layanan dari satu sumber",
	},
	{
		label: "Recipient",
		description: "menerima ETA, reschedule, dan safe-drop instruction yang tetap sinkron",
	},
];

const proofMetrics = [
	{
		value: "12,4 jt",
		target: "12.4",
		suffix: " jt",
		decimal: true,
		label: "Parcel ditangani sepanjang 2025",
	},
	{
		value: "91%",
		target: "91",
		suffix: "%",
		decimal: false,
		label: "Klaim standar selesai <= 2 x 24 jam",
	},
	{
		value: "31%",
		target: "31",
		suffix: "%",
		decimal: false,
		label: "Volume berulang datang dari dashboard/API",
	},
];

const controlTowerReadouts = [
	{
		label: "Mode jaringan",
		value: "Lane-based coverage",
		description: "setiap SLA dikunci oleh lane, cut-off, dan tipe penanganan",
	},
	{
		label: "Node sinkron",
		value: "9 titik utama",
		description: "8 gateway regional dipantau dari control tower nasional Cikarang",
	},
	{
		label: "Trust layer",
		value: "Geo scan + photo POD",
		description: "dipakai pada layanan yang membutuhkan bukti tambahan dan recovery lebih presisi",
	},
];

const commandPills = [
	"247 kota & kabupaten aktif",
	"97,9% scan compliance",
	"SLA dibuka hanya pada lane tervalidasi",
];

const platformHref = Astro.url.pathname === "/" ? "#platform" : "/#platform";
---

<section
	id="jangkauan"
	aria-labelledby="jangkauan-heading"
	class="border-mist-dark relative overflow-hidden border-t bg-white py-20 lg:py-28"
>
	<div
		class="from-mist/80 pointer-events-none absolute inset-x-0 top-0 h-64 bg-linear-to-b via-white to-white"
		aria-hidden="true"
	>
	</div>

	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div
			class="relative grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)] lg:gap-16"
		>
			<header class="max-w-3xl space-y-5">
				<p class="text-navy-light font-body text-sm font-semibold tracking-[0.18em] uppercase">
					Jangkauan Nasional
				</p>
				<div class="space-y-4">
					<h2
						id="jangkauan-heading"
						class="font-display text-navy text-[clamp(2.25rem,5vw,4.25rem)] leading-[0.98] font-bold tracking-tight"
					>
						Cakupan dibuka per lane, bukan disamaratakan untuk semua layanan.
					</h2>
					<p class="font-body text-charcoal max-w-[56ch] text-base leading-7 sm:text-lg">
						LintasNusa menunjukkan coverage sebagai sistem operasional: node yang aktif, jalur yang
						dijaga, dan layanan yang hanya dibuka saat SLA-nya benar-benar bisa dipertahankan.
					</p>
				</div>
			</header>

			<div class="jangkauan-map-shell border-mist-dark bg-mist/70 rounded-4xl border p-6 sm:p-8">
				<div class="flex items-start justify-between gap-4">
					<div class="space-y-2">
						<p class="text-navy-light font-body text-sm font-semibold tracking-[0.14em] uppercase">
							Cakupan Aktif
						</p>
						<p class="font-body text-charcoal max-w-[30ch] text-sm leading-6 sm:text-base">
							247 kota dan kabupaten aktif di jaringan, lalu setiap layanan dibedakan lagi menurut
							lane, cut-off, dan penanganannya.
						</p>
					</div>
					<div class="text-right">
						<span
							class="jangkauan-number font-display text-navy block text-[clamp(3.5rem,9vw,6.25rem)] leading-none font-bold tracking-tight"
							data-target="247"
							data-suffix=""
						>
							247
						</span>
						<span class="text-charcoal-mid font-body text-sm leading-6">kota & kabupaten aktif</span
						>
					</div>
				</div>

				<div class="border-mist-dark mt-6 border-t pt-5">
					<ul class="grid gap-3 text-sm leading-6 sm:grid-cols-3">
						<li class="font-body text-charcoal">
							8 gateway regional menopang perpindahan volume utama.
						</li>
						<li class="font-body text-charcoal">
							Cikarang menjaga dispatch, handoff, dan exception tetap sinkron.
						</li>
						<li class="font-body text-charcoal">
							Lane cepat dan lane khusus hanya dibuka saat mekanismenya siap.
						</li>
					</ul>
				</div>
			</div>
		</div>

		<div
			id="jangkauan-jaringan"
			class="mt-14 scroll-mt-[calc(var(--nav-height)+1.5rem)] space-y-10"
		>
			<div
				class="jangkauan-map-shell jangkauan-command-shell bg-navy relative overflow-hidden rounded-4xl px-5 py-6 text-white sm:px-8 sm:py-8"
			>
				<div class="pointer-events-none absolute inset-0" aria-hidden="true">
					<div
						class="jangkauan-command-aura bg-teal/18 absolute top-10 -left-10 h-44 w-44 rounded-full blur-3xl"
					>
					</div>
					<div
						class="jangkauan-command-aura absolute top-0 right-0 h-64 w-64 rounded-full bg-orange-400/10 blur-3xl"
					>
					</div>
					<div class="absolute inset-x-6 top-8 h-px bg-white/20"></div>
					<div class="absolute inset-x-6 bottom-8 h-px bg-white/12"></div>
					<div class="absolute inset-6 rounded-4xl border border-white/8"></div>
					<div
						class="absolute inset-x-6 top-6 bottom-6 rounded-4xl bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0))]"
					>
					</div>
				</div>

				<div class="relative z-10 space-y-6">
					<div
						class="jangkauan-command-header flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
					>
						<div class="max-w-3xl space-y-3">
							<div class="flex flex-wrap gap-2">
								{
									commandPills.map((pill) => (
										<span class="jangkauan-command-pill font-body inline-flex min-h-8 items-center rounded-full border border-white/12 bg-white/8 px-3 py-1.5 text-[0.7rem] font-semibold tracking-[0.14em] text-white/78 uppercase">
											{pill}
										</span>
									))
								}
							</div>
							<div class="space-y-2">
								<p
									class="font-body text-sm font-semibold tracking-[0.16em] text-white/70 uppercase"
								>
									Jejak Jaringan
								</p>
								<h3
									class="font-display text-[clamp(1.5rem,3vw,2.35rem)] leading-tight font-bold tracking-tight"
								>
									Gateway regional bekerja sebagai node. Cikarang menjaga satu ritme jaringan.
								</h3>
							</div>
						</div>
						<div class="jangkauan-command-caption grid max-w-lg grid-cols-1 gap-3 sm:grid-cols-3">
							{
								controlTowerReadouts.map((readout) => (
									<div class="jangkauan-command-card rounded-[1.4rem] border border-white/10 bg-white/7 px-4 py-4 backdrop-blur-sm">
										<p class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase">
											{readout.label}
										</p>
										<p class="font-display mt-2 text-lg leading-tight font-semibold text-white">
											{readout.value}
										</p>
										<p class="font-body mt-2 text-sm leading-6 text-white/68">
											{readout.description}
										</p>
									</div>
								))
							}
						</div>
					</div>
					<p class="font-body max-w-[60ch] text-sm leading-6 text-white/78 sm:text-base">
						Diagram ini sengaja skematis. Tujuannya bukan meniru peta, tetapi menunjukkan bagaimana
						volume nasional dibaca sebagai sistem yang terkoordinasi, lalu dipindai terus-menerus
						oleh control tower untuk menjaga handoff dan recovery tetap sinkron.
					</p>
				</div>

				<div
					class="jangkauan-map-stage relative z-10 mt-7 overflow-hidden rounded-[1.9rem] border border-white/10 bg-[#081723]/90 p-3 sm:p-5"
				>
					<div
						class="via-teal/22 pointer-events-none absolute inset-y-5 left-0 w-1/2 bg-linear-to-r from-transparent to-transparent opacity-0 blur-2xl"
						aria-hidden="true"
					>
						<div class="jangkauan-scan-beam h-full w-full"></div>
					</div>
					<div
						class="jangkauan-scan-line pointer-events-none absolute top-5 bottom-5 left-0 w-px bg-linear-to-b from-transparent via-white/70 to-transparent opacity-0"
						aria-hidden="true"
					>
					</div>
					<div
						class="pointer-events-none absolute inset-3 rounded-3xl border border-white/6 bg-[linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(180deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-size-[3.6rem_3.6rem]"
						aria-hidden="true"
					>
					</div>
					<div class="absolute top-4 left-4 z-20 flex flex-wrap gap-2 sm:top-5 sm:left-5">
						<span
							class="font-body border-teal/22 bg-teal/12 inline-flex min-h-8 items-center rounded-full border px-3 py-1 text-[0.66rem] font-semibold tracking-[0.16em] text-teal-100 uppercase"
						>
							control sweep aktif
						</span>
						<span
							class="font-body inline-flex min-h-8 items-center rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[0.66rem] font-semibold tracking-[0.16em] text-white/70 uppercase"
						>
							gateway-to-gateway signal
						</span>
					</div>
					<div
						class="pointer-events-none absolute inset-3 flex items-center justify-center opacity-20 mix-blend-screen sm:inset-5"
						aria-hidden="true"
					>
						<img
							src="/indonesia-blankmap.svg"
							alt=""
							class="h-full w-full scale-[1.02] object-contain brightness-0 invert"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<svg
						viewBox="0 0 640 420"
						class="relative z-10 w-full"
						role="img"
						aria-label="Diagram jaringan gateway regional dan control tower Cikarang"
					>
						<defs>
							<radialGradient id="jangkauan-control-gradient">
								<stop offset="0%" stop-color="rgba(98, 233, 214, 0.95)"></stop>
								<stop offset="65%" stop-color="rgba(98, 233, 214, 0.22)"></stop>
								<stop offset="100%" stop-color="rgba(98, 233, 214, 0)"></stop>
							</radialGradient>
							<linearGradient id="jangkauan-route-glow" x1="0%" x2="100%" y1="0%" y2="0%">
								<stop offset="0%" stop-color="rgba(255,255,255,0.16)"></stop>
								<stop offset="45%" stop-color="rgba(112,229,214,0.9)"></stop>
								<stop offset="100%" stop-color="rgba(255,255,255,0.12)"></stop>
							</linearGradient>
							<linearGradient id="jangkauan-support-glow" x1="0%" x2="100%" y1="0%" y2="0%">
								<stop offset="0%" stop-color="rgba(94, 202, 201, 0.15)"></stop>
								<stop offset="100%" stop-color="rgba(94, 202, 201, 0.55)"></stop>
							</linearGradient>
						</defs>
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="74"
							class="jangkauan-control-glow fill-[url(#jangkauan-control-gradient)]"></circle>
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="24"
							class="jangkauan-control-ring stroke-teal/24 fill-none"
							stroke-width="1.2"></circle>
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="40"
							class="jangkauan-control-ring stroke-teal/18 fill-none"
							stroke-width="1"></circle>
						{
							primaryRoutes.map((route) => (
								<path
									d={route}
									class="jangkauan-network-line jangkauan-route-primary text-white/22"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
									stroke-linecap="round"
								/>
							))
						}
						{
							supportingRoutes.map((route) => (
								<path
									d={route}
									class="jangkauan-network-line jangkauan-route-support text-teal/28"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
							))
						}
						{
							primaryRoutes.map((route) => (
								<path
									d={route}
									class="jangkauan-route-glow"
									fill="none"
									stroke="url(#jangkauan-route-glow)"
									stroke-width="4.5"
									stroke-linecap="round"
									opacity="0.45"
								/>
							))
						}
						{
							supportingRoutes.map((route) => (
								<path
									d={route}
									class="jangkauan-route-glow"
									fill="none"
									stroke="url(#jangkauan-support-glow)"
									stroke-width="3"
									stroke-linecap="round"
									opacity="0.3"
								/>
							))
						}
						{
							primaryRoutes.map((route) => (
								<path
									d={route}
									class="jangkauan-route-signal"
									fill="none"
									stroke="rgba(255,255,255,0.92)"
									stroke-width="1.4"
									stroke-dasharray="4 18"
									stroke-linecap="round"
									opacity="0.88"
								/>
							))
						}
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="4"
							class="fill-teal/16 stroke-teal/35"
							stroke-width="1.5"></circle>
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="2.5"
							class="fill-teal stroke-white/20"
							stroke-width="3"></circle>
						<circle
							cx={controlTower.x}
							cy={controlTower.y}
							r="5.5"
							class="jangkauan-control-core fill-white/96"></circle>
						<text
							x={controlTower.titleX}
							y={controlTower.titleY}
							text-anchor="middle"
							class="jangkauan-network-label font-body fill-white text-[6px] font-semibold tracking-[0.02em]"
						>
							Cikarang
						</text>
						<text
							x={controlTower.subtitleX}
							y={controlTower.subtitleY}
							text-anchor="middle"
							class="jangkauan-network-label font-body fill-white/62 text-[4px] font-medium tracking-[0.08em] uppercase"
						>
							control tower nasional
						</text>

						{
							gatewayNodes.map((node) => (
								<>
									<circle
										cx={node.x}
										cy={node.y}
										r="4"
										class="jangkauan-node-pulse stroke-teal/30 fill-none"
										stroke-width="1.2"
									/>
									<circle
										cx={node.x}
										cy={node.y}
										r="2.5"
										class="jangkauan-network-node fill-teal stroke-white/10"
										stroke-width="2.5"
									/>
									<text
										x={node.labelX}
										y={node.labelY}
										text-anchor={node.labelAnchor}
										class="jangkauan-network-label font-body fill-white/76 text-[6px] font-semibold"
									>
										{node.city}
									</text>
								</>
							))
						}
					</svg>
				</div>

				<div class="relative z-10 mt-5 grid gap-3 text-sm leading-6 sm:grid-cols-3">
					<div
						class="jangkauan-command-card rounded-3xl border border-white/10 bg-white/7 px-4 py-4 text-white/85"
					>
						<p
							class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase"
						>
							Koridor primer
						</p>
						<p class="font-display mt-2 text-xl leading-tight font-semibold text-white">
							Stabil antar-node
						</p>
						<p class="font-body mt-2 text-sm leading-6 text-white/72">
							Perpindahan volume antarnode dibaca sebagai tulang punggung jaringan nasional.
						</p>
					</div>
					<div
						class="jangkauan-command-card rounded-3xl border border-white/10 bg-white/7 px-4 py-4 text-white/85"
					>
						<p
							class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase"
						>
							Metro prioritas
						</p>
						<p class="font-display mt-2 text-xl leading-tight font-semibold text-white">
							ETA lebih ketat
						</p>
						<p class="font-body mt-2 text-sm leading-6 text-white/72">
							Klaster metro memakai ritme dispatch berbeda agar cut-off cepat tetap realistis.
						</p>
					</div>
					<div
						class="jangkauan-command-card rounded-3xl border border-white/10 bg-white/7 px-4 py-4 text-white/85"
					>
						<p
							class="font-body text-[0.68rem] font-semibold tracking-[0.14em] text-white/55 uppercase"
						>
							Penanganan khusus
						</p>
						<p class="font-display mt-2 text-xl leading-tight font-semibold text-white">
							Hanya lane tervalidasi
						</p>
						<p class="font-body mt-2 text-sm leading-6 text-white/72">
							LN Cold, LN Secure, dan LN BulkDrop aktif saat suhu, volume, dan handoff lolos
							validasi.
						</p>
					</div>
				</div>
			</div>

			<div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start">
				<div class="border-mist-dark rounded-4xl border bg-white p-6 sm:p-8">
					<div class="space-y-2">
						<p class="font-body text-navy-light text-sm font-semibold tracking-[0.14em] uppercase">
							Jejak Operasional
						</p>
						<h3
							class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold"
						>
							Angka jaringan ini menjelaskan kapasitas baca, bukan sekadar skala.
						</h3>
					</div>
					<p class="font-body text-charcoal mt-3 max-w-[48ch] text-base leading-7">
						Yang ingin ditunjukkan di sini adalah struktur kerja coverage: node utama untuk arus
						antarwilayah, titik satelit untuk konsolidasi, service point untuk pickup dan handoff,
						lalu armada aktif yang mengunci ritme pengiriman.
					</p>

					<div class="mt-6">
						{
							networkStats.map((stat) => (
								<div class="jangkauan-network-row border-mist-dark flex items-start justify-between gap-5 border-t py-4 first:border-t-0 first:pt-0 last:pb-0">
									<dl class="max-w-[24rem] space-y-1">
										<dt class="font-body text-navy text-sm font-semibold sm:text-base">
											{stat.label}
										</dt>
										<dd class="font-body text-charcoal-mid text-sm leading-6">
											{stat.description}
										</dd>
									</dl>
									<div
										class="jangkauan-number font-display text-navy shrink-0 text-[clamp(2rem,4vw,3rem)] leading-none font-bold tracking-tight"
										data-target={stat.target}
										data-suffix=""
									>
										{stat.value}
									</div>
								</div>
							))
						}
					</div>
				</div>

				<div class="border-mist-dark bg-mist/60 rounded-4xl border p-6 sm:p-8">
					<div class="space-y-2">
						<p class="font-body text-navy-light text-sm font-semibold tracking-[0.14em] uppercase">
							Satu Status, Banyak Peran
						</p>
						<h3
							class="font-display text-navy text-[clamp(1.35rem,3vw,2rem)] leading-tight font-bold"
						>
							Coverage yang baik harus bisa dibaca serempak oleh tim ops, finance, CS, dan
							recipient.
						</h3>
					</div>
					<div class="mt-5 grid gap-3 sm:grid-cols-2">
						{
							roleViews.map((view) => (
								<div class="jangkauan-role-item rounded-2xl bg-white px-4 py-4">
									<p class="font-body text-navy text-sm font-semibold">{view.label}</p>
									<p class="font-body text-charcoal-mid mt-1 text-sm leading-6">
										{view.description}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<div
			id="jangkauan-lens"
			class="border-mist-dark mt-14 scroll-mt-[calc(var(--nav-height)+1.5rem)] border-t pt-10"
		>
			<div
				class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,0.75fr)_minmax(0,1.25fr)] lg:gap-12"
			>
				<div class="max-w-xl space-y-5">
					<div class="space-y-2">
						<p class="font-body text-navy-light text-sm font-semibold tracking-[0.14em] uppercase">
							Cara Membaca Jangkauan
						</p>
						<h3
							class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold"
						>
							Coverage explorer dimulai dari keputusan operasional yang perlu Anda buat.
						</h3>
					</div>
					<p class="font-body text-charcoal text-base leading-7">
						Alih-alih menampilkan daftar kota yang panjang, section ini memecah coverage ke tiga
						lensa yang lebih berguna: perpindahan volume utama, lane cepat untuk klaster metro, dan
						rute yang perlu validasi khusus sebelum dibuka.
					</p>
					<a
						href={platformHref}
						class="font-body bg-navy hover:bg-navy-light focus:outline-teal inline-flex min-h-11 items-center rounded-full px-5 py-3 text-sm font-semibold text-white no-underline transition-colors duration-150 focus:outline-2 focus:outline-offset-3"
					>
						Lihat cara dashboard membaca lane
					</a>
				</div>

				<ol class="space-y-4">
					{
						coverageLenses.map((lens, index) => (
							<li class="jangkauan-lane-item border-mist-dark bg-mist/50 rounded-[1.75rem] border p-5 sm:p-6">
								<div class="flex flex-col gap-5">
									<div class="flex items-start gap-4">
										<span class="font-display text-navy inline-flex size-10 items-center justify-center rounded-full bg-white text-lg font-bold">
											0{index + 1}
										</span>
										<div class="space-y-2">
											<p class="font-body text-navy-light text-xs font-semibold tracking-[0.14em] uppercase">
												{lens.eyebrow}
											</p>
											<h4 class="font-display text-navy text-[clamp(1.2rem,2.2vw,1.6rem)] leading-tight font-bold">
												{lens.title}
											</h4>
										</div>
									</div>

									<div class="grid gap-4 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
										<p class="font-body text-charcoal text-base leading-7">{lens.description}</p>
										<ul
											class="max-w-xl space-y-2"
											aria-label={`Detail ${lens.title.toLowerCase()}`}
										>
											{lens.details.map((detail) => (
												<li class="font-body text-charcoal-mid flex gap-3 text-sm leading-6">
													<span
														class="bg-teal mt-2 block h-1.5 w-1.5 shrink-0 rounded-full"
														aria-hidden="true"
													/>
													<span>{detail}</span>
												</li>
											))}
										</ul>
									</div>
								</div>
							</li>
						))
					}
				</ol>
			</div>
		</div>

		<div
			id="jangkauan-proof"
			class="border-mist-dark mt-14 scroll-mt-[calc(var(--nav-height)+1.5rem)] border-t pt-10"
		>
			<div
				class="grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(18rem,1.1fr)] lg:items-end lg:gap-12"
			>
				<div class="max-w-2xl space-y-4">
					<p class="font-body text-navy-light text-sm font-semibold tracking-[0.14em] uppercase">
						Kontrol Tower
					</p>
					<h3
						class="font-display text-navy text-[clamp(1.5rem,3vw,2.25rem)] leading-tight font-bold"
					>
						Cikarang menjaga agar visibility, recovery, dan ritme operasional dibaca dari sumber
						yang sama.
					</h3>
					<p class="font-body text-charcoal text-base leading-7">
						Bagian ini sengaja menutup section dengan bukti sistemik, bukan slogan: volume yang
						sudah lewat jaringan, kecepatan recovery klaim, dan seberapa besar aktivitas berulang
						yang datang lewat dashboard serta API.
					</p>
				</div>

				<dl class="grid grid-cols-1 gap-4 sm:grid-cols-3">
					{
						proofMetrics.map((metric) => (
							<div class="jangkauan-proof-item border-mist-dark rounded-2xl border bg-white p-5 text-center sm:text-left">
								<dt class="font-body text-navy-light text-sm font-semibold">{metric.label}</dt>
								<dd class="mt-3">
									<span
										class="jangkauan-number font-display text-navy block text-[clamp(1.9rem,4vw,2.8rem)] leading-none font-bold tracking-tight"
										data-target={metric.target}
										data-decimal={metric.decimal ? "true" : undefined}
										data-suffix={metric.suffix}
									>
										{metric.value}
									</span>
								</dd>
							</div>
						))
					}
				</dl>
			</div>
		</div>
	</div>
</section>
