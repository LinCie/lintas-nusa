---
import ServiceCard from "./ServiceCard.astro";
---

<section id="layanan" class="border-mist-dark border-t bg-white" aria-label="Layanan LintasNusa">
	<header class="mx-auto max-w-7xl px-8 py-16 lg:py-24">
		<div class="mb-4">
			<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
				>Portofolio Layanan</span
			>
		</div>
		<div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_320px] lg:gap-12">
			<h2
				class="font-display text-navy max-w-[18ch] leading-[1.05] font-bold tracking-tight"
				style="font-size: clamp(2rem, 4vw, 3rem);"
			>
				Setiap layanan, dalam satu sistem.
			</h2>
			<p class="font-body text-charcoal-mid max-w-[42ch] leading-relaxed lg:self-end">
				Dari pengiriman reguler hingga rantai dingin, semua terhubung dalam satu dasbor dengan
				pelacakan menyeluruh dan standar layanan yang jelas.
			</p>
		</div>
	</header>

	<div
		class="service-tabs-wrapper border-mist-dark border-t"
		role="region"
		aria-label="Pilih kategori layanan"
	>
		<div class="mx-auto max-w-7xl px-8">
			<div
				class="service-tab-list border-mist-dark flex gap-0 border-b pt-6"
				role="tablist"
				aria-label="Kategori layanan"
			>
				<button
					id="tab-kirim"
					role="tab"
					class="service-tab active font-body text-charcoal-mid -mb-px inline-flex cursor-pointer items-center gap-2 border-b-2 border-transparent bg-transparent px-5 py-3 text-sm font-medium transition-colors duration-150"
					aria-selected="true"
					aria-controls="panel-kirim"
					tabindex="0"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 14 14"
						fill="none"
						aria-hidden="true"
						class="tab-icon text-teal opacity-60 transition-opacity duration-150"
					>
						<path
							d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
					Kirim
				</button>
				<button
					id="tab-kelola"
					role="tab"
					class="service-tab font-body text-charcoal-mid hover:text-navy -mb-px inline-flex cursor-pointer items-center gap-2 border-b-2 border-transparent bg-transparent px-5 py-3 text-sm font-medium transition-colors duration-150"
					aria-selected="false"
					aria-controls="panel-kelola"
					tabindex="0"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 14 14"
						fill="none"
						aria-hidden="true"
						class="tab-icon opacity-60 transition-opacity duration-150"
					>
						<rect x="2" y="3" width="10" height="1.5" rx="0.75" fill="currentColor"></rect>
						<rect x="2" y="6.25" width="10" height="1.5" rx="0.75" fill="currentColor"></rect>
						<rect x="2" y="9.5" width="6" height="1.5" rx="0.75" fill="currentColor"></rect>
					</svg>
					Kelola
				</button>
			</div>
		</div>

		<div
			id="panel-kirim"
			role="tabpanel"
			aria-labelledby="tab-kirim"
			class="service-panel pt-10 pb-4 outline-none"
			tabindex="0"
		>
			<div class="mx-auto max-w-7xl px-8">
				<div class="service-hero-grid mb-2 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
					<ServiceCard
						number="01"
						tag="Paket"
						name="LN Regular"
						description="Kami melayani 247 kota dan kabupaten. Setiap perpindahan paket dipindai, jadi Anda selalu tahu posisinya."
						proofValue="97,9%"
						proofLabel="Kepatuhan Pemindaian 2025"
					/>
					<ServiceCard
						number="02"
						tag="Hari Ini"
						name="LN SameDay Metro"
						description="Pesan sebelum batas waktu, paket Anda berangkat di hari yang sama. Tersedia di klaster metro utama."
						proofValue="98,3%"
						proofLabel="Keberangkatan Tepat Waktu"
					/>
					<ServiceCard
						number="03"
						tag="COD"
						name="LN COD Clear"
						description="Penerima membayar saat paket diterima, lalu pencairannya tercatat di dasbor pada hari kerja berikutnya."
						proofValue="H+1 Kerja"
						proofLabel="Pencairan COD"
					/>
					<ServiceCard
						number="04"
						tag="Besok"
						name="LN NextDay"
						description="Untuk tujuan di jalur utama Jawa dan Sumatra, paket tiba pada hari kerja berikutnya."
						proofValue="95,8%"
						proofLabel="Terkirim di Percobaan Pertama"
					/>
				</div>

				<div
					class="service-expand-group overflow-hidden has-checked:hidden"
					id="kirim-expand"
					hidden
				>
					<div
						class="service-expand-grid grid grid-cols-1 gap-4 pt-4 sm:grid-cols-2 lg:grid-cols-4"
					>
						<ServiceCard
							number="05"
							tag="Multi Tujuan"
							name="LN BulkDrop"
							description="Pengiriman ke banyak titik untuk toko, reseller, atau kebutuhan proyek. Rute kami susun agar lebih hemat dan rapi."
							proofValue="Banyak Titik"
							proofLabel="Rute Dioptimalkan"
						/>
						<ServiceCard
							number="06"
							tag="Tukar Barang"
							name="LN Exchange"
							description="Jika penerima perlu menukar ukuran, warna, atau produk, kami tangani prosesnya tanpa membuat pesanan baru."
							proofValue="Alur Tukar"
							proofLabel="Tanpa Pesanan Baru"
						/>
					</div>
				</div>

				<button
					class="service-expand-toggle font-body text-teal hover:text-navy focus:outline-teal mt-6 inline-flex cursor-pointer items-center gap-1 border-none bg-transparent px-0 py-2 text-[13px] font-medium transition-colors duration-150 focus:rounded-sm focus:outline-2 focus:outline-offset-3"
					aria-expanded="false"
					aria-controls="kirim-expand"
					data-label-default="Lihat semua layanan Kirim"
					data-label-expanded="Sembunyikan"
				>
					<span class="toggle-label">Lihat semua layanan Kirim</span>
					<svg
						class="toggle-chevron transition-transform duration-300"
						width="12"
						height="12"
						viewBox="0 0 12 12"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M2 4L6 8L10 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</button>
			</div>
		</div>

		<div
			id="panel-kelola"
			role="tabpanel"
			aria-labelledby="tab-kelola"
			class="service-panel pt-10 pb-4 outline-none"
			tabindex="0"
			hidden
		>
			<div class="mx-auto max-w-7xl px-8">
				<div class="service-hero-grid mb-2 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
					<ServiceCard
						number="01"
						tag="Pemenuhan"
						name="LN Fulfill"
						description="Penerimaan barang, penyimpanan, pengemasan, sampai pengiriman dipantau dalam satu dasbor. Semua proses gudang tercatat di satu tempat."
						proofValue="Satu Sistem"
						proofLabel="Operasional Gudang"
					/>
					<ServiceCard
						number="02"
						tag="Rantai Dingin"
						name="LN Cold"
						description="Untuk bisnis makanan beku, paket makanan, atau produk dingin lainnya. Suhu tercatat di setiap titik pemindaian, jadi kondisinya bisa dipantau."
						proofValue="Tercatat"
						proofLabel="Suhu di Setiap Pindai"
					/>
					<ServiceCard
						number="03"
						tag="Retur"
						name="LN Return"
						description="Kami jemput retur sesuai jadwal, lalu alasan pengembaliannya dicatat dengan jelas agar tim Anda tahu apa yang perlu diperbaiki."
						proofValue="Jejak Bukti"
						proofLabel="Alur Retur"
					/>
				</div>

				<div
					class="service-expand-group overflow-hidden has-checked:hidden"
					id="kelola-expand"
					hidden
				>
					<div
						class="service-expand-grid grid grid-cols-1 gap-4 pt-4 sm:grid-cols-2 lg:grid-cols-4"
					>
						<ServiceCard
							number="04"
							tag="Klaim"
							name="LN ClaimCenter"
							description="Semua klaim masuk ke satu tempat dan ditangani oleh tim kami. Statusnya bisa Anda pantau langsung di dasbor."
							proofValue="2x24 Jam"
							proofLabel="Target Respons Klaim"
						/>
						<ServiceCard
							number="05"
							tag="Aman"
							name="LN Secure"
							description="Untuk paket bernilai tinggi, penerima diverifikasi dengan OTP dan bukti foto saat serah terima. Anda mendapat bukti yang lengkap."
							proofValue="Foto + OTP"
							proofLabel="Verifikasi Serah Terima"
						/>
						<ServiceCard
							number="06"
							tag="Cepat"
							name="LN FlashPick"
							description="Untuk produk yang cepat habis, pesanan tetap bisa berangkat di hari yang sama meski batas waktunya lebih malam."
							proofValue="Batas Akhir Lebih Malam"
							proofLabel="Jendela Kirim Hari Ini"
						/>
						<ServiceCard
							number="07"
							tag="Stok"
							name="LN Inventory View"
							description="Stok per gudang, per jenis produk, dan riwayat pergerakannya terlihat langsung. Jadi tim Anda bisa isi ulang sebelum kehabisan."
							proofValue="Selalu Terbarui"
							proofLabel="Pantauan Stok"
						/>
					</div>
				</div>

				<button
					class="service-expand-toggle font-body text-teal hover:text-navy focus:outline-teal mt-6 inline-flex cursor-pointer items-center gap-1 border-none bg-transparent px-0 py-2 text-[13px] font-medium transition-colors duration-150 focus:rounded-sm focus:outline-2 focus:outline-offset-3"
					aria-expanded="false"
					aria-controls="kelola-expand"
					data-label-default="Lihat semua layanan Kelola"
					data-label-expanded="Sembunyikan"
				>
					<span class="toggle-label">Lihat semua layanan Kelola</span>
					<svg
						class="toggle-chevron transition-transform duration-300"
						width="12"
						height="12"
						viewBox="0 0 12 12"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M2 4L6 8L10 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>

	<div class="mx-auto max-w-7xl px-8 pb-16 lg:pb-24">
		<div class="service-cta-block border-mist-dark bg-mist rounded-lg border p-8">
			<div class="service-cta-inner flex flex-wrap items-center justify-between gap-8">
				<div class="service-cta-content min-w-60 flex-1">
					<h3
						class="service-cta-heading font-display text-navy mb-1 text-lg font-bold tracking-tight"
					>
						Butuh layanan yang sesuai dengan operasional Anda?
					</h3>
					<p class="service-cta-desc font-body text-charcoal-mid text-sm leading-relaxed">
						Kami bantu pilih layanan yang paling pas berdasarkan volume, jangkauan, dan standar
						layanan yang Anda butuhkan.
					</p>
				</div>
				<a
					href="#kontak"
					class="service-cta-btn bg-navy font-body hover:bg-navy-light focus:outline-teal inline-flex shrink-0 items-center gap-2 rounded-md px-5 py-3.5 text-sm font-semibold whitespace-nowrap text-white no-underline transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(15,39,66,0.2)] focus:outline-2 focus:outline-offset-3 active:translate-y-0 active:scale-[.99]"
				>
					Jadwalkan Konsultasi Operasional
					<svg
						width="16"
						height="16"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
						class="transition-transform duration-150 group-hover:translate-x-0.5"
					>
						<path
							d="M3 8H13M13 8L8.5 3.5M13 8L8.5 12.5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.service-tab {
		border-bottom-color: transparent;
	}
	.service-tab.active {
		border-bottom-color: var(--color-teal);
		color: var(--color-navy);
		font-weight: 600;
	}
	.service-tab.active .tab-icon {
		opacity: 1;
		color: var(--color-teal);
	}
	.service-tab:not(.active):hover {
		color: var(--color-navy);
	}
	.service-tab:not(.active):hover .tab-icon {
		opacity: 1;
	}

	.service-expand-toggle[aria-expanded="true"] .toggle-chevron {
		transform: rotate(180deg);
	}
</style>

<script>
	const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
	const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

	function activateTab(target: HTMLButtonElement) {
		tabs.forEach((tab) => {
			const isActive = tab === target;
			tab.classList.toggle("active", isActive);
			tab.setAttribute("aria-selected", String(isActive));
			tab.setAttribute("tabindex", isActive ? "0" : "-1");
		});
		panels.forEach((panel) => {
			const isTarget = panel.getAttribute("aria-labelledby") === target.id;
			if (isTarget) {
				panel.removeAttribute("hidden");
				panel.focus();
			} else {
				panel.setAttribute("hidden", "");
			}
		});
		const toggle = (target as Element)
			.closest(".service-tabs-wrapper")
			?.querySelector<HTMLButtonElement>(".service-expand-toggle");
		if (toggle) {
			const expandId = toggle.getAttribute("aria-controls");
			if (!expandId) return;
			const expandGroup = document.getElementById(expandId);
			if (expandGroup) {
				const isExpanded = toggle.getAttribute("aria-expanded") === "true";
				if (isExpanded) {
					expandGroup.hidden = true;
					toggle.setAttribute("aria-expanded", "false");
					const label = toggle.querySelector(".toggle-label");
					if (label) label.textContent = toggle.dataset.labelDefault ?? "";
					const chevron = toggle.querySelector<HTMLElement>(".toggle-chevron");
					if (chevron) chevron.style.transform = "";
				}
			}
		}
	}

	tabs.forEach((tab) => {
		tab.addEventListener("click", () => activateTab(tab));
		tab.addEventListener("keydown", (e: KeyboardEvent) => {
			if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
				e.preventDefault();
				const current = Array.from(tabs).indexOf(tab);
				const next =
					e.key === "ArrowRight"
						? (current + 1) % tabs.length
						: (current - 1 + tabs.length) % tabs.length;
				tabs[next].focus();
				activateTab(tabs[next]);
			}
		});
	});

	document.querySelectorAll<HTMLButtonElement>(".service-expand-toggle").forEach((toggle) => {
		toggle.addEventListener("click", () => {
			const expandId = toggle.getAttribute("aria-controls");
			if (!expandId) return;
			const expandGroup = document.getElementById(expandId);
			if (!expandGroup) return;
			const isExpanded = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!isExpanded));
			expandGroup.hidden = isExpanded;
			const label = toggle.querySelector(".toggle-label");
			if (label) {
				label.textContent = isExpanded
					? (toggle.dataset.labelDefault ?? "")
					: (toggle.dataset.labelExpanded ?? "");
			}
		});
	});
</script>
