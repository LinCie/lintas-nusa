---
import ServiceCard from "./ServiceCard.astro";
---

<section
	id="layanan"
	class="service-section border-mist-dark border-t bg-white"
	aria-label="Layanan LintasNusa"
	data-service-section
>
	<header class="mx-auto max-w-7xl px-5 py-12 sm:px-8 sm:py-16 lg:py-24">
		<div class="mb-4">
			<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
				>Portofolio Layanan</span
			>
		</div>
		<div class="grid grid-cols-1 gap-5 sm:gap-6 lg:grid-cols-[1fr_320px] lg:gap-12">
			<h2
				class="font-display text-navy max-w-[18ch] leading-[1.05] font-bold tracking-tight"
				style="font-size: clamp(2rem, 4vw, 3rem);"
			>
				Pilih ritme layanan, lalu jalankan semuanya dalam satu sistem.
			</h2>
			<p class="font-body text-charcoal-mid max-w-[42ch] leading-relaxed lg:self-end">
				Pengiriman harian, gudang, cold chain, retur, dan klaim memakai status, bukti, dan target
				respons yang sama.
			</p>
		</div>
	</header>

	<div
		class="service-tabs-wrapper border-mist-dark border-t"
		role="region"
		aria-label="Kategori layanan"
	>
		<div class="mx-auto max-w-7xl px-5 sm:px-8">
			<nav
				class="service-tab-list border-mist-dark flex flex-wrap gap-0 border-b pt-4 sm:pt-6"
				aria-label="Loncat ke kategori layanan"
			>
				<a
					id="tab-kirim"
					href="#panel-kirim"
					data-service-tab
					data-default-active="true"
					class="service-tab font-body text-charcoal-mid focus-visible:outline-teal -mb-px inline-flex min-h-11 flex-1 items-center justify-center gap-2 border-b-2 border-transparent px-4 py-3 text-sm font-medium no-underline focus:outline-none focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-3 sm:flex-none sm:justify-start sm:px-5"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 14 14"
						fill="none"
						aria-hidden="true"
						class="tab-icon text-teal opacity-60"
					>
						<path
							d="M2 7H12M12 7L7.5 2.5M12 7L7.5 11.5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
					Kirim
				</a>
				<a
					id="tab-kelola-operasi"
					href="#panel-kelola-operasi"
					data-service-tab
					class="service-tab font-body text-charcoal-mid hover:text-navy focus-visible:outline-teal -mb-px inline-flex min-h-11 flex-1 items-center justify-center gap-2 border-b-2 border-transparent px-4 py-3 text-sm font-medium no-underline focus:outline-none focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-3 sm:flex-none sm:justify-start sm:px-5"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 14 14"
						fill="none"
						aria-hidden="true"
						class="tab-icon opacity-60"
					>
						<rect x="2" y="3" width="10" height="1.5" rx="0.75" fill="currentColor"></rect>
						<rect x="2" y="6.25" width="10" height="1.5" rx="0.75" fill="currentColor"></rect>
						<rect x="2" y="9.5" width="6" height="1.5" rx="0.75" fill="currentColor"></rect>
					</svg>
					Kelola Operasi
				</a>
			</nav>
		</div>

		<div class="service-mobile-cta mx-auto hidden max-w-7xl px-5 pt-4 sm:px-8">
			<div class="border-mist-dark bg-mist rounded-lg border px-4 py-4">
				<div class="flex flex-col gap-3">
					<div class="space-y-1">
						<p class="font-display text-navy text-base leading-tight font-bold tracking-tight">
							Perlu arahan sebelum membandingkan semua layanan?
						</p>
						<p class="font-body text-charcoal-mid text-sm leading-relaxed">
							Kami bantu pilih alur kirim atau operasi yang paling masuk akal untuk ritme Anda.
						</p>
					</div>
					<a
						href="#kontak"
						class="bg-navy font-body hover:bg-navy-light focus:outline-teal inline-flex min-h-11 w-full items-center justify-center rounded-md px-4 py-3 text-sm font-semibold text-white no-underline focus:outline-2 focus:outline-offset-3"
					>
						Bicarakan Kebutuhan Operasional
					</a>
				</div>
			</div>
		</div>

		<div
			id="panel-kirim"
			data-service-panel
			aria-labelledby="tab-kirim"
			class="service-category service-panel pt-8 pb-2 sm:pt-10 sm:pb-4"
		>
			<div class="mx-auto max-w-7xl px-5 sm:px-8">
				<div
					class="service-category-header mb-6 grid grid-cols-1 gap-4 sm:mb-8 lg:grid-cols-[minmax(0,28rem)_minmax(0,1fr)] lg:items-end lg:gap-10"
				>
					<div class="space-y-3">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
							>Kirim</span
						>
						<h3
							class="font-display text-navy max-w-[16ch] text-[1.75rem] leading-[1.08] font-bold tracking-tight"
						>
							Alur pickup sampai penerimaan yang mudah dibaca oleh tim ops dan customer service.
						</h3>
					</div>
					<p class="font-body text-charcoal-mid max-w-[44ch] text-sm leading-relaxed">
						Mulai dari lane reguler sampai COD dan same-day, setiap layanan menjelaskan kapan
						dipakai dan bukti operasional yang Anda terima.
					</p>
				</div>

				<div class="mb-4 space-y-2 sm:mb-5">
					<span
						class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
						>Layanan Inti</span
					>
					<p class="font-body text-charcoal-mid max-w-[46ch] text-sm leading-relaxed">
						Mulai dari arus kirim yang paling sering dipakai, lalu buka skenario tambahan hanya saat
						dibutuhkan.
					</p>
				</div>

				<div class="service-feature-grid grid grid-cols-1 gap-3 sm:gap-4 lg:grid-cols-2">
					<ServiceCard
						number="01"
						tag="Paket"
						name="LN Regular"
						description="Layanan reguler untuk volume kirim harian dengan status yang tetap terbaca dari pickup sampai paket diterima."
						proofValue="97,9%"
						proofLabel="Kepatuhan Pemindaian 2025"
						bestFor="volume harian lintas 247 kota dan kabupaten"
						highlights={[
							"Setiap perpindahan utama dipindai agar posisi paket tidak perlu ditebak.",
							"Status yang dilihat tim ops, finance, dan customer service tetap sinkron.",
						]}
						featured={true}
					/>
					<ServiceCard
						number="03"
						tag="COD"
						name="LN COD Clear"
						description="Pengiriman COD dengan alur pembayaran dan settlement yang terbaca di dashboard tanpa pindah sistem."
						proofValue="H+1 kerja"
						proofLabel="Target settlement COD"
						bestFor="penjualan yang dibayar saat paket diterima"
						highlights={[
							"Status kirim dan status payout mengikuti order yang sama.",
							"Finance tidak perlu merekonsiliasi COD dari laporan yang terpisah.",
						]}
						featured={true}
					/>
				</div>

				<div
					class="service-support-block border-mist-dark mt-6 space-y-4 border-t pt-5 sm:mt-8 sm:space-y-5 sm:pt-6"
				>
					<div class="flex flex-wrap items-end justify-between gap-4">
						<div class="space-y-2">
							<span
								class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
								>Lane Harian</span
							>
							<h4
								class="font-display text-navy text-[1.25rem] leading-tight font-bold tracking-tight"
							>
								Pilihan kecepatan untuk area dan ritme kirim yang berbeda.
							</h4>
						</div>
						<p class="font-body text-charcoal-mid max-w-[36ch] text-sm leading-relaxed">
							Gunakan saat Anda sudah tahu pola rute dan batas waktu yang dibutuhkan.
						</p>
					</div>
					<div class="service-support-grid grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
						<ServiceCard
							number="02"
							tag="Hari Ini"
							name="LN SameDay Metro"
							description="Pesan sebelum batas waktu dan paket berangkat di hari yang sama untuk klaster metro utama."
							proofValue="98,3%"
							proofLabel="Keberangkatan tepat waktu 2025"
						/>
						<ServiceCard
							number="04"
							tag="Besok"
							name="LN NextDay"
							description="Untuk jalur utama Jawa dan Sumatra, paket tiba pada hari kerja berikutnya dengan alur scan yang sama."
							proofValue="95,8%"
							proofLabel="Keberhasilan kirim pertama 2025"
						/>
					</div>
				</div>

				<button
					class="service-expand-toggle font-body text-teal hover:text-navy focus:outline-teal mt-5 inline-flex min-h-11 items-center gap-1 border-none bg-transparent px-0 py-2 text-sm font-medium focus:rounded-sm focus:outline-2 focus:outline-offset-3 sm:mt-6"
					aria-expanded="false"
					aria-controls="kirim-expand"
					data-label-default="Lihat skenario kirim tambahan"
					data-label-expanded="Sembunyikan skenario kirim tambahan"
					type="button"
					hidden
				>
					<span class="toggle-label">Lihat skenario kirim tambahan</span>
					<svg
						class="toggle-chevron"
						width="12"
						height="12"
						viewBox="0 0 12 12"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M2 4L6 8L10 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</button>

				<div
					class="service-expand-group border-mist-dark mt-5 space-y-4 border-t pt-5 sm:mt-6 sm:space-y-5 sm:pt-6"
					id="kirim-expand"
				>
					<div class="flex flex-wrap items-end justify-between gap-4">
						<div class="space-y-2">
							<span
								class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
								>Skenario Tambahan</span
							>
							<h4
								class="font-display text-navy text-[1.25rem] leading-tight font-bold tracking-tight"
							>
								Saat operasi butuh alur yang tidak masuk lane harian.
							</h4>
						</div>
						<p class="font-body text-charcoal-mid max-w-[36ch] text-sm leading-relaxed">
							Multi-drop dan tukar barang tetap memakai jejak status yang sama dengan kirim utama.
						</p>
					</div>
					<div class="service-expand-grid grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
						<ServiceCard
							number="05"
							tag="Multi Tujuan"
							name="LN BulkDrop"
							description="Pengiriman ke banyak titik untuk toko, reseller, atau kebutuhan proyek dengan urutan rute yang dikonsolidasikan lebih dulu."
							proofValue="Rute multi-drop"
							proofLabel="Konsolidasi banyak titik"
						/>
						<ServiceCard
							number="06"
							tag="Tukar Barang"
							name="LN Exchange"
							description="Jika penerima perlu menukar ukuran, warna, atau produk, alurnya tetap berjalan tanpa membuat pesanan baru."
							proofValue="Tanpa order baru"
							proofLabel="Tukar barang satu alur"
						/>
					</div>
				</div>
			</div>
		</div>

		<div
			id="panel-kelola-operasi"
			data-service-panel
			aria-labelledby="tab-kelola-operasi"
			class="service-category service-panel pt-8 pb-2 sm:pt-10 sm:pb-4"
		>
			<div class="mx-auto max-w-7xl px-5 sm:px-8">
				<div
					class="service-category-header mb-6 grid grid-cols-1 gap-4 sm:mb-8 lg:grid-cols-[minmax(0,28rem)_minmax(0,1fr)] lg:items-end lg:gap-10"
				>
					<div class="space-y-3">
						<span class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
							>Kelola Operasi</span
						>
						<h3
							class="font-display text-navy max-w-[16ch] text-[1.75rem] leading-[1.08] font-bold tracking-tight"
						>
							Gudang, recovery, dan bukti serah terima tetap berada dalam satu alur operasi.
						</h3>
					</div>
					<p class="font-body text-charcoal-mid max-w-[44ch] text-sm leading-relaxed">
						Dirancang untuk tim operasi, finance, dan customer service yang butuh status yang sama,
						bukti yang sama, dan target respons yang jelas.
					</p>
				</div>

				<div class="mb-4 space-y-2 sm:mb-5">
					<span
						class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
						>Layanan Inti</span
					>
					<p class="font-body text-charcoal-mid max-w-[46ch] text-sm leading-relaxed">
						Fokus pada alur yang paling sering dipakai untuk fulfillment dan pemulihan layanan.
					</p>
				</div>

				<div class="service-feature-grid grid grid-cols-1 gap-3 sm:gap-4 lg:grid-cols-2">
					<ServiceCard
						number="01"
						tag="Pemenuhan"
						name="LN Fulfill"
						description="Inbound, penyimpanan, pick-pack-ship, sampai outbound tercatat di satu alur dashboard yang sama."
						proofValue="Satu login lintas peran"
						proofLabel="Ops, finance, dan customer service"
						bestFor="brand dengan stok aktif dan dispatch harian"
						highlights={[
							"Inbound, pick-pack-ship, dan outbound tidak terpecah ke laporan yang berbeda.",
							"Owner, ops, dan finance melihat progres gudang dari sistem yang sama.",
						]}
						featured={true}
					/>
					<ServiceCard
						number="02"
						tag="Rantai Dingin"
						name="LN Cold"
						description="Layanan chilled dan frozen dengan log suhu yang mengikuti titik pindai utama sepanjang perjalanan."
						proofValue="Log suhu per pindai"
						proofLabel="Rantai dingin tercatat"
						bestFor="makanan beku, meal kit, dan produk sensitif suhu"
						highlights={[
							"Tim dapat menelusuri kondisi paket tanpa meminta bukti manual ke lapangan.",
							"Jejak suhu menyatu dengan status kirim sehingga recovery lebih cepat dimulai.",
						]}
						featured={true}
					/>
				</div>

				<div
					class="service-support-block border-mist-dark mt-6 space-y-4 border-t pt-5 sm:mt-8 sm:space-y-5 sm:pt-6"
				>
					<div class="flex flex-wrap items-end justify-between gap-4">
						<div class="space-y-2">
							<span
								class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
								>Recovery Utama</span
							>
							<h4
								class="font-display text-navy text-[1.25rem] leading-tight font-bold tracking-tight"
							>
								Alur retur dan klaim yang perlu terbaca tanpa tarik data manual.
							</h4>
						</div>
						<p class="font-body text-charcoal-mid max-w-[36ch] text-sm leading-relaxed">
							Dipakai saat tim Anda perlu tahu penyebab masalah dan kapan penanganannya dimulai.
						</p>
					</div>
					<div class="service-support-grid grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
						<ServiceCard
							number="03"
							tag="Retur"
							name="LN Return"
							description="Retur dijemput sesuai jadwal dan alasan pengembaliannya dicatat agar tim Anda tahu apa yang perlu diperbaiki."
							proofValue="Alasan retur terkode"
							proofLabel="Jejak penyebab retur"
						/>
						<ServiceCard
							number="04"
							tag="Klaim"
							name="LN ClaimCenter"
							description="Semua klaim masuk ke satu tempat dengan status yang bisa dipantau langsung di dashboard oleh tim terkait."
							proofValue="2 x 24 jam"
							proofLabel="Target respons awal klaim"
						/>
					</div>
				</div>

				<button
					class="service-expand-toggle font-body text-teal hover:text-navy focus:outline-teal mt-5 inline-flex min-h-11 items-center gap-1 border-none bg-transparent px-0 py-2 text-sm font-medium focus:rounded-sm focus:outline-2 focus:outline-offset-3 sm:mt-6"
					aria-expanded="false"
					aria-controls="kelola-expand"
					data-label-default="Lihat layanan operasi tambahan"
					data-label-expanded="Sembunyikan layanan operasi tambahan"
					type="button"
					hidden
				>
					<span class="toggle-label">Lihat layanan operasi tambahan</span>
					<svg
						class="toggle-chevron"
						width="12"
						height="12"
						viewBox="0 0 12 12"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M2 4L6 8L10 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</button>

				<div
					class="service-expand-group border-mist-dark mt-5 space-y-4 border-t pt-5 sm:mt-6 sm:space-y-5 sm:pt-6"
					id="kelola-expand"
				>
					<div class="flex flex-wrap items-end justify-between gap-4">
						<div class="space-y-2">
							<span
								class="text-charcoal-mid/70 font-mono text-[10px] font-medium tracking-[0.2em] uppercase"
								>Tambahan Operasi</span
							>
							<h4
								class="font-display text-navy text-[1.25rem] leading-tight font-bold tracking-tight"
							>
								Lapis bukti dan visibilitas saat alur inti perlu diperluas.
							</h4>
						</div>
						<p class="font-body text-charcoal-mid max-w-[36ch] text-sm leading-relaxed">
							Pakai saat order bernilai tinggi, cut-off bergeser, atau stok perlu diawasi lebih
							rapat.
						</p>
					</div>
					<div
						class="service-expand-grid grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3"
					>
						<ServiceCard
							number="05"
							tag="Aman"
							name="LN Secure"
							description="Untuk paket bernilai tinggi, penerima diverifikasi dengan OTP dan foto saat serah terima."
							proofValue="OTP + foto POD"
							proofLabel="Serah terima tervalidasi"
						/>
						<ServiceCard
							number="06"
							tag="Cepat"
							name="LN FlashPick"
							description="Untuk produk yang cepat habis, pesanan tetap bisa berangkat di hari yang sama meski cut-off lebih malam."
							proofValue="Cut-off lebih malam"
							proofLabel="Dispatch hari yang sama"
						/>
						<ServiceCard
							number="07"
							tag="Stok"
							name="LN Inventory View"
							description="Stok per gudang, per SKU, dan riwayat pergerakannya terlihat untuk membantu tim mengisi ulang lebih cepat."
							proofValue="Per gudang dan per SKU"
							proofLabel="Riwayat stok terlihat"
						/>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="service-cta-shell mx-auto max-w-7xl px-5 pb-12 sm:px-8 sm:pb-16 lg:pb-24">
		<div class="service-cta-block border-mist-dark bg-mist rounded-lg border p-5 sm:p-8">
			<div class="service-cta-inner flex flex-wrap items-center justify-between gap-6 sm:gap-8">
				<div class="service-cta-content min-w-60 flex-1">
					<h3
						class="service-cta-heading font-display text-navy mb-1 text-lg font-bold tracking-tight"
					>
						Butuh layanan yang sesuai dengan operasional Anda?
					</h3>
					<p class="service-cta-desc font-body text-charcoal-mid text-sm leading-relaxed">
						Kami bantu pilih layanan yang paling pas berdasarkan volume, jangkauan, dan standar
						layanan yang Anda butuhkan.
					</p>
				</div>
				<a
					href="#kontak"
					class="service-cta-btn group bg-navy font-body hover:bg-navy-light focus:outline-teal inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-md px-5 py-3.5 text-sm font-semibold text-white no-underline focus:outline-2 focus:outline-offset-3 sm:w-auto"
				>
					Jadwalkan Konsultasi Operasional
					<svg
						width="16"
						height="16"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
						class="service-cta-icon"
					>
						<path
							d="M3 8H13M13 8L8.5 3.5M13 8L8.5 12.5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.service-tab {
		border-bottom-color: transparent;
	}

	.service-tab.active {
		border-bottom-color: var(--color-teal);
		color: var(--color-navy);
		font-weight: 600;
	}

	.service-tab.active .tab-icon {
		opacity: 1;
		color: var(--color-teal);
	}

	.service-tab:not(.active):hover .tab-icon,
	.service-tab:focus-visible .tab-icon {
		opacity: 1;
	}

	.service-mobile-cta {
		display: none;
	}

	@media (max-width: 39.999rem) {
		.service-section[data-enhanced="true"] .service-mobile-cta {
			display: block;
		}

		.service-section[data-enhanced="true"] .service-cta-shell {
			display: none;
		}
	}
</style>
