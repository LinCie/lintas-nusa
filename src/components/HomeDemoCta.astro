---
const demoAgenda = [
	"Pembacaan lane prioritas, ritme pickup, dan exception yang paling sering mengganggu operasi.",
	"Demo bagaimana ops, finance, dan customer service membaca status, payout, dan klaim dari alur yang sama.",
	"Pembahasan SLA, proof layer, dan kesiapan integrasi sebelum tahap teknis diperdalam.",
];

const channels = [
	{
		label: "Email demo",
		value: "partner@lintasnusa.co.id",
		href: "mailto:partner@lintasnusa.co.id?subject=Permintaan%20Demo%20LintasNusa",
	},
	{
		label: "WhatsApp bisnis",
		value: "+62 812 3456 7890",
		href: "https://wa.me/6281234567890",
	},
];
---

<section
	id="demo"
	class="border-mist-dark border-t bg-white py-18 lg:py-24"
	aria-labelledby="demo-heading"
	data-home-reveal
>
	<div class="mx-auto max-w-7xl px-6 sm:px-8">
		<div
			class="bg-navy relative overflow-hidden rounded-[2.2rem] px-6 py-8 text-white sm:px-8 sm:py-10 lg:px-10 lg:py-12"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="bg-teal/14 absolute -top-8 right-16 h-40 w-40 rounded-full blur-3xl"></div>
				<div class="bg-orange/12 absolute bottom-2 left-12 h-44 w-44 rounded-full blur-3xl"></div>
				<div class="absolute inset-x-8 top-8 h-px bg-white/14"></div>
			</div>

			<div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.82fr)] lg:gap-12">
				<div class="space-y-5" data-home-reveal-item>
					<p class="text-teal font-mono text-[10px] font-medium tracking-[0.2em] uppercase">
						Formal Demo
					</p>
					<h2
						id="demo-heading"
						class="font-display max-w-[13ch] text-[clamp(2rem,4vw,3.4rem)] leading-[1] font-bold tracking-tight text-white"
					>
						Jadwalkan demo untuk membaca kecocokan sistem dan lane lebih jauh.
					</h2>
					<p class="font-body max-w-[54ch] text-base leading-7 text-white/78 sm:text-lg">
						Sesi ini ditujukan untuk tim enterprise yang sudah ingin menilai fit operasional, bukan
						sekadar melihat katalog layanan. Kami akan masuk ke struktur workflow, proof layer, dan
						target layanan yang realistis untuk jaringan Anda.
					</p>

					<div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
						<a
							href="mailto:partner@lintasnusa.co.id?subject=Permintaan%20Demo%20LintasNusa"
							class="bg-orange font-body hover:bg-orange-hover inline-flex min-h-12 items-center justify-center rounded-md px-6 py-4 text-[15px] font-semibold text-white no-underline transition-colors duration-150 focus:outline-2 focus:outline-offset-3 focus:outline-white sm:min-w-56"
						>
							Jadwalkan Demo via Email
						</a>
						<a
							href="https://wa.me/6281234567890"
							class="font-body text-teal hover:border-teal inline-flex min-h-12 items-center justify-center rounded-md border border-white/18 px-6 py-4 text-[15px] font-semibold no-underline transition-colors duration-150 hover:text-white focus:outline-2 focus:outline-offset-3 focus:outline-white sm:min-w-52"
						>
							Koordinasi via WhatsApp
						</a>
					</div>
				</div>

				<div
					class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5 backdrop-blur-sm sm:p-6"
					data-home-reveal-item
				>
					<p class="font-body text-sm font-semibold tracking-[0.14em] text-white/68 uppercase">
						Agenda yang dibahas
					</p>
					<ul class="mt-5 grid gap-4">
						{
							demoAgenda.map((item) => (
								<li class="grid grid-cols-[auto_1fr] gap-3">
									<span class="bg-teal mt-2 block h-1.5 w-1.5 rounded-full" aria-hidden="true" />
									<p class="font-body text-sm leading-6 text-white/82">{item}</p>
								</li>
							))
						}
					</ul>

					<div class="mt-6 grid gap-4 border-t border-white/10 pt-5">
						{
							channels.map((channel) => (
								<div>
									<p class="font-body text-xs font-semibold tracking-[0.08em] text-white/56 uppercase">
										{channel.label}
									</p>
									<a
										href={channel.href}
										class="font-body mt-1 block text-sm leading-6 text-white/84 no-underline transition-colors duration-150 hover:text-white"
									>
										{channel.value}
									</a>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
